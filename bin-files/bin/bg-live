#!/usr/bin/env sh

WALLPAPER_DIR="$HOME/.config/themes/current/wallpapers"
CURRENT_LINK="$HOME/.config/themes/current/wallpaper.png"
LIVEPAPER_BIN="$HOME/builds/livepaper/livepaper"
FLAGS="--transition-type=fade --transition-duration=0.3"

# Get current theme from symlink
THEME_PATH=$(readlink -f "$HOME/.config/themes/current")
THEME_RAW=$(basename "$THEME_PATH")

# Format theme name
THEME=$(echo "$THEME_RAW" \
    | tr '-' ' ' \
    | sed -E 's/\b(.)/\U\1/g')

if pgrep -x livepaper >/dev/null 2>&1; then
    pkill -USR1 -x livepaper >/dev/null 2>&1
    exit 0
fi

notify-send -t 2000 "Background" "Opened $THEME live gallery."

if [ ! -x "$LIVEPAPER_BIN" ]; then
    notify-send -t 4000 "Background" "livepaper binary not found at $LIVEPAPER_BIN"
    exit 1
fi

run_livepaper() {
    "$LIVEPAPER_BIN" --switch-cmd "awww img $FLAGS {}" --link "$CURRENT_LINK" "$WALLPAPER_DIR"
}

run_livepaper

SELECTED_WALL=$(readlink -f "$CURRENT_LINK")
[ -z "$SELECTED_WALL" ] && exit 0

# Extract filename
FILENAME=$(basename "$SELECTED_WALL")
NAME="${FILENAME%.*}"

# Remove leading digits + dash
NAME=$(echo "$NAME" | sed -E 's/^[0-9]+-//')
