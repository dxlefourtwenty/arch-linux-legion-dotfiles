#!/usr/bin/env bash

WALL_DIR="$HOME/.config/themes/current/wallpapers"
CURRENT_LINK="$HOME/.config/themes/current/wallpaper.png"

# Ensure directory exists
[ -d "$WALL_DIR" ] || exit 1

# Get current filename from symlink
CURRENT_FILE=$(basename "$(readlink -f "$CURRENT_LINK")")

# Extract leading number
CURRENT_NUM=$(echo "$CURRENT_FILE" | grep -o '^[0-9]\+')

# Build sorted numeric list of wallpapers
mapfile -t FILES < <(
    find "$WALL_DIR" -maxdepth 1 -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" \) \
    -printf "%f\n" \
    | sort -n
)

# If nothing found
[ ${#FILES[@]} -eq 0 ] && exit 1

# Default next file
NEXT_FILE="${FILES[0]}"

# Find next higher number
for FILE in "${FILES[@]}"; do
    NUM=$(echo "$FILE" | grep -o '^[0-9]\+')
    if [[ "$NUM" -gt "$CURRENT_NUM" ]]; then
        NEXT_FILE="$FILE"
        break
    fi
done

FULL_PATH="$WALL_DIR/$NEXT_FILE"

# Set wallpaper with diagonal wipe
swww img "$FULL_PATH" \
    --transition-type wipe \
    --transition-angle 45 \
    --transition-duration 2

# Update symlink
ln -sf "$FULL_PATH" "$CURRENT_LINK"

notify-send -t 2500 "Background" "Updated to next."
