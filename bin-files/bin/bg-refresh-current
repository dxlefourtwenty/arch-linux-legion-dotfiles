#!/usr/bin/env bash
set -euo pipefail

FLAGS="--transition-type=none"
SELECTED="$HOME/.config/themes/current/wallpaper.png"
READY=0

# Ensure the daemon exists, but don't let a failed restart stall theme changes.
if ! pgrep -x awww-daemon >/dev/null 2>&1; then
    nohup awww-daemon >/dev/null 2>&1 &
fi

for _ in {1..8}; do
    if timeout 0.25s awww query >/dev/null 2>&1; then
        READY=1
        break
    fi

    sleep 0.15
done

[ "$READY" -eq 1 ] || exit 0

awww img "$SELECTED" $FLAGS
