#!/usr/bin/env bash
set -euo pipefail

CURSOR_FILE="$HOME/.config/themes/current/cursor"
HYPR_ENV_FILE="$HOME/.config/hypr/environment.conf"
HYPR_MAIN_CONF="$HOME/.config/hypr/hyprland.conf"
HYPR_CURSOR_CONF="$HOME/.config/hypr/cursor.conf"
GTK3_SETTINGS="$HOME/.config/gtk-3.0/settings.ini"
GTK4_SETTINGS="$HOME/.config/gtk-4.0/settings.ini"
XCURSOR_INDEX="$HOME/.icons/default/index.theme"

DEFAULT_CURSOR="Bibata-Modern-Ice"
DEFAULT_SIZE=24

trim() {
    sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

theme_exists() {
    local theme="$1"
    resolve_theme_path "$theme" >/dev/null
}

resolve_theme_path() {
    local theme="$1"
    local candidate

    for candidate in \
        "/usr/share/icons/$theme" \
        "$HOME/.local/share/icons/$theme" \
        "$HOME/.icons/$theme" \
        "$HOME/.local/.local/share/icons/Bibata-Custom/$theme" \
        "$HOME/dotfiles/.local/share/icons/Bibata-Custom/$theme"
    do
        if [ -d "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

ensure_local_cursor_theme() {
    local theme="$1"
    local local_target="$HOME/.local/share/icons/$theme"
    local source_path

    mkdir -p "$HOME/.local/share/icons"

    if [ -e "$local_target" ]; then
        return
    fi

    source_path="$(resolve_theme_path "$theme")" || return 1
    ln -s "$source_path" "$local_target"
}

read_current_size() {
    if [ -f "$HYPR_ENV_FILE" ]; then
        local configured_size
        configured_size="$(sed -n 's/^[[:space:]]*env = XCURSOR_SIZE,\(.*\)$/\1/p' "$HYPR_ENV_FILE" | tail -n 1 | trim)"
        if [ -n "${configured_size:-}" ]; then
            printf '%s\n' "$configured_size"
            return
        fi
    fi

    printf '%s\n' "$DEFAULT_SIZE"
}

upsert_kv_file() {
    local file="$1"
    local key="$2"
    local value="$3"

    mkdir -p "$(dirname "$file")"

    if [ ! -f "$file" ]; then
        printf '[Settings]\n%s=%s\n' "$key" "$value" > "$file"
        return
    fi

    if rg -q "^${key}=" "$file"; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$file"
    else
        if ! rg -q '^\[Settings\]$' "$file"; then
            printf '\n[Settings]\n' >> "$file"
        fi
        printf '%s=%s\n' "$key" "$value" >> "$file"
    fi
}

upsert_hypr_env() {
    local file="$1"
    local cursor="$2"
    local size="$3"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    local tmp
    tmp="$(mktemp "${file}.XXXXXX")"

    awk -F',' '
        BEGIN {
            seen_xcursor_theme = 0
            seen_xcursor_size = 0
        }
        /^[[:space:]]*env = XCURSOR_THEME,/ {
            print "env = XCURSOR_THEME," cursor
            seen_xcursor_theme = 1
            next
        }
        /^[[:space:]]*env = HYPRCURSOR_THEME,/ {
            next
        }
        /^[[:space:]]*env = XCURSOR_SIZE,/ {
            print "env = XCURSOR_SIZE," size
            seen_xcursor_size = 1
            next
        }
        /^[[:space:]]*env = HYPRCURSOR_SIZE,/ {
            next
        }
        { print }
        END {
            if (!seen_xcursor_theme) {
                print "env = XCURSOR_THEME," cursor
            }
            if (!seen_xcursor_size) {
                print "env = XCURSOR_SIZE," size
            }
        }
    ' cursor="$cursor" size="$size" "$file" > "$tmp"

    mv "$tmp" "$file"
}

ensure_hypr_cursor_source() {
    local main_conf="$1"
    local cursor_conf="$2"
    local source_line="source = ~/.config/hypr/$(basename "$cursor_conf")"

    mkdir -p "$(dirname "$main_conf")"
    touch "$main_conf"

    if rg -qxF "$source_line" "$main_conf"; then
        return
    fi

    local tmp
    tmp="$(mktemp "${main_conf}.XXXXXX")"

    awk -v source_line="$source_line" '
        { print }
        /^source = ~\/\.config\/hypr\/environment\.conf$/ && !inserted {
            print source_line
            inserted = 1
        }
        END {
            if (!inserted) {
                print source_line
            }
        }
    ' "$main_conf" > "$tmp"

    mv "$tmp" "$main_conf"
}

write_hypr_cursor_conf() {
    local file="$1"
    local cursor="$2"
    local size="$3"

    mkdir -p "$(dirname "$file")"
    cat > "$file" <<EOF
exec-once = hyprctl setcursor $cursor $size
EOF
}

CURSOR="${1:-}"

if [ -z "$CURSOR" ] && [ -f "$CURSOR_FILE" ]; then
    CURSOR="$(trim < "$CURSOR_FILE")"
fi

if [ -z "$CURSOR" ]; then
    CURSOR="$DEFAULT_CURSOR"
fi

if ! theme_exists "$CURSOR"; then
    CURSOR="$DEFAULT_CURSOR"
fi

SIZE="$(read_current_size)"

echo "Applying cursor theme: $CURSOR ($SIZE)"

ensure_local_cursor_theme "$CURSOR"
upsert_hypr_env "$HYPR_ENV_FILE" "$CURSOR" "$SIZE"
ensure_hypr_cursor_source "$HYPR_MAIN_CONF" "$HYPR_CURSOR_CONF"
write_hypr_cursor_conf "$HYPR_CURSOR_CONF" "$CURSOR" "$SIZE"

upsert_kv_file "$GTK3_SETTINGS" "gtk-cursor-theme-name" "$CURSOR"
upsert_kv_file "$GTK3_SETTINGS" "gtk-cursor-theme-size" "$SIZE"
upsert_kv_file "$GTK4_SETTINGS" "gtk-cursor-theme-name" "$CURSOR"
upsert_kv_file "$GTK4_SETTINGS" "gtk-cursor-theme-size" "$SIZE"

mkdir -p "$(dirname "$XCURSOR_INDEX")"
cat > "$XCURSOR_INDEX" <<EOF
[Icon Theme]
Inherits=$CURSOR
EOF

gsettings set org.gnome.desktop.interface cursor-theme "$CURSOR" >/dev/null 2>&1 || true
gsettings set org.gnome.desktop.interface cursor-size "$SIZE" >/dev/null 2>&1 || true

hyprctl setcursor "$CURSOR" "$SIZE" >/dev/null 2>&1 || true
