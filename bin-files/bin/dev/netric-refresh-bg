#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="netric-refresh-bg"
NETRIC_BACKEND_DIR="/home/dxle/dev/coding-in-class/spring2026/4800CS/netric/backend"
DEFAULT_PYTHON_BIN="${NETRIC_BACKEND_DIR}/venv/bin/python"
FALLBACK_PYTHON_BIN="/usr/bin/python3"
PID_FILE="/tmp/netric-nightly-refresh.pid"
LOG_DIR="${NETRIC_BACKEND_DIR}/logs"

usage() {
  /usr/bin/cat <<USAGE
Usage: ${SCRIPT_NAME} [start|status|stop] [options]

Commands:
  start                 Start nightly refresh in background (default)
  status                Show running status
  stop                  Stop running refresh process

Options (for start):
  --season-ids <ids>    Comma-separated seasons (example: 2025-26,2024-25)
  --max-seasons <n>     Max seasons to store when --season-ids is not set
  --dry-run             Print planned command without starting
  -h, --help            Show this help
USAGE
}

announce() {
  local title="$1"
  local body="$2"

  if [ -x /home/dxle/bin/notify-send ]; then
    /home/dxle/bin/notify-send "$title" "$body"
  fi

  /usr/bin/printf '%s\n' "$body"
}

resolve_python_bin() {
  if [ -x "$DEFAULT_PYTHON_BIN" ]; then
    /usr/bin/printf '%s\n' "$DEFAULT_PYTHON_BIN"
    return
  fi

  /usr/bin/printf '%s\n' "$FALLBACK_PYTHON_BIN"
}

is_running() {
  if [ ! -f "$PID_FILE" ]; then
    return 1
  fi

  local pid
  pid="$(/usr/bin/cat "$PID_FILE")"

  if [ -z "$pid" ]; then
    return 1
  fi

  if /usr/bin/kill -0 "$pid" 2>/dev/null; then
    return 0
  fi

  return 1
}

start_refresh() {
  local dry_run="false"
  local season_ids=""
  local max_seasons=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        dry_run="true"
        ;;
      --season-ids)
        if [ "$#" -lt 2 ] || [ -z "${2:-}" ]; then
          /usr/bin/printf 'Error: --season-ids requires a value\n' >&2
          exit 2
        fi
        season_ids="$2"
        shift
        ;;
      --max-seasons)
        if [ "$#" -lt 2 ] || [ -z "${2:-}" ]; then
          /usr/bin/printf 'Error: --max-seasons requires a value\n' >&2
          exit 2
        fi
        if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -le 0 ]; then
          /usr/bin/printf 'Error: --max-seasons must be a positive integer\n' >&2
          exit 2
        fi
        max_seasons="$2"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        /usr/bin/printf 'Error: unknown option: %s\n' "$1" >&2
        usage
        exit 2
        ;;
    esac
    shift
  done

  if [ ! -d "$NETRIC_BACKEND_DIR" ]; then
    /usr/bin/printf 'Error: backend directory not found: %s\n' "$NETRIC_BACKEND_DIR" >&2
    exit 1
  fi

  if is_running; then
    local active_pid
    active_pid="$(/usr/bin/cat "$PID_FILE")"
    announce "Netric Refresh" "Already running (pid ${active_pid})"
    exit 0
  fi

  /usr/bin/mkdir -p "$LOG_DIR"

  local timestamp
  timestamp="$(/usr/bin/date +%Y%m%d-%H%M%S)"
  local log_file
  log_file="${LOG_DIR}/nightly-refresh-${timestamp}.log"

  local python_bin
  python_bin="$(resolve_python_bin)"

  local command
  command="cd '${NETRIC_BACKEND_DIR}' &&"

  if [ -n "$season_ids" ]; then
    command="${command} NBA_SEASON_IDS_TO_STORE='${season_ids}'"
  fi

  if [ -n "$max_seasons" ]; then
    command="${command} NBA_MAX_SEASONS_TO_STORE='${max_seasons}'"
  fi

  command="${command} '${python_bin}' nightly_refresh.py"

  if [ "$dry_run" = "true" ]; then
    /usr/bin/printf 'Dry-run: /usr/bin/nohup /usr/bin/bash -lc "%s" >> "%s" 2>&1 &\n' "$command" "$log_file"
    exit 0
  fi

  /usr/bin/nohup /usr/bin/bash -lc "$command" >> "$log_file" 2>&1 &
  local pid=$!
  /usr/bin/printf '%s\n' "$pid" > "$PID_FILE"

  announce "Netric Refresh" "Started (pid ${pid}) log: ${log_file}"
}

status_refresh() {
  if is_running; then
    local pid
    pid="$(/usr/bin/cat "$PID_FILE")"
    announce "Netric Refresh" "Running (pid ${pid})"
    exit 0
  fi

  announce "Netric Refresh" "Not running"
  exit 1
}

stop_refresh() {
  if ! is_running; then
    announce "Netric Refresh" "Not running"
    /usr/bin/rm -f "$PID_FILE"
    exit 0
  fi

  local pid
  pid="$(/usr/bin/cat "$PID_FILE")"
  /usr/bin/kill "$pid"
  /usr/bin/rm -f "$PID_FILE"
  announce "Netric Refresh" "Stopped (pid ${pid})"
}

main() {
  local command="start"

  if [ "$#" -gt 0 ]; then
    case "$1" in
      start|status|stop)
        command="$1"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
    esac
  fi

  case "$command" in
    start)
      start_refresh "$@"
      ;;
    status)
      status_refresh
      ;;
    stop)
      stop_refresh
      ;;
  esac
}

main "$@"
