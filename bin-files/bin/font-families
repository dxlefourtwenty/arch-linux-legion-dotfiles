#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
OMIT_FILE="$SCRIPT_DIR/scans/omit-fonts"
INCLUDE_OMITTED=0

if [[ "${1:-}" == "--include-omitted" ]]; then
    INCLUDE_OMITTED=1
fi

FONTS="$(fc-list : family | awk -F',' '
function trim(s) {
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
    return s
}

{
    primary = trim($1)
    if (primary != "") {
        print primary
    }

    alias = trim($2)
    if (alias != "" && length(alias) < length(primary)) {
        print alias
    }
}
' | grep -Fvi 'Emoji' | sort -u)"

if [[ "$INCLUDE_OMITTED" -eq 1 || ! -f "$OMIT_FILE" ]]; then
    printf "%s\n" "$FONTS"
    exit 0
fi

printf "%s\n" "$FONTS" | awk -v omit_file="$OMIT_FILE" '
BEGIN {
    while ((getline pattern < omit_file) > 0) {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", pattern)
        if (pattern != "") {
            omit[++omit_count] = tolower(pattern)
        }
    }

    close(omit_file)
}

{
    font = tolower($0)

    for (i = 1; i <= omit_count; ++i) {
        if (index(font, omit[i])) {
            next
        }
    }

    print
}
'
