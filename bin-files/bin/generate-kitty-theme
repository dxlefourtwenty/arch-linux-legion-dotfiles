#!/usr/bin/env bash

set -e

[ -z "$1" ] && {
    echo "Usage: generate-kitty-theme <theme-directory>"
    exit 1
}

THEME_DIR="$HOME/.config/themes/$1"
ALACRITTY_FILE="$THEME_DIR/alacritty.toml"
KITTY_FILE="$THEME_DIR/kitty.conf"

[ ! -f "$ALACRITTY_FILE" ] && {
    echo "No alacritty.toml found in $THEME_DIR"
    exit 1
}

# Extract value helper (removes quotes + whitespace)
get_value() {
    # Only accept hex colors like #RRGGBB or #RRGGBBAA, quoted with ' or "
    echo "$1" | sed -nE "s/.*=\s*['\"](#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?)['\"].*/\1/p"
}

# Extract section block safely (ignores whitespace)
get_section() {
    awk -v section="$1" '
        $0 ~ "\\["section"\\]" { in_section=1; next }
        /^\[/ { in_section=0 }
        in_section
    ' "$ALACRITTY_FILE"
}

{
echo "# Autogenerated from alacritty.toml"
echo

# --- Primary ---
get_section "colors.primary" | while read -r line; do
    case "$line" in
        *background* )
            val=$(get_value "$line")
            [ -n "$val" ] && echo "background $val"
            ;;
        *foreground* )
            val=$(get_value "$line")
            [ -n "$val" ] && echo "foreground $val"
            ;;
    esac
done

echo

# --- Cursor ---
get_section "colors.cursor" | while read -r line; do
    case "$line" in
        *cursor* )
            val=$(get_value "$line")
            [ -n "$val" ] && echo "cursor $val"
            ;;
    esac
done

echo

# --- Selection ---
get_section "colors.selection" | while read -r line; do
    case "$line" in
        *background* )
            val=$(get_value "$line")
            [ -n "$val" ] && echo "selection_background $val"
            ;;
    esac
done

echo

# --- Normal Colors ---
get_section "colors.normal" | while read -r line; do
    name=$(echo "$line" | cut -d= -f1 | xargs)
    val=$(get_value "$line")

    case "$name" in
        black)   echo "color0  $val" ;;
        red)     echo "color1  $val" ;;
        green)   echo "color2  $val" ;;
        yellow)  echo "color3  $val" ;;
        blue)    echo "color4  $val" ;;
        magenta) echo "color5  $val" ;;
        cyan)    echo "color6  $val" ;;
        white)   echo "color7  $val" ;;
    esac
done

echo

# --- Bright Colors ---
get_section "colors.bright" | while read -r line; do
    name=$(echo "$line" | cut -d= -f1 | xargs)
    val=$(get_value "$line")

    case "$name" in
        black)   echo "color8  $val" ;;
        red)     echo "color9  $val" ;;
        green)   echo "color10 $val" ;;
        yellow)  echo "color11 $val" ;;
        blue)    echo "color12 $val" ;;
        magenta) echo "color13 $val" ;;
        cyan)    echo "color14 $val" ;;
        white)   echo "color15 $val" ;;
    esac
done

} > "$KITTY_FILE"

echo "Generated $KITTY_FILE"
