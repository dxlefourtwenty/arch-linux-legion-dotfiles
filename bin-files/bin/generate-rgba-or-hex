#!/usr/bin/env bash

input="$1"

trim() {
    echo "$1" | tr -d '[:space:]'
}

is_valid_hex() {
    local hex
    hex=$(trim "$1")
    hex="${hex#\#}"
    [[ "$hex" =~ ^([A-Fa-f0-9]{6}|[A-Fa-f0-9]{8})$ ]]
}

is_valid_rgba() {
    local rgba r g b a
    rgba=$(trim "$1")

    if [[ ! "$rgba" =~ ^rgba\(([0-9]{1,3}),([0-9]{1,3}),([0-9]{1,3}),(([0-9]*\.[0-9]+)|([0-9]+(\.[0-9]+)?))\)$ ]]; then
        return 1
    fi

    r="${BASH_REMATCH[1]}"
    g="${BASH_REMATCH[2]}"
    b="${BASH_REMATCH[3]}"
    a="${BASH_REMATCH[4]}"

    ((r >= 0 && r <= 255)) || return 1
    ((g >= 0 && g <= 255)) || return 1
    ((b >= 0 && b <= 255)) || return 1

    awk -v alpha="$a" 'BEGIN {exit !(alpha >= 0 && alpha <= 1)}' || return 1
}

hex_to_rgba() {
    local hex r g b a
    hex=$(trim "$1")
    hex="${hex#\#}"

    is_valid_hex "$hex" || return 1

    r=$((16#${hex:0:2}))
    g=$((16#${hex:2:2}))
    b=$((16#${hex:4:2}))

    if [[ ${#hex} == 8 ]]; then
        a=$(awk -v aa="$((16#${hex:6:2}))" 'BEGIN {printf "%.2f", aa/255}')
    else
        a=1
    fi

    echo "rgba($r, $g, $b, $a)"
}

rgba_to_hex() {
    local rgba r g b a a255
    rgba=$(trim "$1")

    if ! is_valid_rgba "$rgba"; then
        return 1
    fi

    r="${BASH_REMATCH[1]}"
    g="${BASH_REMATCH[2]}"
    b="${BASH_REMATCH[3]}"
    a="${BASH_REMATCH[4]}"

    ((r >= 0 && r <= 255)) || return 1
    ((g >= 0 && g <= 255)) || return 1
    ((b >= 0 && b <= 255)) || return 1

    awk -v alpha="$a" 'BEGIN {exit !(alpha >= 0 && alpha <= 1)}' || return 1
    a255=$(awk -v alpha="$a" 'BEGIN {printf "%d", (alpha * 255) + 0.5}')

    printf "#%02X%02X%02X%02X\n" "$r" "$g" "$b" "$a255"
}

create_color_icon() {
    local color="$1"
    local icon="$2"
    magick -size 32x32 "xc:$color" "$icon" >/dev/null 2>&1 || return 1
}

icon_path_for_hex() {
    local hex="$1"
    hex="${hex#\#}"
    echo "/tmp/rofi-color-${hex^^}.png"
}

emit_invalid_warning() {
    local message="$1"
    local warn_icon="/tmp/rofi-color-invalid.png"

    if [[ ! -f "$warn_icon" ]]; then
        create_color_icon "#C62828" "$warn_icon" || true
    fi

    printf '\0keep-filter\x1ftrue\n'
    printf '\0message\x1f%s\n' "$message"

    if [[ -f "$warn_icon" ]]; then
        printf 'Invalid color format\0icon\x1f%s\n' "$warn_icon"
    else
        printf 'Invalid color format\n'
    fi
}

convert_input() {
    local raw hex
    raw="$1"
    result=""
    preview_hex=""

    if [[ "$raw" =~ ^# ]]; then
        result=$(hex_to_rgba "$raw") || return 1
        hex=$(trim "$raw")
        hex="${hex#\#}"
        preview_hex="#${hex:0:6}"
        return 0
    fi

    if [[ "$raw" =~ ^rgba\( ]]; then
        result=$(rgba_to_hex "$raw") || return 1
        preview_hex="${result:0:7}"
        return 0
    fi

    return 1
}

emit_result_row() {
    local text="$1"
    local color="$2"
    local icon
    icon=$(icon_path_for_hex "$color")

    if create_color_icon "$color" "$icon"; then
        printf '%s\0icon\x1f%s\x1finfo\x1f%s\n' "$text" "$icon" "$text"
    else
        printf '%s\0info\x1f%s\n' "$text" "$text"
    fi
}

emit_conversion_or_warn() {
    local raw="$1"

    if convert_input "$raw"; then
        printf '\0keep-filter\x1ffalse\n'
        emit_result_row "$result" "$preview_hex"
    else
        if [[ "$raw" =~ ^# ]]; then
            emit_invalid_warning "Invalid hex. Use #RRGGBBAA (or #RRGGBB)."
        elif [[ "$(trim "$raw")" =~ ^rgba\( ]]; then
            emit_invalid_warning "Invalid rgba. Use rgba(r,g,b,a); r/g/b=0-255, a=0-1."
        else
            emit_invalid_warning "Invalid color. Use #RRGGBBAA or rgba(r,g,b,a)."
        fi
    fi
}

copy_selected_or_warn() {
    local selected="$1"
    local copied_hex=""
    local notify_icon=""

    if [[ "$selected" =~ ^# ]]; then
        copied_hex="${selected#\#}"
        copied_hex="#${copied_hex:0:6}"
    elif [[ "$(trim "$selected")" =~ ^rgba\( ]]; then
        copied_hex=$(rgba_to_hex "$selected")
        copied_hex="${copied_hex:0:7}"
    else
        emit_conversion_or_warn "$selected"
        return 1
    fi

    echo -n "$selected" | wl-copy >/dev/null 2>&1
    notify_icon=$(icon_path_for_hex "$copied_hex")
    create_color_icon "$copied_hex" "$notify_icon" || true
    notify-send -i "$notify_icon" -t 3000 "Color Copied" "$selected" >/dev/null 2>&1 || true

    printf '\0keep-filter\x1ffalse\n'
    emit_result_row "$selected" "$copied_hex"
    return 0
}

# ---------- user selected ----------
if [[ "$ROFI_RETV" == "2" ]]; then
    emit_conversion_or_warn "$input"
    exit 0
fi

if [[ "$ROFI_RETV" == "1" ]]; then
    if [[ -n "$ROFI_INFO" ]]; then
        copy_selected_or_warn "$ROFI_INFO"
    else
        emit_conversion_or_warn "$input"
    fi
    exit 0
fi

# ---------- generate results ----------
if [[ -z "$input" ]]; then
    exit 0
fi

if convert_input "$input"; then
    emit_result_row "$result" "$preview_hex"
else
    if [[ "$input" =~ ^# ]]; then
        emit_invalid_warning "Invalid hex. Use #RRGGBBAA (or #RRGGBB)."
    elif [[ "$(trim "$input")" =~ ^rgba\( ]]; then
        emit_invalid_warning "Invalid rgba. Use rgba(r,g,b,a); r/g/b=0-255, a=0-1."
    else
        emit_invalid_warning "Invalid color. Use #RRGGBBAA or rgba(r,g,b,a)."
    fi
fi
