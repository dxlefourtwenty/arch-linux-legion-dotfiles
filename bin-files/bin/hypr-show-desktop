#!/usr/bin/env bash
set -euo pipefail

readonly HYPRCTL_BIN="${HYPRCTL_BIN:-/usr/bin/hyprctl}"
readonly JQ_BIN="${JQ_BIN:-/usr/bin/jq}"
readonly RM_BIN="${RM_BIN:-/usr/bin/rm}"

STATE_PREFIX="${HYPR_SHOW_DESKTOP_STATE_PREFIX:-${XDG_RUNTIME_DIR:-/tmp}/hyprland-show-desktop}"
SPECIAL_WORKSPACE="${HYPR_SHOW_DESKTOP_WORKSPACE:-desktop}"
DRY_RUN=0

usage() {
    printf 'Usage: %s [--dry-run]\n' "${0##*/}"
}

parse_args() {
    while (($# > 0)); do
        case "$1" in
            -n|--dry-run)
                DRY_RUN=1
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                usage >&2
                exit 1
                ;;
        esac
        shift
    done
}

require_binary() {
    local binary_path="$1"

    [[ -x "$binary_path" ]] || {
        printf 'Missing required binary: %s\n' "$binary_path" >&2
        exit 1
    }
}

get_current_workspace() {
    "$HYPRCTL_BIN" activeworkspace -j | "$JQ_BIN" -r '.name'
}

get_state_file() {
    local workspace_name="$1"

    printf '%s-%s' "$STATE_PREFIX" "$workspace_name"
}

collect_workspace_addresses() {
    local workspace_name="$1"

    "$HYPRCTL_BIN" clients -j \
        | "$JQ_BIN" -r --arg workspace_name "$workspace_name" \
            '.[] | select(.workspace.name == $workspace_name) | .address'
}

run_batch() {
    local batch_commands="$1"

    [[ -n "$batch_commands" ]] || return 0

    if ((DRY_RUN)); then
        printf '%s\n' "$batch_commands"
        return 0
    fi

    "$HYPRCTL_BIN" --batch "$batch_commands" >/dev/null
}

restore_workspace_windows() {
    local workspace_name="$1"
    local state_file="$2"
    local batch_commands=""
    local address=""
    local addresses=()

    mapfile -t addresses < "$state_file"

    for address in "${addresses[@]}"; do
        [[ -n "$address" ]] || continue
        batch_commands+="dispatch movetoworkspacesilent name:${workspace_name},address:${address};"
    done

    run_batch "$batch_commands"

    if (( ! DRY_RUN )); then
        "$RM_BIN" -f "$state_file"
    fi
}

hide_workspace_windows() {
    local workspace_name="$1"
    local state_file="$2"
    local batch_commands=""
    local address=""
    local addresses=()

    mapfile -t addresses < <(collect_workspace_addresses "$workspace_name")

    ((${#addresses[@]} > 0)) || return 0

    if (( ! DRY_RUN )); then
        : > "$state_file"
    fi

    for address in "${addresses[@]}"; do
        [[ -n "$address" ]] || continue

        if (( ! DRY_RUN )); then
            printf '%s\n' "$address" >> "$state_file"
        fi

        batch_commands+="dispatch movetoworkspacesilent special:${SPECIAL_WORKSPACE},address:${address};"
    done

    run_batch "$batch_commands"
}

main() {
    parse_args "$@"

    require_binary "$HYPRCTL_BIN"
    require_binary "$JQ_BIN"
    require_binary "$RM_BIN"

    local workspace_name=""
    local state_file=""

    workspace_name="$(get_current_workspace)"
    [[ -n "$workspace_name" ]] || exit 1

    state_file="$(get_state_file "$workspace_name")"

    if [[ -s "$state_file" ]]; then
        restore_workspace_windows "$workspace_name" "$state_file"
        return
    fi

    hide_workspace_windows "$workspace_name" "$state_file"
}

main "$@"
