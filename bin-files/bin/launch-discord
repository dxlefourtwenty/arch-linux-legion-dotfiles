#!/usr/bin/env bash

set -euo pipefail

WIDTH=1200
HEIGHT=800
APP_CLASS=discord

find_discord_address() {
    hyprctl clients -j | jq -r '
        map(select((.class | ascii_downcase) == "'"$APP_CLASS"'"))[0].address // empty
    '
}

discord_address="$(find_discord_address)"

if [ -z "$discord_address" ]; then
    discord >/dev/null 2>&1 &

    for _ in {1..100}; do
        sleep 0.1
        discord_address="$(find_discord_address)"
        if [ -n "$discord_address" ]; then
            break
        fi
    done
fi

if [ -z "$discord_address" ]; then
    echo "launch-discord: could not find Discord window" >&2
    exit 1
fi

hyprctl dispatch focuswindow "address:$discord_address"
hyprctl dispatch setfloating
hyprctl dispatch resizeactive exact "$WIDTH" "$HEIGHT"
hyprctl dispatch centerwindow
hyprctl dispatch movetoworkspacesilent special:discordspace
