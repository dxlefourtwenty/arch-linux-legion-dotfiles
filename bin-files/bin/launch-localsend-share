#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-}" in
    file)
        shift
        exec "$SCRIPT_DIR/launch-localsend-share-file" "$@"
        ;;
    clipboard)
        shift
        exec "$SCRIPT_DIR/launch-localsend-share-clipboard" "$@"
        ;;
    *)
        exec "$SCRIPT_DIR/menu-localsend-share"
        ;;
esac
