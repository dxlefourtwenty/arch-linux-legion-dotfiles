#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/localsend-share"

focus_floating_workspace() {
    hyprctl dispatch focusworkspaceoncurrentmonitor special:floating >/dev/null 2>&1 || true
}

launch_localsend() {
    local selected_path="$1"

    "$SCRIPT_DIR/launch-window-floating" 800 600 localsend "$selected_path"
    focus_floating_workspace
}

clipboard_path() {
    local types mime extension output_path

    types="$(wl-paste --list-types 2>/dev/null || true)"

    if [[ -z "$types" ]]; then
        notify-send "LocalSend" "Clipboard is empty"
        exit 0
    fi

    mkdir -p "$CACHE_DIR"
    find "$CACHE_DIR" -type f -mtime +3 -delete 2>/dev/null || true

    if printf '%s\n' "$types" | grep -Fxq 'image/png'; then
        mime='image/png'
        extension='png'
    elif printf '%s\n' "$types" | grep -Fxq 'image/jpeg'; then
        mime='image/jpeg'
        extension='jpg'
    elif printf '%s\n' "$types" | grep -Fxq 'image/webp'; then
        mime='image/webp'
        extension='webp'
    elif printf '%s\n' "$types" | grep -Fxq 'text/html'; then
        mime='text/html'
        extension='html'
    elif printf '%s\n' "$types" | grep -Fxq 'text/plain;charset=utf-8'; then
        mime='text/plain;charset=utf-8'
        extension='txt'
    elif printf '%s\n' "$types" | grep -Fxq 'text/plain'; then
        mime='text/plain'
        extension='txt'
    else
        notify-send "LocalSend" "Clipboard type is not supported"
        exit 0
    fi

    output_path="$(mktemp "$CACHE_DIR/clipboard-XXXXXX.$extension")"
    wl-paste --type "$mime" >"$output_path"

    if [[ ! -s "$output_path" ]]; then
        rm -f -- "$output_path"
        notify-send "LocalSend" "Clipboard is empty"
        exit 0
    fi

    printf '%s\n' "$output_path"
}

launch_localsend "$(clipboard_path)"
