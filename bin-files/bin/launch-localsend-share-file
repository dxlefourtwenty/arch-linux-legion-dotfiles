#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MAX_PREVIEW_BYTES="${LOCALSEND_SHARE_MAX_PREVIEW_BYTES:-262144}"

focus_floating_workspace() {
    hyprctl dispatch focusworkspaceoncurrentmonitor special:floating >/dev/null 2>&1 || true
}

launch_localsend() {
    local selected_path="$1"

    "$SCRIPT_DIR/launch-window-floating" 800 600 localsend "$selected_path"
    focus_floating_workspace
}

preview_file() {
    local target="$1"
    local size mime human_size

    [[ -f "$target" ]] || exit 0

    size="$(stat -c '%s' -- "$target" 2>/dev/null || echo 0)"
    mime="$(file --brief --mime-type -- "$target" 2>/dev/null || echo application/octet-stream)"

    if (( size > MAX_PREVIEW_BYTES )); then
        human_size="$(numfmt --to=iec-i --suffix=B "$size" 2>/dev/null || printf '%s B' "$size")"
        printf '%s\n%s\nPreview skipped for large file.\n' "$mime" "$human_size"
        exit 0
    fi

    case "$mime" in
        text/*|application/json|application/xml|application/javascript|application/x-shellscript|*/xml)
            bat --style=numbers --color=always --line-range=:200 -- "$target" 2>/dev/null \
                || sed -n '1,200p' -- "$target" 2>/dev/null \
                || file --brief --mime -- "$target"
            ;;
        *)
            file --brief --mime -- "$target"
            ;;
    esac
}

pick_file() {
    local root_dir="$1"
    local selected_file=""

    if ! cd -- "$root_dir"; then
        echo "Directory not found: $root_dir" >&2
        exit 1
    fi

    if command -v fd >/dev/null 2>&1; then
        selected_file=$(
            fd --type f --follow --exclude .git . \
                | fzf \
                    --prompt "Share file> " \
                    --preview "$SCRIPT_DIR/launch-localsend-share-file --preview-file {}" \
                    --preview-window=right:45%,wrap
        ) || true
    else
        selected_file=$(
            find . -path './.*' -prune -o -type f -print \
                | sed 's#^\./##' \
                | fzf \
                    --prompt "Share file> " \
                    --preview "$SCRIPT_DIR/launch-localsend-share-file --preview-file {}" \
                    --preview-window=right:45%,wrap
        ) || true
    fi

    clear

    if [[ -n "$selected_file" ]]; then
        launch_localsend "$(realpath -- "$selected_file")"
    fi
}

case "${1:-}" in
    --preview-file)
        preview_file "${2:-}"
        ;;
    --pick)
        pick_file "$(realpath -m -- "${2:-$HOME}")"
        ;;
    *)
        "$SCRIPT_DIR/launch-terminal-floating" 1200 800 "$SCRIPT_DIR/launch-localsend-share-file" --pick "${1:-$HOME}"
        ;;
esac
