#!/usr/bin/env bash

set -euo pipefail

WIDTH=1200
HEIGHT=800
APP_CLASS=obsidian

find_obsidian_address() {
    hyprctl clients -j | jq -r '
        map(
            select(
                ((.class // "" | ascii_downcase) == "'"$APP_CLASS"'")
                or
                ((.initialClass // "" | ascii_downcase) == "'"$APP_CLASS"'")
            )
        )[0].address // empty
    '
}

obsidian_address="$(find_obsidian_address)"

if [ -z "$obsidian_address" ]; then
    obsidian >/dev/null 2>&1 &

    for _ in {1..100}; do
        sleep 0.1
        obsidian_address="$(find_obsidian_address)"
        if [ -n "$obsidian_address" ]; then
            break
        fi
    done
fi

if [ -z "$obsidian_address" ]; then
    echo "launch-obsidian: could not find obsidian window" >&2
    exit 1
fi

hyprctl dispatch focuswindow "address:$obsidian_address"
hyprctl dispatch setfloating
hyprctl dispatch resizeactive exact "$WIDTH" "$HEIGHT"
hyprctl dispatch centerwindow
hyprctl dispatch movetoworkspacesilent special:scratchpad
