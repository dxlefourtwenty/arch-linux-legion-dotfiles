#!/usr/bin/env bash

set -euo pipefail

PIDFILE="/tmp/launch-screenshot-clipboard.pid"
OUTPUT_DIR="${HOME}/files/pictures/screenshots"
NOTIFICATION_ICON="/usr/share/icons/hicolor/scalable/apps/satty.svg"

if [[ -f "$PIDFILE" ]]; then
    pid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
        kill -TERM -- "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
        exit 0
    fi
    rm -f "$PIDFILE"
fi

setsid bash -c '
set -euo pipefail

PIDFILE="/tmp/launch-screenshot-clipboard.pid"
OUTPUT_DIR="${HOME}/files/pictures/screenshots"
NOTIFICATION_ICON="/usr/share/icons/hicolor/scalable/apps/satty.svg"
echo "$$" > "$PIDFILE"

cleanup() {
    rm -rf "${tmp_dir:-}"
    rm -f "$PIDFILE"
}
trap cleanup EXIT INT TERM

mkdir -p "$OUTPUT_DIR"

tmp_dir="$(mktemp -d /tmp/launch-screenshot-clipboard-XXXXXX)" || exit 1
tmp_input="${tmp_dir}/capture.png"
output_file="${OUTPUT_DIR}/screenshot-$(date +%Y-%m-%d_%H-%M-%S).png"

geometry="$(slurp 2>/dev/null || true)"
[[ -n "$geometry" ]] || exit 0

grim -g "$geometry" "$tmp_input" || exit 1

satty \
    --filename "$tmp_input" \
    --output-filename "$output_file" \
    --actions-on-enter save-to-clipboard \
    --save-after-copy \
    --copy-command "wl-copy" \
    --disable-notifications \
    --floating-hack \
    --resize 1200x800 \
    --early-exit || true

if [[ -s "$output_file" ]] && command -v notify-send >/dev/null 2>&1; then
    notify-send -i "$NOTIFICATION_ICON" -t 3000 "Screenshot" "Region saved and copied."
fi
' >/dev/null 2>&1 &

disown || true
