#!/usr/bin/env bash

# Fallback if TERMINAL isn't set
: "${TERMINAL:=kitty}"

term_bin="${TERMINAL%% *}"

if ! command -v "$term_bin" >/dev/null 2>&1; then
    TERMINAL=kitty
    term_bin=kitty
fi

case "$term_bin" in
    kitty|alacritty|foot|ghostty|xterm)
        if [ "$#" -eq 0 ]; then
            exec "$term_bin"
        fi
        exec "$term_bin" -e "$@"
        ;;
    wezterm)
        if [ "$#" -eq 0 ]; then
            exec "$term_bin" start --always-new-process
        fi
        exec "$term_bin" start --always-new-process -- "$@"
        ;;
    gnome-terminal)
        if [ "$#" -eq 0 ]; then
            exec "$term_bin"
        fi
        exec "$term_bin" -- "$@"
        ;;
    konsole)
        if [ "$#" -eq 0 ]; then
            exec "$term_bin"
        fi
        exec "$term_bin" -e "$@"
        ;;
    xfce4-terminal)
        if [ "$#" -eq 0 ]; then
            exec "$term_bin"
        fi
        exec "$term_bin" --command="$*"
        ;;
    *)
        if [ "$#" -eq 0 ]; then
            exec kitty
        fi
        exec kitty -e "$@"
        ;;
esac
