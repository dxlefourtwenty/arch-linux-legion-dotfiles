#!/usr/bin/env bash

: "${TERMINAL:=kitty}"

term_bin="${TERMINAL%% *}"

# Default size
WIDTH="${1:-1200}"
HEIGHT="${2:-800}"

# Remove them from argument list if they were used
if [[ "$1" =~ ^[0-9]+$ && "$2" =~ ^[0-9]+$ ]]; then
    shift 2
fi

if ! command -v "$term_bin" >/dev/null 2>&1; then
    TERMINAL=kitty
    term_bin=kitty
fi

launch_terminal() {
    "$@" &
    sleep 0.12

    hyprctl dispatch togglefloating
    hyprctl dispatch resizeactive exact "$WIDTH" "$HEIGHT"
    hyprctl dispatch centerwindow
    hyprctl dispatch pin
}

case "$term_bin" in
    kitty|alacritty|foot|ghostty|xterm)
        if [ "$#" -eq 0 ]; then
            launch_terminal "$term_bin"
        else
            launch_terminal "$term_bin" -e "$@"
        fi
        ;;
    wezterm)
        if [ "$#" -eq 0 ]; then
            launch_terminal "$term_bin" start --always-new-process
        else
            launch_terminal "$term_bin" start --always-new-process -- "$@"
        fi
        ;;
    gnome-terminal)
        if [ "$#" -eq 0 ]; then
            launch_terminal "$term_bin"
        else
            launch_terminal "$term_bin" -- "$@"
        fi
        ;;
    konsole)
        if [ "$#" -eq 0 ]; then
            launch_terminal "$term_bin"
        else
            launch_terminal "$term_bin" -e "$@"
        fi
        ;;
    xfce4-terminal)
        if [ "$#" -eq 0 ]; then
            launch_terminal "$term_bin"
        else
            launch_terminal "$term_bin" --command="$*"
        fi
        ;;
    *)
        if [ "$#" -eq 0 ]; then
            launch_terminal kitty
        else
            launch_terminal kitty -e "$@"
        fi
        ;;
esac
