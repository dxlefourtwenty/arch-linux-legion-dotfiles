#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
WIDTH=1200
HEIGHT=800
APP_URL="https://tiktok.com"
SOCIAL_WORKSPACE="special:socialspace"
APP_MATCHES=("tiktok.com" "tiktokcomwebapp")
OTHER_APP_MATCHES=("instagram.com" "instagramcomwebapp")

find_address() {
    local workspace_name="$1"
    shift

    hyprctl clients -j | jq -r --arg workspace_name "$workspace_name" '
        map(
            select(
                ($workspace_name == "" or (.workspace.name // "") == $workspace_name)
                and
                (
                    ($ARGS.positional | map(ascii_downcase)) as $needles
                    | [(.class // ""), (.initialClass // ""), (.title // ""), (.initialTitle // "")]
                    | map(ascii_downcase) as $haystacks
                    | any($needles[]; . as $needle | any($haystacks[]; contains($needle)))
                )
            )
        )[0].address // empty
    ' --args "$@"
}

address_exists() {
    hyprctl clients -j | jq -e --arg address "$1" 'any(.[]; .address == $address)' >/dev/null
}

wait_for_address_to_close() {
    local address="$1"

    for _ in {1..50}; do
        if ! address_exists "$address"; then
            return 0
        fi
        sleep 0.1
    done

    return 1
}

find_tiktok_address() {
    find_address "" "${APP_MATCHES[@]}"
}

find_instagram_socialspace_address() {
    find_address "$SOCIAL_WORKSPACE" "${OTHER_APP_MATCHES[@]}"
}

tiktok_address="$(find_tiktok_address)"
instagram_socialspace_address="$(find_instagram_socialspace_address)"

if [ -n "$instagram_socialspace_address" ] && [ "$instagram_socialspace_address" != "$tiktok_address" ]; then
    hyprctl dispatch closewindow "address:$instagram_socialspace_address" >/dev/null
    wait_for_address_to_close "$instagram_socialspace_address"
fi

if [ -z "$tiktok_address" ]; then
    "$SCRIPT_DIR/launch-web-app" "$APP_URL" >/dev/null 2>&1 &

    for _ in {1..100}; do
        sleep 0.1
        tiktok_address="$(find_tiktok_address)"
        if [ -n "$tiktok_address" ]; then
            break
        fi
    done
fi

if [ -z "$tiktok_address" ]; then
    echo "launch-tiktok: could not find tiktok window" >&2
    exit 1
fi

hyprctl dispatch focuswindow "address:$tiktok_address"
hyprctl dispatch setfloating
hyprctl dispatch resizeactive exact "$WIDTH" "$HEIGHT"
hyprctl dispatch centerwindow
hyprctl dispatch movetoworkspacesilent "$SOCIAL_WORKSPACE"
