#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SEARCH_DIR="$HOME"
MENU_ID="menu-open-pdf"
PID_FILE="/tmp/menu-rofi.pid"

open_pdf() {
    local real_path="$1"
    local display_path="${2:-${real_path/#$HOME/\~}}"
    local command=""

    if [[ ! -f "$real_path" ]]; then
        notify-send -t 5000 "Files" "PDF no longer exists"
        exit 1
    fi

    if ! command -v zathura >/dev/null 2>&1; then
        notify-send -t 5000 "Files" "zathura is not installed"
        exit 1
    fi

    notify-send -t 5000 "Files" "Opening $display_path"

    if command -v hyprctl >/dev/null 2>&1 && [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
        printf -v command 'zathura %q' "$real_path"
        exec hyprctl dispatch exec "$command"
    fi

    nohup zathura "$real_path" >/dev/null 2>&1 &
}

if [[ -n "${1:-}" && "$1" != "Loading…" ]]; then
    real_path="${1/#\~/$HOME}"
    open_pdf "$real_path" "$1"
fi

if [[ -z "${ROFI_RETV:-}" ]]; then
    if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
        exit 0
    fi

    chosen=$(
        if command -v fd >/dev/null 2>&1; then
            fd --ignore-case --type f --follow '\.pdf$' "$SEARCH_DIR"
        else
            find "$SEARCH_DIR" -path '*/.*' -prune -o -type f -iname '*.pdf' -print
        fi | sed "s|^$HOME|~|" | rofi -dmenu -i \
            -pid "$PID_FILE" \
            -p "" \
            -async-pre-read 1 \
            -theme-str '
                window { width: 1300px; }
                entry { placeholder: "Open PDF…"; }
                element {
                    orientation: horizontal;
                    children: [ element-text ];
                    spacing: 0px;
                    padding: 8px 10px;
                }
                element-text {
                    horizontal-align: 0.0;
                    padding-left: 0px;
                }
            '
    )

    "$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"
    [[ -n "$chosen" ]] && exec "$SCRIPT_DIR/launch-zathura-pdf" "$chosen"
    exit
fi
