#!/usr/bin/env bash
set -euo pipefail

PLAYERCTL_BIN="${PLAYERCTL_BIN:-/usr/bin/playerctl}"
CURL_BIN="${CURL_BIN:-/usr/bin/curl}"
MAGICK_BIN="${MAGICK_BIN:-/usr/bin/magick}"
NOTIFY_SEND_BIN="${NOTIFY_SEND_BIN:-/usr/bin/notify-send}"
FLOCK_BIN="${FLOCK_BIN:-/usr/bin/flock}"
MKDIR_BIN="${MKDIR_BIN:-/usr/bin/mkdir}"
DATE_BIN="${DATE_BIN:-/usr/bin/date}"
CKSUM_BIN="${CKSUM_BIN:-/usr/bin/cksum}"
AWK_BIN="${AWK_BIN:-/usr/bin/awk}"
MKTEMP_BIN="${MKTEMP_BIN:-/usr/bin/mktemp}"
MV_BIN="${MV_BIN:-/usr/bin/mv}"
RM_BIN="${RM_BIN:-/usr/bin/rm}"
TIMEOUT_BIN="${TIMEOUT_BIN:-/usr/bin/timeout}"
GDBUS_BIN="${GDBUS_BIN:-/usr/bin/gdbus}"
PGREP_BIN="${PGREP_BIN:-/usr/bin/pgrep}"
SPOTIFY_PLAYER="${SPOTIFY_PLAYER:-spotify}"
SPOTIFY_NOTIFY_DRY_RUN="${SPOTIFY_NOTIFY_DRY_RUN:-0}"
SPOTIFY_NOTIFY_DAEMON="${SPOTIFY_NOTIFY_DAEMON:-auto}"
SPOTIFY_NOTIFY_APP_NAME="${SPOTIFY_NOTIFY_APP_NAME:-spotify-media-controls}"
SPOTIFY_NOTIFY_STACK_TAG="${SPOTIFY_NOTIFY_STACK_TAG:-spotify-media-controls}"
SPOTIFY_NOTIFY_STATE_DIR="${SPOTIFY_NOTIFY_STATE_DIR:-/tmp/spotify-media-controls-notify}"
SPOTIFY_NOTIFY_LOCK_FILE="${SPOTIFY_NOTIFY_LOCK_FILE:-$SPOTIFY_NOTIFY_STATE_DIR/notification.lock}"
SPOTIFY_TRACK_CHANGE_MARK_FILE="${SPOTIFY_TRACK_CHANGE_MARK_FILE:-$SPOTIFY_NOTIFY_STATE_DIR/track-change-mark}"
SPOTIFY_TRACK_CHANGE_MARK_LOCK_FILE="${SPOTIFY_TRACK_CHANGE_MARK_LOCK_FILE:-$SPOTIFY_NOTIFY_STATE_DIR/track-change-mark.lock}"
SPOTIFY_TRACK_CHANGE_MARK_TTL="${SPOTIFY_TRACK_CHANGE_MARK_TTL:-5}"
SPOTIFY_NOTIFY_ICON_DIR="${SPOTIFY_NOTIFY_ICON_DIR:-$SPOTIFY_NOTIFY_STATE_DIR/icons}"
SPOTIFY_NOTIFY_WARD_STATE_FILE="${SPOTIFY_NOTIFY_WARD_STATE_FILE:-$SPOTIFY_NOTIFY_STATE_DIR/ward-notification-state}"
SPOTIFY_NOTIFY_CURL_MAX_TIME="${SPOTIFY_NOTIFY_CURL_MAX_TIME:-5}"
SPOTIFY_NOTIFY_SEND_TIMEOUT="${SPOTIFY_NOTIFY_SEND_TIMEOUT:-5}"
SPOTIFY_NOTIFY_EXEC_COMMAND="${SPOTIFY_NOTIFY_EXEC_COMMAND:-~/bin/hypr-focus-workspace special:mediaspace}"
SPOTIFY_NOTIFY_DEFAULT_TEXT_GAP="${SPOTIFY_NOTIFY_DEFAULT_TEXT_GAP:-5}"
SPOTIFY_NOTIFY_TEXT_GAP="${SPOTIFY_NOTIFY_TEXT_GAP:-$SPOTIFY_NOTIFY_DEFAULT_TEXT_GAP}"

spotify_notify_lib_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if [[ -r "$spotify_notify_lib_dir/spotify-notify-ward-lib" ]]; then
  source "$spotify_notify_lib_dir/spotify-notify-ward-lib"
fi

spotify_notify_usage() {
  local program_name="${1:-spotify-notify}"

  printf 'Usage: %s [--text-gap PIXELS]\n' "$program_name"
}

spotify_notify_set_text_gap() {
  local value="${1-}"

  if [[ ! "$value" =~ ^[0-9]+$ ]]; then
    printf 'invalid text gap: %s\n' "$value" >&2
    return 1
  fi

  SPOTIFY_NOTIFY_TEXT_GAP="$value"
}

spotify_notify_parse_args() {
  local program_name="${1:-spotify-notify}"
  shift || true

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --text-gap)
        [[ "$#" -ge 2 ]] || {
          printf '%s\n' "missing value for --text-gap" >&2
          return 1
        }
        spotify_notify_set_text_gap "$2"
        shift 2
        ;;
      --text-gap=*)
        spotify_notify_set_text_gap "${1#*=}"
        shift
        ;;
      -h|--help)
        spotify_notify_usage "$program_name"
        exit 0
        ;;
      --)
        shift
        [[ "$#" -eq 0 ]] || {
          printf 'unexpected arguments: %s\n' "$*" >&2
          return 1
        }
        ;;
      *)
        printf 'unexpected argument: %s\n' "$1" >&2
        return 1
        ;;
    esac
  done
}

spotify_notify_append_hint_args() {
  local -n args_ref="$1"

  if [[ -n "${SPOTIFY_NOTIFY_TEXT_GAP:-}" ]]; then
    args_ref+=(-h "int:x-ward-text-gap:$SPOTIFY_NOTIFY_TEXT_GAP")
  fi
}

spotify_escape_markup() {
  local value="${1-}"

  value=${value//&/\&amp;}
  value=${value//</\&lt;}
  value=${value//>/\&gt;}
  value=${value//\"/\&quot;}
  value=${value//\'/\&apos;}

  printf '%s' "$value"
}

spotify_track_artists() {
  local artists_raw
  local entry
  local piece
  local joined_artists
  local metadata_output
  local trimmed_piece
  local count=0
  local -a artists=()
  local -a entries=()
  local -a pieces=()

  metadata_output="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata 2>/dev/null || printf '')"
  artists_raw="$(printf '%s\n' "$metadata_output" | "$AWK_BIN" '$1 == "xesam:artist" { $1=""; sub(/^[[:space:]]+/, ""); print; exit }')"

  if [[ -z "$artists_raw" ]]; then
    artists_raw="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata --format '{{artist}}' 2>/dev/null || printf '')"
  fi

  mapfile -t entries <<< "$artists_raw"

  for entry in "${entries[@]}"; do
    IFS=',' read -r -a pieces <<< "$entry"

    for piece in "${pieces[@]}"; do
      trimmed_piece="${piece#"${piece%%[![:space:]]*}"}"
      trimmed_piece="${trimmed_piece%"${trimmed_piece##*[![:space:]]}"}"

      [[ -n "$trimmed_piece" ]] || continue

      artists+=("$trimmed_piece")
      count=$(( count + 1 ))

      if [[ "$count" -ge 3 ]]; then
        joined_artists="$(IFS=', '; printf '%s' "${artists[*]}")"
        printf '%s\n' "$joined_artists"
        return 0
      fi
    done
  done

  if [[ "${#artists[@]}" -gt 0 ]]; then
    joined_artists="$(IFS=', '; printf '%s' "${artists[*]}")"
    printf '%s\n' "$joined_artists"
    return 0
  fi

  printf '\n'
}

spotify_track_markup() {
  local title
  local artist

  title="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata --format '{{title}}' 2>/dev/null || printf '')"
  artist="$(spotify_track_artists)"

  printf '<b>%s</b>\n<span foreground="var(--border-color)">%s</span>' \
    "$(spotify_escape_markup "$title")" \
    "$(spotify_escape_markup "$artist")"
}

spotify_summary_markup() {
  local summary="${1-}"

  printf '<span font-weight="300">%s</span>' "$(spotify_escape_markup "$summary")"
}

spotify_format_mmss() {
  local total_seconds="${1:-0}"
  local minutes
  local seconds

  if [[ "$total_seconds" -lt 0 ]]; then
    total_seconds=0
  fi

  minutes=$(( total_seconds / 60 ))
  seconds=$(( total_seconds % 60 ))

  printf '%02d:%02d' "$minutes" "$seconds"
}

spotify_track_time_label() {
  local position_us
  local length_us
  local position_s
  local length_s

  position_us="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata --format '{{position}}' 2>/dev/null || printf '0')"
  length_us="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata --format '{{mpris:length}}' 2>/dev/null || printf '0')"

  [[ "$position_us" =~ ^[0-9]+$ ]] || position_us=0
  [[ "$length_us" =~ ^[0-9]+$ ]] || length_us=0

  position_s=$(( position_us / 1000000 ))
  length_s=$(( length_us / 1000000 ))

  printf '%s/%s' \
    "$(spotify_format_mmss "$position_s")" \
    "$(spotify_format_mmss "$length_s")"
}

spotify_notify_track_with_timestamp() {
  local summary="$1"
  local timeout="${2:-2500}"
  local time_label

  time_label="$(spotify_track_time_label)"
  spotify_notify_track "$summary [$time_label]" "$timeout"
}

spotify_cover_image() {
  local art_url
  local icon_key
  local icon_path
  local temp_icon_path

  art_url="$("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata mpris:artUrl 2>/dev/null || printf '')"
  [[ -n "$art_url" ]] || return 1

  "$MKDIR_BIN" -p "$SPOTIFY_NOTIFY_ICON_DIR"
  icon_key="$(printf '%s' "$art_url" | "$CKSUM_BIN" | "$AWK_BIN" '{print $1}')"
  icon_path="$SPOTIFY_NOTIFY_ICON_DIR/$icon_key.jpg"

  if [[ -s "$icon_path" ]]; then
    printf '%s\n' "$icon_path"
    return 0
  fi

  temp_icon_path="$("$MKTEMP_BIN" "$SPOTIFY_NOTIFY_ICON_DIR/.spotify-cover.XXXXXX.jpg")"

  if ! "$CURL_BIN" -fsSL --max-time "$SPOTIFY_NOTIFY_CURL_MAX_TIME" "$art_url" \
    | "$MAGICK_BIN" - -resize 64x64 "$temp_icon_path"; then
    "$RM_BIN" -f "$temp_icon_path"
    return 1
  fi

  "$MV_BIN" -f "$temp_icon_path" "$icon_path"
  printf '%s\n' "$icon_path"
}

spotify_notify_backend() {
  local backend="$SPOTIFY_NOTIFY_DAEMON"

  case "$backend" in
    auto)
      if [[ -x "$PGREP_BIN" ]] && "$PGREP_BIN" -x ward >/dev/null 2>&1; then
        backend="ward"
      else
        backend="mako"
      fi
      ;;
    mako|ward)
      ;;
    *)
      backend="mako"
      ;;
  esac

  if [[ "$backend" == "ward" ]] && ! declare -F spotify_notify_ward_send >/dev/null 2>&1; then
    backend="mako"
  fi

  printf '%s\n' "$backend"
}

spotify_notify_mako_args() {
  local summary="$1"
  local body="$2"
  local timeout="$3"
  local icon="${4-}"
  local -a args

  args=(
    -a "$SPOTIFY_NOTIFY_APP_NAME"
    -h "string:x-dunst-stack-tag:$SPOTIFY_NOTIFY_STACK_TAG"
    -t "$timeout"
  )

  spotify_notify_append_hint_args args

  if [[ -n "$icon" ]]; then
    args+=(-i "$icon")
  fi

  args+=("$summary" "$body")
  printf '%s\0' "${args[@]}"
}

spotify_notify_preview() {
  local backend="$1"
  local summary="$2"
  local body="$3"
  local timeout="$4"
  local icon="${5-}"
  local summary_markup=""
  local -a preview_args

  summary_markup="$(spotify_summary_markup "$summary")"

  if [[ "$backend" == "ward" ]]; then
    spotify_notify_ward_preview "$summary_markup" "$body" "$timeout" "$icon"
    return 0
  fi

  mapfile -d '' -t preview_args < <(spotify_notify_mako_args "$summary_markup" "$body" "$timeout" "$icon")
  printf 'backend=%s\n' "$backend"
  printf 'summary=%s\n' "$summary"
  printf 'timeout=%s\n' "$timeout"
  printf 'icon=%s\n' "$icon"
  printf 'body=%s\n' "$body"
  printf 'stack_tag=%s\n' "$SPOTIFY_NOTIFY_STACK_TAG"
  printf 'app_name=%s\n' "$SPOTIFY_NOTIFY_APP_NAME"
  printf 'notify_args=%q ' "$NOTIFY_SEND_BIN" "${preview_args[@]}"
  printf '\n'
}

spotify_notify_send() {
  local backend="$1"
  local summary="$2"
  local body="$3"
  local timeout="$4"
  local icon="${5-}"
  local summary_markup=""
  local notify_exit_code=0
  local -a notify_args

  summary_markup="$(spotify_summary_markup "$summary")"

  if [[ "$backend" == "ward" ]]; then
    if spotify_notify_ward_send "$summary_markup" "$body" "$timeout" "$icon"; then
      return 0
    else
      notify_exit_code=$?
      return "$notify_exit_code"
    fi
  fi

  mapfile -d '' -t notify_args < <(spotify_notify_mako_args "$summary_markup" "$body" "$timeout" "$icon")

  if "$TIMEOUT_BIN" "$SPOTIFY_NOTIFY_SEND_TIMEOUT" "$NOTIFY_SEND_BIN" "${notify_args[@]}"; then
    return 0
  else
    notify_exit_code=$?
    return "$notify_exit_code"
  fi
}

spotify_notify_track() {
  local summary="$1"
  local timeout="${2:-2500}"
  local backend
  local body
  local icon
  local lock_fd

  body="$(spotify_track_markup)"
  icon=""
  backend="$(spotify_notify_backend)"

  if ! icon="$(spotify_cover_image 2>/dev/null)"; then
    icon=""
  fi

  if [[ "$SPOTIFY_NOTIFY_DRY_RUN" == "1" ]]; then
    spotify_notify_preview "$backend" "$summary" "$body" "$timeout" "$icon"
    return 0
  fi

  "$MKDIR_BIN" -p "$SPOTIFY_NOTIFY_STATE_DIR"
  exec {lock_fd}> "$SPOTIFY_NOTIFY_LOCK_FILE"
  "$FLOCK_BIN" -x "$lock_fd"
  local notify_exit_code=0

  if spotify_notify_send "$backend" "$summary" "$body" "$timeout" "$icon"; then
    notify_exit_code=0
  else
    notify_exit_code=$?
  fi

  exec {lock_fd}>&-
  return "$notify_exit_code"
}

spotify_notify_track_with_text_gap() {
  local summary="$1"
  local timeout="${2:-2500}"
  local text_gap="${3-}"
  local restore_text_gap=""
  local notify_exit_code=0

  if [[ -n "$text_gap" ]]; then
    restore_text_gap="${SPOTIFY_NOTIFY_TEXT_GAP:-}"
    SPOTIFY_NOTIFY_TEXT_GAP="$text_gap"
  fi

  if spotify_notify_track "$summary" "$timeout"; then
    notify_exit_code=0
  else
    notify_exit_code=$?
  fi

  if [[ -n "$text_gap" ]]; then
    SPOTIFY_NOTIFY_TEXT_GAP="$restore_text_gap"
  fi

  return "$notify_exit_code"
}

spotify_track_change_mark() {
  local summary="$1"
  local previous_id="${2-}"
  local text_gap="${SPOTIFY_NOTIFY_TEXT_GAP:-}"
  local lock_fd
  local now_s
  local expires_at_s
  local temp_mark_file

  "$MKDIR_BIN" -p "$SPOTIFY_NOTIFY_STATE_DIR"
  exec {lock_fd}> "$SPOTIFY_TRACK_CHANGE_MARK_LOCK_FILE"
  "$FLOCK_BIN" -x "$lock_fd"
  now_s="$("$DATE_BIN" +%s)"
  expires_at_s=$(( now_s + SPOTIFY_TRACK_CHANGE_MARK_TTL ))
  temp_mark_file="$("$MKTEMP_BIN" "$SPOTIFY_NOTIFY_STATE_DIR/.track-change-mark.XXXXXX")"

  printf '%s\n%s\n%s\n%s\n' "$expires_at_s" "$previous_id" "$summary" "$text_gap" > "$temp_mark_file"
  "$MV_BIN" -f "$temp_mark_file" "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
  exec {lock_fd}>&-
}

spotify_track_change_take_mark() {
  local previous_id="$1"
  local summary_var_name="$2"
  local text_gap_var_name="$3"
  local lock_fd
  local now_s
  local -a lines=()
  local expires_at_s=""
  local marked_previous_id=""
  local marked_summary=""
  local marked_text_gap=""
  local -n summary_ref="$summary_var_name"
  local -n text_gap_ref="$text_gap_var_name"

  "$MKDIR_BIN" -p "$SPOTIFY_NOTIFY_STATE_DIR"
  exec {lock_fd}> "$SPOTIFY_TRACK_CHANGE_MARK_LOCK_FILE"
  "$FLOCK_BIN" -x "$lock_fd"

  if [[ ! -r "$SPOTIFY_TRACK_CHANGE_MARK_FILE" ]]; then
    exec {lock_fd}>&-
    return 1
  fi

  if ! mapfile -t lines < "$SPOTIFY_TRACK_CHANGE_MARK_FILE"; then
    "$RM_BIN" -f "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
    exec {lock_fd}>&-
    return 1
  fi

  expires_at_s="${lines[0]-}"
  marked_previous_id="${lines[1]-}"
  marked_summary="${lines[2]-}"
  marked_text_gap="${lines[3]-}"

  [[ "$expires_at_s" =~ ^[0-9]+$ ]] || {
    "$RM_BIN" -f "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
    exec {lock_fd}>&-
    return 1
  }

  now_s="$("$DATE_BIN" +%s)"

  if [[ "$now_s" -ge "$expires_at_s" ]]; then
    "$RM_BIN" -f "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
    exec {lock_fd}>&-
    return 1
  fi

  if [[ -z "$marked_summary" ]]; then
    exec {lock_fd}>&-
    return 1
  fi

  if [[ "$marked_previous_id" != "$previous_id" ]]; then
    "$RM_BIN" -f "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
    exec {lock_fd}>&-
    return 1
  fi

  "$RM_BIN" -f "$SPOTIFY_TRACK_CHANGE_MARK_FILE"
  exec {lock_fd}>&-
  summary_ref="$marked_summary"
  text_gap_ref="$marked_text_gap"
}
