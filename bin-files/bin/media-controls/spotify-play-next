#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/spotify-notify-lib"
spotify_notify_parse_args "${0##*/}" "$@"

current_id="$(playerctl -p spotify metadata mpris:trackid 2>/dev/null || echo "")"

spotify_track_change_mark "Playing Next" "$current_id"
playerctl -p spotify next

for _ in {1..50}; do
  new_id="$(playerctl -p spotify metadata mpris:trackid 2>/dev/null || echo "")"
  [[ "$new_id" != "$current_id" && -n "$new_id" ]] && break
  sleep 0.1
done
