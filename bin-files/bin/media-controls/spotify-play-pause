#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/spotify-notify-lib"

status="$(playerctl -p spotify status 2>/dev/null || echo "Stopped")"

case "$status" in
  Playing)
    playerctl -p spotify pause
    spotify_notify_track "Paused" 3000
    ;;

  Paused|Stopped)
    playerctl -p spotify play

    # wait until actually playing
    for _ in {1..50}; do
      new_status="$(playerctl -p spotify status 2>/dev/null || echo "")"
      [[ "$new_status" == "Playing" ]] && break
      sleep 0.1
    done

    spotify_notify_track "Resuming…" 3000
    ;;
esac
