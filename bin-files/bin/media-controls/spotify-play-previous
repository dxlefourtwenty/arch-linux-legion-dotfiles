#!/usr/bin/env bash
set -euo pipefail

current_id="$(playerctl -p spotify metadata mpris:trackid 2>/dev/null || echo "")"

# force real previous
playerctl -p spotify position 0
sleep 0.1
playerctl -p spotify previous

for _ in {1..50}; do
  new_id="$(playerctl -p spotify metadata mpris:trackid 2>/dev/null || echo "")"
  [[ "$new_id" != "$current_id" && -n "$new_id" ]] && break
  sleep 0.1
done

track="$(playerctl -p spotify metadata --format '<b><i>{{title}}</i></b> \n{{artist}}')"

art="$(playerctl -p spotify metadata mpris:artUrl)"
img="/tmp/spotify-cover.jpg"
curl -sL "$art" | magick - -resize 64x64 "$img"

notify-send -i "$img" -t 2500 "Playing Previous" "$track"
