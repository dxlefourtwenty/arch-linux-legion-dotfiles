#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/spotify-notify-lib"

status="$(playerctl -p spotify status 2>/dev/null || echo "Stopped")"

playerctl -p spotify position 0

if [[ "$status" == "Playing" ]]; then
  spotify_notify_track "Replaying…" 2500
else
  spotify_notify_track "Reset" 2500
fi
