#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/spotify-notify-lib"
spotify_notify_parse_args "${0##*/}" "$@"

last_id=""
last_pos=0
last_len=0

spotify_track_change_notify() {
  local previous_id="$1"
  local summary=""
  local text_gap=""

  [[ -n "$previous_id" ]] || return 0

  if spotify_track_change_take_mark "$previous_id" summary text_gap 2>/dev/null; then
    sleep 0.5
    spotify_notify_track_with_text_gap "$summary" 6500 "$text_gap" || true
    return 0
  fi

  sleep 0.5
  spotify_notify_track "Now Playing" 6500 || true
}

while IFS='|' read -r status id length pos; do
  [[ "$status" != "Playing" ]] && continue

  length_s=$(( ${length:-0} / 1000000 ))
  pos_s=$(( ${pos:-0} / 1000000 ))

  if [[ "$id" != "$last_id" ]]; then
    spotify_track_change_notify "$last_id"
    last_id="$id"
    last_len="$length_s"
  fi

  last_pos="$pos_s"
done < <("$PLAYERCTL_BIN" -p "$SPOTIFY_PLAYER" metadata --format '{{status}}|{{mpris:trackid}}|{{mpris:length}}|{{position}}' --follow)
