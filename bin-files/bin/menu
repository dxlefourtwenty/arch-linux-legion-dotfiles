#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󰋁  Apps
󰨝  Dashboard
  Style
󰧑  Learn
  Config
  Tools
  Activity
⏻  System"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 260px; }
        entry { placeholder: "Go…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen##* }"

case "$label" in
    Apps) "$SCRIPT_DIR/menu-apps" ;;
    Dashboard) "$SCRIPT_DIR/toggle-dashboard" ;;
    Style) "$SCRIPT_DIR/menu-style" ;;
    Learn) "$SCRIPT_DIR/menu-learn" ;;
    Config) "$SCRIPT_DIR/menu-config" ;;
    Tools) "$SCRIPT_DIR/menu-tools" ;;
    Activity) "$SCRIPT_DIR/launch-terminal" btop ;;
    System) "$SCRIPT_DIR/menu-power" ;;
esac
