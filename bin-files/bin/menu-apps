#!/usr/bin/env bash
set -euo pipefail

LIST="$HOME/.config/apps.list"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-apps"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

selection=$(
awk -F'|' '{
    name=$3
    icon=$2
    printf "%s\0icon\x1f%s\n", name, icon
}' "$LIST" |
rofi -dmenu -i -show-icons \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 300px; }
        entry { placeholder: "Launch…"; }
        element {
            orientation: horizontal;
            children: [ element-icon, element-text ];
            spacing: 8px;
            padding: 8px 8px;
        }
        element-icon { 
            size: 26px; 
        }
        element-text {
            horizontal-align: 0.0;
            padding: 0px 6px;
        }
    '
)

[[ -z "$selection" ]] && exit 0

launcher=$(
awk -F'|' -v name="$selection" '$3==name {print $1; exit}' "$LIST"
)

[[ -z "$launcher" ]] && exit 0

if [[ "$launcher" == *.desktop ]]; then
    setsid gtk-launch "${launcher%.desktop}" >/dev/null 2>&1 &
elif [[ -x "$SCRIPT_DIR/$launcher" ]]; then
    setsid "$SCRIPT_DIR/$launcher" >/dev/null 2>&1 &
elif command -v "$launcher" >/dev/null 2>&1; then
    setsid "$launcher" >/dev/null 2>&1 &
fi
