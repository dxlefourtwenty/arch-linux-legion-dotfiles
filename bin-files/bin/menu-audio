#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-audio"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

# Get sinks
sinks=$(pactl list sinks short)
current_sink=$(pactl get-default-sink 2>/dev/null)

options=()
entries=()

display_name_for_sink() {
    local raw="$1"

    shopt -s nocasematch
    if [[ "$raw" == *acer* ]]; then
        printf 'Acer\n'
    elif [[ "$raw" == *asus* ]]; then
        printf 'Asus\n'
    else
        printf '%s\n' "$raw"
    fi
    shopt -u nocasematch
}

while read -r id name driver format channels rate state; do
    # Get node.nick (real device name like Acer/ASUS)
    nick=$(pactl list sinks | awk -v n="$name" '
        $0 ~ "Name: " n {found=1}
        found && /node.nick/ {
            gsub(/.*= "/, "")
            gsub(/"/, "")
            print
            exit
        }
    ')

    # Label logic
    if [[ "$name" == *usb* ]]; then
        label="󰋋  Headset"
    elif [[ "$name" == *hdmi* ]]; then
        label="󰍹  $(display_name_for_sink "$nick")"
    elif [[ "$name" == *analog* ]]; then
        label="󰓃  Speakers"
    else
        label="󰕾  Audio"
    fi

    display_label="$(printf '%s\n' "$label" | "$SCRIPT_DIR/rofi-nerd-markup")"

    if [[ "$name" == "$current_sink" ]]; then
        display_label="<i>$display_label</i>"
    fi

    entries+=("$display_label|$name")
done <<< "$sinks"

chosen=$(printf '%s\n' "${entries[@]}" | cut -d'|' -f1 | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 260px; }
        entry { placeholder: "Audio…"; }
        element {
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text {
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

chosen_plain=$(printf '%s' "$chosen" | sed -E 's/<[^>]+>//g')
sink_id=""

for entry in "${entries[@]}"; do
    label="${entry%%|*}"
    name="${entry##*|}"

    plain=$(printf '%s' "$label" | sed -E 's/<[^>]+>//g')

    if [[ "$plain" == "$chosen" ]]; then
        sink_id="$name"
        break
    fi
done

if [ -n "$sink_id" ]; then
    pactl set-default-sink "$sink_id"

    # Move existing audio streams
    pactl list sink-inputs short | while read -r input rest; do
        pactl move-sink-input "$input" "$sink_id"
    done
fi
