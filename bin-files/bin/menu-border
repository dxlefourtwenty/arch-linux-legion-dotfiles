#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-border"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󰃎  Thickness
󰝤  Rounding
󱡓  Rounding Smoothness"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 360px; }
        entry { placeholder: "Border…"; }
        element {
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text {
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"

case "$label" in
  "Thickness")
    "$SCRIPT_DIR/menu-border-thickness"
    ;;
  "Rounding")
    "$SCRIPT_DIR/menu-border-radius"
    ;;
  "Rounding Smoothness")
    "$SCRIPT_DIR/menu-border-rounding-power"
    ;;
esac
