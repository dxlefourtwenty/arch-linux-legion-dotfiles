#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
HYPR_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/decorations.conf"
MENU_ID="menu-border-rounding-power"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

get_current_value() {
    awk '
        /^[[:space:]]*decoration[[:space:]]*\{/ {
            in_section = 1
            next
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        in_section && /^[[:space:]]*rounding_power[[:space:]]*=/ {
            sub(/^[[:space:]]*rounding_power[[:space:]]*=[[:space:]]*/, "", $0)
            sub(/[[:space:]]*(#.*)?$/, "", $0)
            print $0
            exit
        }
    ' "$HYPR_CONF"
}

normalize_value() {
    local input="$1"

    awk -v value="$input" '
        BEGIN {
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)

            if (value !~ /^[+-]?(([0-9]+([.][0-9]*)?)|([.][0-9]+))$/) {
                exit 1
            }

            number = value + 0

            if (number < 0) {
                number = 0
            } else if (number > 10) {
                number = 10
            }

            if (number == int(number)) {
                printf "%.1f\n", number
                exit
            }

            formatted = sprintf("%.10f", number)
            sub(/0+$/, "", formatted)

            if (formatted ~ /\.$/) {
                formatted = formatted "0"
            }

            print formatted
        }
    '
}

update_value() {
    local new_value="$1"
    local tmp_file

    tmp_file="$(mktemp)"

    awk -v new_value="$new_value" '
        /^[[:space:]]*decoration[[:space:]]*\{/ {
            in_section = 1
        }

        in_section && !updated && /^[[:space:]]*rounding_power[[:space:]]*=/ {
            sub(/=[[:space:]]*[^[:space:]#]+/, "= " new_value)
            updated = 1
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        { print }

        END {
            if (!updated) {
                exit 1
            }
        }
    ' "$HYPR_CONF" > "$tmp_file"

    mv "$tmp_file" "$HYPR_CONF"
}

[[ -f "$HYPR_CONF" ]] || {
    notify-send -t 4000 "Border" "Config not found: $HYPR_CONF"
    exit 1
}

while true; do
    current_value="$(get_current_value)"
    current_value="${current_value:-0.0}"

    selected="$(
        printf '' | rofi -dmenu -i \
            -pid "$PID_FILE" \
            -p "" \
            -mesg "Current Rounding Smoothness = $current_value" \
            -theme-str '
                window { width: 510px; }
                mainbox { children: [ inputbar, message, listview ]; }
                inputbar { children: [ entry ]; }
                entry { placeholder: "Enter Rounding Smoothness…"; }
                message {
                    padding: 0px 8px 8px 8px;
                }
                textbox {
                    horizontal-align: 0.0;
                }
                listview {
                    lines: 0;
                    spacing: 0px;
                    padding: 0px;
                }
                element {
                    orientation: horizontal;
                    children: [ element-text ];
                    spacing: 0px;
                    padding: 8px 8px;
                }
                element-text {
                    horizontal-align: 0.0;
                    padding-left: 0px;
                }
            '
    )"

    [[ -n "$selected" ]] || exit 0

    if ! new_value="$(normalize_value "$selected")"; then
        notify-send -t 4000 "Border" "Enter a valid number."
        continue
    fi

    update_value "$new_value"

    if command -v hyprctl >/dev/null 2>&1; then
        hyprctl reload >/dev/null 2>&1 || notify-send -t 4000 "Border" "Rounding Smoothness updated, but Hyprland reload failed."
    fi

    notify-send -t 3000 "Border" "Rounding Smoothness set to $new_value"
    exit 0
done
