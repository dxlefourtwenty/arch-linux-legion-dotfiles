#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-capture"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

options="  Screenshot
  Screenrecord
  Color"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 320px; }
        entry { placeholder: "Capture…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

label="${chosen#*  }"

case "$label" in
  "Screenshot")
    "$SCRIPT_DIR/menu-screenshot"
    ;;
  "Screenrecord")
    if pgrep -x obs >/dev/null 2>&1; then
      if ! hyprctl dispatch focuswindow 'class:^(obs)$' >/dev/null 2>&1; then
        obs >/dev/null 2>&1 &
      fi
    else
      obs >/dev/null 2>&1 &
    fi
    ;;
  "Color")
    "$SCRIPT_DIR/launch-colorpicker"
    ;;
esac
