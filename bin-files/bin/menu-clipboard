#!/usr/bin/env bash
set -euo pipefail

MAX_THUMBNAILS="${MENU_CLIPBOARD_MAX_THUMBNAILS:-12}"
MAX_MENU_ENTRIES="${MENU_CLIPBOARD_MAX_ENTRIES:-200}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/menu-clipboard"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-clipboard"
PID_FILE="/tmp/menu-rofi.pid"
CLEANUP_STAMP="$CACHE_DIR/.last-cleanup"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

THEME='
window { width: 900px; }
inputbar {
    children: [ entry ];
}
entry { placeholder: "Clipboard…"; }
listview { lines: 15; }
element {
    orientation: horizontal;
    children: [ element-text, element-icon ];
    spacing: 8px;
    padding: 8px 10px;
}
element-icon {
    size: 2.2em;
    margin: -10px 0px 0px 0px;
}
element-text {
    horizontal-align: 0.0;
    padding-left: 0px;
}
'

cache_key_for_entry() {
    printf '%s' "$1" | sha256sum | awk '{print $1}'
}

cache_entry_status() {
    local cache_key="$1"
    local status_file="$CACHE_DIR/$cache_key.status"

    if [[ -f "$status_file" ]]; then
        cat "$status_file"
    fi
}

build_image_label() {
    local image_path="$1"
    local mime_type="$2"
    local dimensions bytes human_bytes

    dimensions="$(identify -format '%wx%h' "$image_path" 2>/dev/null || true)"
    bytes="$(stat -c '%s' "$image_path" 2>/dev/null || echo 0)"
    human_bytes="$(numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || echo "${bytes} B")"

    printf '%s' "${mime_type} -- size: ${dimensions:-unknown}, ${human_bytes}"
}

cache_image_thumbnail() {
    local entry="$1"
    local cache_key="$2"
    local decode_file="$3"
    local mime_type extension image_path label_path status_path

    mime_type="$(file --mime-type -b "$decode_file" 2>/dev/null || true)"
    status_path="$CACHE_DIR/$cache_key.status"

    if [[ "$mime_type" != image/* ]]; then
        printf 'not-image' >"$status_path"
        return 1
    fi

    extension="${mime_type#image/}"
    image_path="$CACHE_DIR/$cache_key.$extension"
    label_path="$CACHE_DIR/$cache_key.label"

    cp "$decode_file" "$image_path"
    build_image_label "$image_path" "$mime_type" >"$label_path"
    printf '%s\n%s\n' 'image' "$image_path" >"$status_path"
    return 0
}

append_menu_entry() {
    local preview="$1"
    local entry="$2"
    local decode_file="$3"
    local menu_input="$4"
    local cache_key status_file status image_path label_path label

    cache_key="$(cache_key_for_entry "$entry")"
    status_file="$CACHE_DIR/$cache_key.status"
    status="$(cache_entry_status "$cache_key")"

    if [[ "$status" == image* ]]; then
        image_path="$(sed -n '2p' "$status_file" 2>/dev/null || true)"
        label_path="$CACHE_DIR/$cache_key.label"

        if [[ -f "$image_path" && -f "$label_path" ]]; then
            label="$(cat "$label_path")"
            printf '%s\0icon\x1f%s\n' "$label" "$image_path" >>"$menu_input"
            return 0
        fi
    elif [[ "$status" == "not-image" ]]; then
        printf '%s\n' "$preview" >>"$menu_input"
        return 1
    fi

    if printf '%s\n' "$entry" | cliphist decode >"$decode_file" 2>/dev/null; then
        if cache_image_thumbnail "$entry" "$cache_key" "$decode_file"; then
            image_path="$(sed -n '2p' "$status_file" 2>/dev/null || true)"
            label="$(cat "$CACHE_DIR/$cache_key.label" 2>/dev/null || true)"
            printf '%s\0icon\x1f%s\n' "$label" "$image_path" >>"$menu_input"
            return 0
        fi
    fi

    printf '%s\n' "$preview" >>"$menu_input"
    return 1
}

if ! history="$(cliphist list 2>/dev/null)"; then
    history=""
fi

if [[ -z "$history" ]]; then
    notify-send "Clipboard" "No clipboard history found"
    exit 0
fi

mkdir -p "$CACHE_DIR"

if [[ ! -f "$CLEANUP_STAMP" ]] || find "$CLEANUP_STAMP" -mtime +0 | grep -q .; then
    find "$CACHE_DIR" -type f -mtime +14 -delete 2>/dev/null || true
    touch "$CLEANUP_STAMP"
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"; "$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

menu_input="$tmp_dir/menu-input"
decode_file="$tmp_dir/decode"

declare -a history_entries=()
declare -a history_previews=()

while IFS= read -r history_line; do
    [[ -z "${history_line:-}" ]] && continue

    preview="${history_line#*$'\t'}"
    if [[ "$preview" == "$history_line" ]]; then
        preview="[empty]"
    elif [[ -z "$preview" ]]; then
        preview="[empty]"
    fi

    history_entries+=("$history_line")
    history_previews+=("$preview")

    if (( ${#history_entries[@]} >= MAX_MENU_ENTRIES )); then
        break
    fi
done <<< "$history"

if (( ${#history_entries[@]} == 0 )); then
    notify-send "Clipboard" "No clipboard history found"
    exit 0
fi

thumbnail_count=0
for row_index in "${!history_entries[@]}"; do
    preview="${history_previews[$row_index]}"
    entry="${history_entries[$row_index]}"

    if (( thumbnail_count < MAX_THUMBNAILS )); then
        if append_menu_entry "$preview" "$entry" "$decode_file" "$menu_input"; then
            ((thumbnail_count += 1))
        fi
    else
        printf '%s\n' "$preview" >>"$menu_input"
    fi
done

chosen_index="$(rofi -dmenu -i \
    -pid "$PID_FILE" \
    -p "" \
    -format i \
    -no-custom \
    -show-icons \
    -theme-str "$THEME" \
    <"$menu_input")"

[[ -z "$chosen_index" ]] && exit 0

chosen="${history_entries[$chosen_index]:-}"
[[ -z "$chosen" ]] && exit 0

tmp="$tmp_dir/selected"

printf '%s\n' "$chosen" | cliphist decode >"$tmp"

mime_type="$(file --mime-type -b "$tmp")"

if [[ "$mime_type" == image/* ]]; then
    wl-copy --type "$mime_type" <"$tmp"
    notify-send "Clipboard" "Copied image from history"
else
    wl-copy --type "$mime_type" <"$tmp"
    notify-send "Clipboard" "Copied selection from history"
fi
