#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="¾░©î  Themes
´Ç¥  Background
¯İ©  Audio
´ç½  WiFi
´èô  Bluetooth
´ıÖ  Hyprland
´âë  Waybar
¾░«½  Rofi
´â│  Mako
´äá  Kitty
¯¬à  Alacritty"

HOME_DIR="/home/dxle"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -p "" \
    -theme-str '
        window { width: 250px; }
        entry { placeholder: "ConfigÔÇĞ"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

case "$chosen" in
  *Themes)
    "$SCRIPT_DIR/launch-terminal-floating" 1600 900 nvim ~/.config/themes/
    ;;
  *Background)
    "$SCRIPT_DIR/launch-file-explorer" ~/.config/themes/current/wallpapers/
    ;;
  *Audio)
    "$SCRIPT_DIR/menu-audio"
    ;;
  *WiFi)
    "$SCRIPT_DIR/launch-terminal" nmtui
    ;;
  *Bluetooth)
    "$SCRIPT_DIR/launch-terminal" bluetuith
    ;;
  *Hyprland)
    "$SCRIPT_DIR/launch-terminal-floating" 1600 900 nvim ~/.config/hypr/ &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/hypr/"
    ;;
  *Waybar)
    "$SCRIPT_DIR/launch-terminal-floating" 1400 800 nvim ~/.config/waybar &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/waybar"
    ;;
  *Rofi)
    "$SCRIPT_DIR/launch-terminal-floating" 1400 800 nvim ~/.config/rofi &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/rofi"
    ;;
  *Mako)
    "$SCRIPT_DIR/launch-terminal-floating" 1400 800 nvim ~/.config/mako/config &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/mako/config"
    ;;
  *Kitty)
    "$SCRIPT_DIR/launch-terminal-floating" 1400 800 nvim ~/.config/kitty/kitty.conf &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/kitty/kitty.conf"
    ;;
  *Alacritty)
    "$SCRIPT_DIR/launch-terminal-floating" 1400 800 nvim ~/.config/alacritty/alacritty.toml &
    notify-send -t 3000 "Config" "Editing $HOME_DIR/.config/alacritty/alacritty.toml"
    ;;
esac
