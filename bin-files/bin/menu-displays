#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-displays"
PID_FILE="/tmp/menu-rofi.pid"
MONITORS_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/monitors.conf"
BACKUP_FILE="${XDG_RUNTIME_DIR:-/tmp}/menu-displays.monitors.conf.bak"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

if ! command -v hyprctl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    notify-send -t 4000 "Displays" "Missing dependency: hyprctl or jq"
    exit 1
fi

if ! monitors_json="$(hyprctl -j monitors all 2>/dev/null)"; then
    notify-send -t 4000 "Displays" "Unable to read Hyprland monitors"
    exit 1
fi

if [[ "$(jq 'length' <<< "$monitors_json")" -eq 0 ]]; then
    notify-send -t 4000 "Displays" "No monitors found"
    exit 1
fi

set_monitor_state_in_config() {
    local target_monitor="$1"
    local target_state="$2"
    local tmp_file=""
    local changed=0

    [[ -f "$MONITORS_CONF" ]] || return 1

    tmp_file="$(mktemp)"

    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$line" =~ ^([[:space:]]*)#?[[:space:]]*monitor[[:space:]]*=[[:space:]]*(${target_monitor},[^#]*)([[:space:]]+#.*)?$ ]]; then
            local indent="${BASH_REMATCH[1]}"
            local body="${BASH_REMATCH[2]}"
            local comment="${BASH_REMATCH[3]:-}"
            local prefix=""

            changed=1

            if [[ "$body" == "${target_monitor},disable"* ]]; then
                [[ "$target_state" == "enabled" ]] && prefix="#"
            else
                [[ "$target_state" == "disabled" ]] && prefix="#"
            fi

            printf '%s%smonitor=%s%s\n' "$indent" "$prefix" "$body" "$comment" >> "$tmp_file"
        else
            printf '%s\n' "$line" >> "$tmp_file"
        fi
    done < "$MONITORS_CONF"

    if [[ "$changed" -eq 0 ]]; then
        rm -f "$tmp_file"
        return 1
    fi

    mv "$tmp_file" "$MONITORS_CONF"
}

ensure_backup() {
    [[ -f "$BACKUP_FILE" ]] || cp "$MONITORS_CONF" "$BACKUP_FILE"
}

restore_backup() {
    [[ -f "$BACKUP_FILE" ]] || return 1
    cp "$BACKUP_FILE" "$MONITORS_CONF"
    rm -f "$BACKUP_FILE"
}

monitors=()
display_monitors=()

while IFS= read -r row; do
    name="$(jq -r '.name' <<< "$row")"
    model="$(jq -r '.model // empty' <<< "$row")"
    disabled="$(jq -r '.disabled' <<< "$row")"

    label="󰍹  $name"
    if [[ -n "$model" && "$model" != "$name" ]]; then
        label+="  $model"
    fi

    pretty="$(printf '%s\n' "$label" | "$SCRIPT_DIR/rofi-nerd-markup")"
    if [[ "$disabled" == "false" ]]; then
        pretty="<i>$pretty</i>"
    fi

    monitors+=("$name")
    display_monitors+=("$pretty")
done < <(jq -c '.[]' <<< "$monitors_json")

display_monitors+=("$(printf '%s\n' "󰑐  Default Layout" | "$SCRIPT_DIR/rofi-nerd-markup")")

chosen_index="$(
    printf '%s\n' "${display_monitors[@]}" | rofi -dmenu -i -markup-rows -format i \
        -pid "$PID_FILE" \
        -p "" \
        -theme-str '
            window { width: 360px; }
            entry { placeholder: "Displays…"; }
            element {
                orientation: horizontal;
                children: [ element-text ];
                spacing: 0px;
                padding: 8px 2px;
            }
            element-text {
                horizontal-align: 0.0;
                padding-left: 0px;
            }
        '
)"

[[ "$chosen_index" =~ ^[0-9]+$ ]] || exit 0

if (( chosen_index == ${#monitors[@]} )); then
    restore_backup || true
    hyprctl reload >/dev/null
    exit 0
fi

selected_monitor="${monitors[$chosen_index]}"
selected_disabled="$(jq -r --arg name "$selected_monitor" '.[] | select(.name == $name) | .disabled' <<< "$monitors_json")"
ensure_backup

if [[ "$selected_disabled" == "false" ]]; then
    set_monitor_state_in_config "$selected_monitor" "disabled"
else
    set_monitor_state_in_config "$selected_monitor" "enabled"
fi

hyprctl reload >/dev/null
