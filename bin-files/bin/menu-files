#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="  Edit File
  File Explorer"

chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 300px; }
        entry { placeholder: "Files…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
    "Edit File")      "$SCRIPT_DIR/menu-edit-file" ;;
    "File Explorer")  nemo ;;
    *) exit 0 ;;
esac
