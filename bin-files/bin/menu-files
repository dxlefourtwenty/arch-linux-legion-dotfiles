#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-files"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="  Edit File
  File Explorer
󰈙  Open PDF
󰇮  Share with LocalSend"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 400px; }
        entry { placeholder: "Files…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
    "Edit File")      "$SCRIPT_DIR/menu-edit-file" ;;
    "File Explorer")  "$SCRIPT_DIR/menu-file-explorer" ;;
    "Open PDF")       "$SCRIPT_DIR/launch-zathura-pdf" ;;
    "Share with LocalSend") "$SCRIPT_DIR/menu-localsend-share-file" ;;
    *) exit 0 ;;
esac
