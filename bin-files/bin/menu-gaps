#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
HYPR_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/decorations.conf"
MENU_ID="menu-gaps"
PID_FILE="/tmp/menu-rofi.pid"
GAPS_MIN=0
GAPS_MAX=30
WAYBAR_MARGIN_MIN=2

# format: path|addition|base_value
WAYBAR_CONFIGS=(
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/floating.jsonc|true|14"
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/pill.jsonc|true|38"
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/island.jsonc|false|0"
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/minimal.jsonc|false|0"
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/spaced-arrow.jsonc|false|0"
    "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/configs/arrowline.jsonc|false|0"
)

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

get_current_gap() {
    awk '
        /^[[:space:]]*general[[:space:]]*\{/ {
            in_section = 1
            next
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        in_section && /^[[:space:]]*gaps_out[[:space:]]*=/ {
            value = $0
            sub(/^[[:space:]]*gaps_out[[:space:]]*=[[:space:]]*/, "", value)
            sub(/[[:space:]]*(#.*)?$/, "", value)
            print value
            exit
        }
    ' "$HYPR_CONF"
}

normalize_value() {
    local input="$1"

    awk -v value="$input" -v min_value="$GAPS_MIN" -v max_value="$GAPS_MAX" '
        BEGIN {
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)

            if (value !~ /^[+-]?(([0-9]+([.][0-9]*)?)|([.][0-9]+))$/) {
                exit 1
            }

            number = value + 0
            floored = (number >= 0 || number == int(number)) ? int(number) : int(number) - 1

            if (floored < min_value) {
                floored = min_value
            } else if (floored > max_value) {
                floored = max_value
            }

            print floored
        }
    '
}

update_values() {
    local new_out="$1"
    local new_in="$2"
    local tmp_file

    tmp_file="$(mktemp)"

    awk -v new_out="$new_out" -v new_in="$new_in" '
        /^[[:space:]]*general[[:space:]]*\{/ {
            in_section = 1
        }

        in_section && !updated_out && /^[[:space:]]*gaps_out[[:space:]]*=/ {
            sub(/=[[:space:]]*[^[:space:]#]+/, "= " new_out)
            updated_out = 1
        }

        in_section && !updated_in && /^[[:space:]]*gaps_in[[:space:]]*=/ {
            sub(/=[[:space:]]*[^[:space:]#]+/, "= " new_in)
            updated_in = 1
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        { print }

        END {
            if (!updated_out || !updated_in) {
                exit 1
            }
        }
    ' "$HYPR_CONF" > "$tmp_file"

    mv "$tmp_file" "$HYPR_CONF"
}

is_valid_waybar_bool() {
    local value="$1"

    [[ "$value" == "true" || "$value" == "false" ]]
}

is_valid_nonnegative_integer() {
    local value="$1"

    [[ "$value" =~ ^[0-9]+$ ]]
}

config_has_key() {
    local config_file="$1"
    local key_name="$2"

    awk -v key_name="$key_name" '
        index($0, "\"" key_name "\"") {
            found = 1
            exit
        }

        END {
            exit found ? 0 : 1
        }
    ' "$config_file"
}

update_waybar_vertical_margins() {
    local config_file="$1"
    local new_top="$2"
    local new_bottom="$3"
    local tmp_file

    tmp_file="$(mktemp)"

    if ! awk -v new_top="$new_top" -v new_bottom="$new_bottom" '
        /"margin-top"[[:space:]]*:/ && !updated_top {
            sub(/"margin-top"[[:space:]]*:[[:space:]]*[-]?[0-9]+([.][0-9]+)?/, "\"margin-top\": " new_top)
            updated_top = 1
        }

        /"margin-bottom"[[:space:]]*:/ && !updated_bottom {
            sub(/"margin-bottom"[[:space:]]*:[[:space:]]*[-]?[0-9]+([.][0-9]+)?/, "\"margin-bottom\": " new_bottom)
            updated_bottom = 1
        }

        { print }

        END {
            if (!updated_top || !updated_bottom) {
                exit 1
            }
        }
    ' "$config_file" > "$tmp_file"; then
        rm -f "$tmp_file"
        return 1
    fi

    mv "$tmp_file" "$config_file"
}

update_waybar_horizontal_margins() {
    local config_file="$1"
    local new_left="$2"
    local new_right="$3"
    local tmp_file

    tmp_file="$(mktemp)"

    if ! awk -v new_left="$new_left" -v new_right="$new_right" '
        /"margin-left"[[:space:]]*:/ && !updated_left {
            sub(/"margin-left"[[:space:]]*:[[:space:]]*[-]?[0-9]+([.][0-9]+)?/, "\"margin-left\": " new_left)
            updated_left = 1
        }

        /"margin-right"[[:space:]]*:/ && !updated_right {
            sub(/"margin-right"[[:space:]]*:[[:space:]]*[-]?[0-9]+([.][0-9]+)?/, "\"margin-right\": " new_right)
            updated_right = 1
        }

        { print }

        END {
            if (!updated_left || !updated_right) {
                exit 1
            }
        }
    ' "$config_file" > "$tmp_file"; then
        rm -f "$tmp_file"
        return 1
    fi

    mv "$tmp_file" "$config_file"
}

[[ -f "$HYPR_CONF" ]] || {
    notify-send -t 4000 "Gaps" "Config not found: $HYPR_CONF"
    exit 1
}

while true; do
    current_gap="$(get_current_gap)"
    current_gap="${current_gap:-0}"

    selected="$(
        printf '' | rofi -dmenu -i \
            -pid "$PID_FILE" \
            -p "" \
            -mesg "Current Gaps = $current_gap" \
            -theme-str '
                window { width: 380px; }
                mainbox { children: [ inputbar, message, listview ]; }
                inputbar { children: [ entry ]; }
                entry { placeholder: "Enter Gaps…"; }
                message {
                    padding: 0px 8px 8px 8px;
                }
                textbox {
                    horizontal-align: 0.0;
                }
                listview {
                    lines: 0;
                    spacing: 0px;
                    padding: 0px;
                }
                element {
                    orientation: horizontal;
                    children: [ element-text ];
                    spacing: 0px;
                    padding: 8px 8px;
                }
                element-text {
                    horizontal-align: 0.0;
                    padding-left: 0px;
                }
            '
    )"

    [[ -n "$selected" ]] || exit 0

    if ! new_out="$(normalize_value "$selected")"; then
        notify-send -t 4000 "Gaps" "Enter a valid number."
        continue
    fi

    new_in=$((new_out / 2))
    new_margin_top=$((new_out < WAYBAR_MARGIN_MIN ? WAYBAR_MARGIN_MIN : new_out))
    new_margin_bottom=$((new_out < WAYBAR_MARGIN_MIN ? WAYBAR_MARGIN_MIN - new_out : 0))

    update_values "$new_out" "$new_in"

    for waybar_entry in "${WAYBAR_CONFIGS[@]}"; do
        IFS='|' read -r waybar_config addition_enabled base_value <<< "$waybar_entry"

        if [[ ! -f "$waybar_config" ]]; then
            notify-send -t 4000 "Gaps" "Waybar config not found: $waybar_config"
            continue
        fi

        if ! is_valid_waybar_bool "$addition_enabled"; then
            notify-send -t 4000 "Gaps" "Invalid addition flag for: $waybar_config"
            continue
        fi

        if ! is_valid_nonnegative_integer "$base_value"; then
            notify-send -t 4000 "Gaps" "Invalid base value for: $waybar_config"
            continue
        fi

        if config_has_key "$waybar_config" "margin-top" && config_has_key "$waybar_config" "margin-bottom"; then
            if ! update_waybar_vertical_margins "$waybar_config" "$new_margin_top" "$new_margin_bottom"; then
                notify-send -t 4000 "Gaps" "Failed to update Waybar config: $waybar_config"
                continue
            fi
        fi

        if [[ "$addition_enabled" == "true" ]]; then
            new_margin_side=$((base_value + new_out))

            if config_has_key "$waybar_config" "margin-left" && config_has_key "$waybar_config" "margin-right"; then
                if ! update_waybar_horizontal_margins "$waybar_config" "$new_margin_side" "$new_margin_side"; then
                    notify-send -t 4000 "Gaps" "Failed to update Waybar side margins: $waybar_config"
                fi
            else
                notify-send -t 4000 "Gaps" "Addition enabled, but side margins are missing: $waybar_config"
            fi
        fi
    done

    if command -v hyprctl >/dev/null 2>&1; then
        hyprctl reload >/dev/null 2>&1 || notify-send -t 4000 "Gaps" "Gaps updated, but Hyprland reload failed."
    fi

    ~/bin/reload-waybar
    notify-send -t 3000 "Gaps" "Set to $new_out"
    exit 0
done
