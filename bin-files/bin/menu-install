#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="  System Update
  Arch
  AUR"

HOME_DIR="/home/dxle"

chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 275px; }
        entry { placeholder: "Install…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Arch")
    "$SCRIPT_DIR/launch-pacman-tui"
    ;;
  "AUR")
    "$SCRIPT_DIR/launch-pacman-aur-tui"
    ;;
  "System Update")
    "$SCRIPT_DIR/launch-pacman-update"
    ;;
esac
