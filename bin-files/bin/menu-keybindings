#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
HYPERLAND_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/keybindings.conf"
FILE="$SCRIPT_DIR/scans/keybindings"
arrow=" "

[[ ! -f "$HYPERLAND_FILE" ]] && {
    notify-send "Keybind Menu" "File not found: $HYPERLAND_FILE"
    exit 1
}

[[ ! -f "$FILE" ]] && {
    notify-send "Keybind Menu" "File not found: $FILE"
    exit 1
}

combined_file="$(mktemp)"
trap 'rm -f "$combined_file"' EXIT

awk '
function trim(str) {
    sub(/^[[:space:]]+/, "", str)
    sub(/[[:space:]]+$/, "", str)
    return str
}

function normalize_mods(str,    n, i, parts, out) {
    str = trim(str)
    if (str == "") {
        return ""
    }

    n = split(str, parts, /[[:space:]]+/)
    out = ""
    for (i = 1; i <= n; i++) {
        if (parts[i] == "") {
            continue
        }
        if (out != "") {
            out = out " + "
        }
        out = out parts[i]
    }
    return out
}

function replace_vars(str,    changed, name) {
    changed = str
    for (name in vars) {
        gsub("\\" name, vars[name], changed)
    }
    return changed
}

/^[[:space:]]*\$/ {
    split($0, pair, "=")
    if (length(pair) >= 2) {
        name = trim(pair[1])
        value = trim(substr($0, index($0, "=") + 1))
        vars[name] = value
    }
    next
}

/^[[:space:]]*bind[a-z]*d[a-z]*[[:space:]]*=/ {
    split($0, pair, "=")
    right = trim(pair[2])
    count = split(right, fields, ",")
    if (count < 3) {
        next
    }

    mods = replace_vars(trim(fields[1]))
    key = replace_vars(trim(fields[2]))
    desc = trim(fields[3])

    if (desc == "") {
        next
    }

    left = normalize_mods(mods)
    if (left != "" && key != "") {
        left = left " + " key
    } else if (key != "") {
        left = key
    }

    print left " | " desc
}
' "$HYPERLAND_FILE" > "$combined_file"

cat "$FILE" >> "$combined_file"

# Get longest left column width
max_width=$(awk -F'|' '
{
    gsub(/^ +| +$/, "", $1)
    print length($1)
}' "$combined_file" | sort -nr | head -1)

# Format for rofi
formatted=$(
awk -F'|' -v arrow="$arrow" -v width="$max_width" '
{
    left=$1
    right=$2

    gsub(/^ +| +$/, "", left)
    gsub(/^ +| +$/, "", right)

    printf "%-*s    %s %s\n", width, left, arrow, right
}
' "$combined_file"
)

chosen=$(echo "$formatted" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 1075px; }
        entry { placeholder: "Keybindings…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
            font: "JetBrainsMono Nerd Font 16";
        }
    ')

# Do nothing on selection (view-only menu)
exit 0
