#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROFI_BIN="/usr/bin/rofi"
NOTIFY_BIN="/home/dxle/bin/notify-send"
AWK_BIN="/usr/bin/awk"
MKDIR_BIN="/usr/bin/mkdir"
MKTEMP_BIN="/usr/bin/mktemp"
MV_BIN="/usr/bin/mv"
RM_BIN="/usr/bin/rm"
HYPRCTL_BIN="/usr/bin/hyprctl"
READLINK_BIN="/usr/bin/readlink"
HYPR_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/decorations.conf"
ANIMATIONS_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/animations.conf"
PLUGINS_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/plugins.conf"
XDG_STATE_HOME_DEFAULT="${HOME}/.local/state"
STATE_DIR="${XDG_STATE_HOME:-$XDG_STATE_HOME_DEFAULT}/menu-layout"
AXIS_STATE_FILE="${STATE_DIR}/workspace-axis.state"
MENU_ID="menu-layouts"
PID_FILE="/tmp/menu-rofi.pid"
DRY_RUN=0
SELECTED_LAYOUT=""
LAYOUTS=("dwindle" "scrolling" "master" "monocle")

usage() {
    printf 'Usage: %s [--layout master|dwindle|scrolling|monocle] [--config PATH] [--animations-config PATH] [--plugins-config PATH] [--dry-run]\n' "$(basename "$0")"
}

notify() {
    "$NOTIFY_BIN" -t 4000 "Layout" "$1" >/dev/null 2>&1 || true
}

is_valid_layout() {
    local candidate="$1"
    local layout=""

    for layout in "${LAYOUTS[@]}"; do
        [[ "$candidate" == "$layout" ]] && return 0
    done

    return 1
}

format_layout_display() {
    case "$1" in
        master)
            printf 'Master\n'
            ;;
        dwindle)
            printf 'Dwindle\n'
            ;;
        scrolling)
            printf 'Scrolling\n'
            ;;
        monocle)
            printf 'Monocle\n'
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

require_config() {
    [[ -f "$HYPR_CONF" ]] || {
        notify "Config not found: $HYPR_CONF"
        exit 1
    }

    [[ -f "$ANIMATIONS_CONF" ]] || {
        notify "Config not found: $ANIMATIONS_CONF"
        exit 1
    }

    [[ -f "$PLUGINS_CONF" ]] || {
        notify "Config not found: $PLUGINS_CONF"
        exit 1
    }
}

resolve_config_path() {
    local resolved_path=""

    resolved_path="$("$READLINK_BIN" -f "$HYPR_CONF" 2>/dev/null || true)"
    [[ -n "$resolved_path" ]] && HYPR_CONF="$resolved_path"

    resolved_path="$("$READLINK_BIN" -f "$ANIMATIONS_CONF" 2>/dev/null || true)"
    [[ -n "$resolved_path" ]] && ANIMATIONS_CONF="$resolved_path"

    resolved_path="$("$READLINK_BIN" -f "$PLUGINS_CONF" 2>/dev/null || true)"
    [[ -n "$resolved_path" ]] && PLUGINS_CONF="$resolved_path"
}

get_current_layout() {
    "$AWK_BIN" '
        /^[[:space:]]*general[[:space:]]*\{/ {
            in_section = 1
            next
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        in_section && /^[[:space:]]*layout[[:space:]]*=/ {
            value = $0
            sub(/^[[:space:]]*layout[[:space:]]*=[[:space:]]*/, "", value)
            sub(/[[:space:]]*(#.*)?$/, "", value)
            print value
            exit
        }
    ' "$HYPR_CONF"
}

normalize_layout() {
    case "$1" in
        scrollingfix)
            printf 'scrolling\n'
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

get_applied_layout() {
    local layout="$1"

    if [[ "$layout" == "scrolling" ]] && has_scrolling_fix_plugin; then
        printf 'scrollingfix\n'
        return
    fi

    printf '%s\n' "$layout"
}

has_scrolling_fix_plugin() {
    "$AWK_BIN" '
        {
            line = $0
            sub(/[[:space:]]*#.*/, "", line)
        }

        line ~ /hypr-scrolling-fix/ || line ~ /hyprscrollingfix\.so/ {
            found = 1
            exit
        }

        END {
            exit found ? 0 : 1
        }
    ' "$PLUGINS_CONF"
}

get_current_axis() {
    "$AWK_BIN" '
        {
            line = $0
            sub(/[[:space:]]*#.*/, "", line)
        }

        line ~ /^[[:space:]]*animation[[:space:]]*=[[:space:]]*workspaces([[:space:]]*,.*)?$/ {
            count = split(line, parts, ",")
            style = (count >= 5) ? parts[5] : ""

            if (style ~ /slidevert/) {
                print "vertical"
                exit
            }

            if (style ~ /slide/) {
                print "horizontal"
                exit
            }

            exit
        }
    ' "$ANIMATIONS_CONF"
}

axis_to_animation_style() {
    case "$1" in
        horizontal)
            printf 'slide\n'
            ;;
        vertical)
            printf 'slidevert\n'
            ;;
        *)
            return 1
            ;;
    esac
}

is_valid_axis() {
    case "$1" in
        horizontal|vertical)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

read_previous_axis() {
    local previous_axis=""

    [[ -r "$AXIS_STATE_FILE" ]] || return 1

    previous_axis="$("$AWK_BIN" 'NR == 1 { print; exit }' "$AXIS_STATE_FILE")"
    is_valid_axis "$previous_axis" || return 1

    printf '%s\n' "$previous_axis"
}

write_previous_axis() {
    local previous_axis="$1"
    local tmp_file=""

    is_valid_axis "$previous_axis" || return 1

    "$MKDIR_BIN" -p "$STATE_DIR"
    tmp_file="$("$MKTEMP_BIN" "${STATE_DIR}/.workspace-axis.XXXXXX")"
    printf '%s\n' "$previous_axis" > "$tmp_file"
    "$MV_BIN" "$tmp_file" "$AXIS_STATE_FILE"
}

clear_previous_axis() {
    "$RM_BIN" -f "$AXIS_STATE_FILE"
}

choose_layout() {
    local current_layout="$1"
    local display_layouts=()
    local layout=""
    local pretty=""
    local chosen_index=""

    for layout in "${LAYOUTS[@]}"; do
        pretty="$(format_layout_display "$layout")"

        if [[ "$layout" == "$current_layout" ]]; then
            pretty="<i>$pretty</i>"
        fi

        display_layouts+=("$pretty")
    done

    chosen_index="$(
        printf '%s\n' "${display_layouts[@]}" | "$ROFI_BIN" -dmenu -i -markup-rows -format i \
            -pid "$PID_FILE" \
            -p "" \
            -theme-str '
                window { width: 250px; }
                entry { placeholder: "Layout…"; }
                element {
                    orientation: horizontal;
                    children: [ element-text ];
                    spacing: 0px;
                    padding: 8px 8px;
                }
                element-text {
                    horizontal-align: 0.0;
                    padding-left: 0px;
                    margin: 0 2px;
                }
            '
    )" || return 1

    [[ "$chosen_index" =~ ^[0-9]+$ ]] || return 1
    [[ "$chosen_index" -lt "${#LAYOUTS[@]}" ]] || return 1

    printf '%s\n' "${LAYOUTS[chosen_index]}"
}

update_layout() {
    local new_layout="$1"
    local tmp_file=""

    tmp_file="$("$MKTEMP_BIN")"

    "$AWK_BIN" -v new_layout="$new_layout" '
        /^[[:space:]]*general[[:space:]]*\{/ {
            in_section = 1
        }

        in_section && !updated && /^[[:space:]]*layout[[:space:]]*=/ {
            sub(/=[[:space:]]*[^[:space:]#]+/, "= " new_layout)
            updated = 1
        }

        in_section && /^[[:space:]]*\}/ {
            in_section = 0
        }

        { print }

        END {
            if (!updated) {
                exit 1
            }
        }
    ' "$HYPR_CONF" > "$tmp_file"

    "$MV_BIN" "$tmp_file" "$HYPR_CONF"
}

update_workspace_animation() {
    local target_style="$1"
    local tmp_file=""

    tmp_file="$("$MKTEMP_BIN")"

    "$AWK_BIN" -v target_style="$target_style" '
        {
            raw_line = $0
            test_line = raw_line
            sub(/[[:space:]]*#.*/, "", test_line)
        }

        !updated && test_line ~ /^[[:space:]]*animation[[:space:]]*=[[:space:]]*workspaces([[:space:]]*,.*)?$/ {
            comment = ""
            body = raw_line

            if (match(raw_line, /[[:space:]]+#.*/)) {
                comment = substr(raw_line, RSTART)
                body = substr(raw_line, 1, RSTART - 1)
            }

            count = split(body, parts, ",")

            if (count >= 5) {
                style = parts[5]

                if (style ~ /slidevert/) {
                    sub(/slidevert/, target_style, style)
                } else if (style ~ /slide/) {
                    sub(/slide/, target_style, style)
                } else {
                    style = style " " target_style
                }

                parts[5] = style
                body = parts[1]

                for (i = 2; i <= count; i++) {
                    body = body "," parts[i]
                }
            } else {
                body = body ", " target_style
            }

            print body comment
            updated = 1
            next
        }

        { print raw_line }

        END {
            if (!updated) {
                exit 1
            }
        }
    ' "$ANIMATIONS_CONF" > "$tmp_file"

    "$MV_BIN" "$tmp_file" "$ANIMATIONS_CONF"
}

reload_hyprland() {
    [[ -x "$HYPRCTL_BIN" ]] || return 0
    "$HYPRCTL_BIN" reload >/dev/null 2>&1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --layout)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            SELECTED_LAYOUT="$2"
            shift 2
            ;;
        --config)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            HYPR_CONF="$2"
            shift 2
            ;;
        --animations-config)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            ANIMATIONS_CONF="$2"
            shift 2
            ;;
        --plugins-config)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            PLUGINS_CONF="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

resolve_config_path
require_config

CURRENT_APPLIED_LAYOUT="$(get_current_layout)"
[[ -n "$CURRENT_APPLIED_LAYOUT" ]] || {
    notify "Failed to detect current layout."
    exit 1
}

CURRENT_LAYOUT="$(normalize_layout "$CURRENT_APPLIED_LAYOUT")"

CURRENT_AXIS="$(get_current_axis)"
[[ -n "$CURRENT_AXIS" ]] || {
    notify "Failed to detect current workspace axis."
    exit 1
}

if [[ -z "$SELECTED_LAYOUT" ]]; then
    if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
        exit 0
    fi

    trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

    SELECTED_LAYOUT="$(choose_layout "$CURRENT_LAYOUT" || true)"
    [[ -n "$SELECTED_LAYOUT" ]] || exit 0
fi

is_valid_layout "$SELECTED_LAYOUT" || {
    notify "Invalid layout: $SELECTED_LAYOUT"
    exit 1
}

TARGET_APPLIED_LAYOUT="$(get_applied_layout "$SELECTED_LAYOUT")"

if [[ "$SELECTED_LAYOUT" == "$CURRENT_LAYOUT" && "$TARGET_APPLIED_LAYOUT" == "$CURRENT_APPLIED_LAYOUT" && "$SELECTED_LAYOUT" != "scrolling" ]]; then
    exit 0
fi

if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Would set layout to %s in %s\n' "$TARGET_APPLIED_LAYOUT" "$HYPR_CONF"

    if [[ "$CURRENT_LAYOUT" != "scrolling" && "$SELECTED_LAYOUT" == "scrolling" ]]; then
        printf 'Would save previous workspace axis as %s in %s\n' "$CURRENT_AXIS" "$AXIS_STATE_FILE"
        printf 'Would force workspace axis to vertical (slidevert) in %s\n' "$ANIMATIONS_CONF"
    fi

    if [[ "$CURRENT_LAYOUT" == "scrolling" && "$SELECTED_LAYOUT" != "scrolling" ]]; then
        if PREVIOUS_AXIS="$(read_previous_axis)"; then
            printf 'Would restore previous workspace axis to %s in %s\n' "$PREVIOUS_AXIS" "$ANIMATIONS_CONF"
        else
            printf 'No saved previous workspace axis to restore from %s\n' "$AXIS_STATE_FILE"
        fi
    fi

    exit 0
fi

if [[ "$CURRENT_LAYOUT" != "scrolling" && "$SELECTED_LAYOUT" == "scrolling" ]]; then
    write_previous_axis "$CURRENT_AXIS" || {
        notify "Failed to save previous workspace axis."
        exit 1
    }
fi

if [[ "$TARGET_APPLIED_LAYOUT" != "$CURRENT_APPLIED_LAYOUT" ]]; then
    update_layout "$TARGET_APPLIED_LAYOUT" || {
        notify "Failed to update layout."
        exit 1
    }
fi

if [[ "$SELECTED_LAYOUT" == "scrolling" ]]; then
    update_workspace_animation "slidevert" || {
        notify "Failed to force vertical workspace axis."
        exit 1
    }
fi

if [[ "$CURRENT_LAYOUT" == "scrolling" && "$SELECTED_LAYOUT" != "scrolling" ]]; then
    if PREVIOUS_AXIS="$(read_previous_axis)"; then
        TARGET_STYLE="$(axis_to_animation_style "$PREVIOUS_AXIS")"

        update_workspace_animation "$TARGET_STYLE" || {
            notify "Failed to restore previous workspace axis."
            exit 1
        }

        clear_previous_axis
    fi
fi

if ! reload_hyprland; then
    notify "Set to $(format_layout_display "$SELECTED_LAYOUT"), but reload failed."
    exit 1
fi

notify "Set to $(format_layout_display "$SELECTED_LAYOUT")"
