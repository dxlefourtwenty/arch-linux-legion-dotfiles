#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="´ä£  Keybindings
´ıÖ  Hyprland
¯£▓  Arch
¯Ü«  Neovim
¾░Æ▓  Lazyvim
¾▒åâ  Bash
¯ÖØ  Git"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -p "" \
    -theme-str '
        window { width: 260px; }
        entry { placeholder: "LearnÔÇĞ"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

case "$chosen" in
  *Keybindings)
    "$SCRIPT_DIR/menu-keybindings"
    ;;
  *Hyprland)
    "$SCRIPT_DIR/launch-web-app" https://wiki.hypr.land/Configuring
    ;;
  *Arch)
    "$SCRIPT_DIR/launch-web-app" https://wiki.archlinux.org/title/Main_page
    ;;
  *Neovim)
    "$SCRIPT_DIR/menu-neovim-bindings"
    ;;
  *Lazyvim)
    "$SCRIPT_DIR/launch-web-app" https://www.lazyvim.org/keymaps
    ;;
  *Bash)
    "$SCRIPT_DIR/launch-web-app" https://devhints.io/bash
    ;;
  *Git)
    "$SCRIPT_DIR/launch-web-app" https://git-scm.com/cheat-sheet
    ;;
esac
