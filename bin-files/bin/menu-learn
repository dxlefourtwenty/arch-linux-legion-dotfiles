#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-learn"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="  Keybindings
  Hyprland
  Arch
  Neovim
󰒲  Lazyvim
󱆃  Bash
  Git"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 260px; }
        entry { placeholder: "Learn…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

case "$chosen" in
  *Keybindings)
    "$SCRIPT_DIR/menu-keybindings"
    ;;
  *Hyprland)
    "$SCRIPT_DIR/launch-web-app" https://wiki.hypr.land/Configuring
    ;;
  *Arch)
    "$SCRIPT_DIR/launch-web-app" https://wiki.archlinux.org/title/Main_page
    ;;
  *Neovim)
    "$SCRIPT_DIR/menu-neovim-bindings"
    ;;
  *Lazyvim)
    "$SCRIPT_DIR/launch-web-app" https://www.lazyvim.org/keymaps
    ;;
  *Bash)
    "$SCRIPT_DIR/launch-web-app" https://devhints.io/bash
    ;;
  *Git)
    "$SCRIPT_DIR/launch-web-app" https://git-scm.com/cheat-sheet
    ;;
esac
