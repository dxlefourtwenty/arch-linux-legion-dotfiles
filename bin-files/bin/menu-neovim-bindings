#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
FILE="$SCRIPT_DIR/scans/neovim-bindings"
arrow=" "
MENU_ID="menu-neovim-bindings"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

[[ ! -f "$FILE" ]] && {
    notify-send "Neovim Bindings Menu" "File not found: $FILE"
    exit 1
}

# Get longest left column width (ignore empty/invalid lines)
max_width=$(awk -F'|' '
NF >= 2 {
    gsub(/^ +| +$/, "", $1)
    if ($1 != "")
        print length($1)
}
' "$FILE" | sort -nr | head -1)

# Format for rofi (ignore whitespace-only lines)
formatted=$(
awk -F'|' -v arrow="$arrow" -v width="$max_width" '
NF >= 2 {
    left=$1
    right=$2

    gsub(/^ +| +$/, "", left)
    gsub(/^ +| +$/, "", right)

    if (left != "" && right != "")
        printf "%-*s     %s %s\n", width, left, arrow, right
}
' "$FILE"
)

chosen=$(echo "$formatted" | rofi -dmenu -i \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 1000px; }
        entry { placeholder: "Neovim…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
            font: "JetBrainsMono Nerd Font 16";
        }
    ')

exit 0
