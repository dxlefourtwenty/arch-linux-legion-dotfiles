#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-power"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󱐋  Power Profile\n󰐥  Shutdown\n󰤁  Reboot\n  Lock"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 300px; }
        entry { placeholder: "Power…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

case "$chosen" in
  *Power\ Profile)
    "$SCRIPT_DIR/menu-power-profile"
    ;;
  *Shutdown)
    "$SCRIPT_DIR/system-shutdown"
    ;;
  *Reboot)
    "$SCRIPT_DIR/system-reboot"
    ;;
  *Lock)
    sleep 0.1
    ~/bin/launch-lock-screen
    ;;
esac
