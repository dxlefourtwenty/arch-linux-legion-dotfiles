#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="ůĪźč  Power Profile\nůįź•  Shutdown\nůį§Ā  Reboot\nÔĎĖ  Lock"

chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 300px; }
        entry { placeholder: "Power‚Ä¶"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

case "$chosen" in
  *Power\ Profile)
    "$SCRIPT_DIR/menu-power-profile"
    ;;
  *Shutdown)
    systemctl poweroff
    ;;
  *Reboot)
    systemctl reboot
    ;;
  *Lock)
    sleep 0.1
    ~/bin/launch-lock-screen
    ;;
esac
