#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-share"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󰈔  File
󰆏  Clipboard
󰅍  Clipboard History"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 340px; }
        entry { placeholder: "Share…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 10px;
        }
        element-text { 
            horizontal-align: 0.0; 
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"

case "$label" in
    "File") "$SCRIPT_DIR/launch-localsend-share-file" ;;
    "Clipboard") "$SCRIPT_DIR/launch-localsend-share-clipboard" ;;
    "Clipboard History") "$SCRIPT_DIR/menu-clipboard" --share ;;
    *) exit 0 ;;
esac
