#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-starship"
PID_FILE="/tmp/menu-rofi.pid"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
STARSHIP_CONFIG="${CONFIG_DIR}/starship.toml"
STARSHIP_STYLES_DIR="${CONFIG_DIR}/starship-styles"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
  exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

CURRENT_STARSHIP_STYLE="$(
  basename "$(readlink -f "${STARSHIP_CONFIG}" 2>/dev/null || true)" .toml
)"

mapfile -t styles < <(
  for toml_file in "${STARSHIP_STYLES_DIR}"/*.toml; do
    [[ -e "${toml_file}" ]] || continue
    printf '%s\n' "$(basename "${toml_file}" .toml)"
  done | sort -u
)

if [[ ${#styles[@]} -eq 0 ]]; then
  notify-send "Terminal Prompt" "No Starship styles found."
  exit 1
fi

refresh_terminal_prompts() {
  local zsh_pid=""
  local tty_name=""
  local tty_path=""

  while read -r zsh_pid tty_name; do
    [[ -n "${zsh_pid}" ]] || continue
    [[ -n "${tty_name}" ]] || continue

    tty_path="/dev/${tty_name}"
    printf '\033[H\033[2J\033[3J' > "${tty_path}" 2>/dev/null || true
    kill -USR1 "${zsh_pid}" >/dev/null 2>&1 || true
  done < <(
    ps -eo pid=,comm=,tty=,stat= |
      awk '$2 == "zsh" && $3 != "?" && $4 ~ /\+/ { print $1, $3 }'
  )
}

format_style_display() {
  local style_name="$1"
  printf '%s\n' "${style_name}" |
    sed -E 's/[-_]+/ /g; s/(^|[[:space:]])([[:alpha:]])/\1\U\2/g'
}

mapfile -t display_styles < <(
  for style_name in "${styles[@]}"; do
    pretty_style="$(format_style_display "${style_name}")"
    if [[ -n "${CURRENT_STARSHIP_STYLE}" ]] && [[ "${style_name}" == "${CURRENT_STARSHIP_STYLE}" ]]; then
      printf '<i>%s</i>\n' "${pretty_style}"
    else
      printf '%s\n' "${pretty_style}"
    fi
  done
)

chosen_index="$(
  printf '%s\n' "${display_styles[@]}" | rofi -dmenu -i -markup-rows -format i \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 300px; }
        entry { placeholder: "Terminal Prompt…"; }
        element {
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text {
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    '
)"

[[ -n "${chosen_index}" ]] || exit 0

chosen="${styles[chosen_index]}"

[[ -n "${chosen}" ]] || exit 0
[[ "${chosen}" != "${CURRENT_STARSHIP_STYLE}" ]] || exit 0

"$SCRIPT_DIR/starship-style" "${chosen}"

FORMATTED_NAME="$(format_style_display "${chosen}")"

sleep 0.5
~/bin/reload-terminal
refresh_terminal_prompts
notify-send -t 5000 "Terminal Prompt" "Updated to ${FORMATTED_NAME}"
