#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-style"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󰸌  Theme
󰛖  Font
  Background
󱢈  Live Gallery
  Terminal Prompt
󰍜  Waybar
󰃇  Border
󰹳  Gaps"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 310px; }
        entry { placeholder: "Style…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Theme")
    "$SCRIPT_DIR/menu-theme"
    ;;
  "Font")
    "$SCRIPT_DIR/menu-font"
    ;;
  "Background")
    "$SCRIPT_DIR/bg-set"
    ;;
  "Live Gallery")
    "$SCRIPT_DIR/bg-live"
    ;;
  "Terminal Prompt")
    "$SCRIPT_DIR/menu-starship"
    ;;
  "Waybar")
    "$SCRIPT_DIR/menu-waybar"
    ;;
  "Border")
    "$SCRIPT_DIR/menu-border"
    ;;
  "Gaps")
    "$SCRIPT_DIR/menu-gaps"
    ;;
esac
