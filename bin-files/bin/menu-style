#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-style"
PID_FILE="/tmp/menu-rofi.pid"
HYPR_ANIMATIONS_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/animations.conf"
HYPR_ANIMATIONS_ALT="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/animations"

get_animations_status() {
    local config_file=""
    local enabled_value=""

    if [[ -f "$HYPR_ANIMATIONS_CONF" ]]; then
        config_file="$HYPR_ANIMATIONS_CONF"
    elif [[ -f "$HYPR_ANIMATIONS_ALT" ]]; then
        config_file="$HYPR_ANIMATIONS_ALT"
    else
        printf 'Unknown\n'
        return 0
    fi

    enabled_value="$(
        awk '
            /^[[:space:]]*animations[[:space:]]*\{/ {
                in_section = 1
                next
            }

            in_section && /^[[:space:]]*\}/ {
                in_section = 0
            }

            in_section && match($0, /^[[:space:]]*enabled[[:space:]]*=[[:space:]]*([^[:space:],#]+)/, captures) {
                print captures[1]
                exit
            }
        ' "$config_file" 2>/dev/null || true
    )"

    case "${enabled_value,,}" in
        yes|1|true|on)
            printf 'ON\n'
            ;;
        no|0|false|off)
            printf 'OFF\n'
            ;;
        *)
            printf 'Unknown\n'
            ;;
    esac
}

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

animations_status="$(get_animations_status)"

options="󰸌  Theme
󰛖  Font
  Background
󱢈  Live Gallery
  Terminal Prompt
󰍜  Waybar
󰗘  Animations: ${animations_status}
󰃇  Border
󰹳  Gaps
  Layouts
󰖲  WS Axis"

chosen="$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 310px; }
        entry { placeholder: "Style…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 8px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ' || true)"

[[ -n "$chosen" ]] || exit 0

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Theme")
    "$SCRIPT_DIR/menu-theme"
    ;;
  "Font")
    "$SCRIPT_DIR/menu-font"
    ;;
  "Background")
    "$SCRIPT_DIR/bg-set"
    ;;
  "Live Gallery")
    "$SCRIPT_DIR/bg-live"
    ;;
  "Terminal Prompt")
    "$SCRIPT_DIR/menu-starship"
    ;;
  "Waybar")
    "$SCRIPT_DIR/menu-waybar"
    ;;
  "Animations:"*)
    "$SCRIPT_DIR/hypr-toggle-animations"
    ;;
  "Border")
    "$SCRIPT_DIR/menu-border"
    ;;
  "Gaps")
    "$SCRIPT_DIR/menu-gaps"
    ;;
  "Layouts")
    "$SCRIPT_DIR/menu-layout"
    ;;
  "WS Axis")
    "$SCRIPT_DIR/menu-workspace-axis"
    ;;
esac
