#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-tasks-add"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

THEME='
window { width: 900px; }
inputbar {
    children: [ entry ];
}
entry { placeholder: "Add Task…"; }
element {
    orientation: horizontal;
    children: [ element-text ];
    spacing: 0px;
    padding: 8px 10px;
}
element-text {
    horizontal-align: 0.0;
    padding-left: 0px;
}
'

dashboard_cmd="${SCRIPT_DIR}/dashboard"

# ---------------------------
# task text
# ---------------------------
task=$(rofi -dmenu -p "" \
    -pid "$PID_FILE" \
    -theme-str "$THEME" \
    -theme-str 'entry { placeholder: "Add Task…"; }')

[[ -z "$task" ]] && exit 0

# ---------------------------
# recurrence type
# ---------------------------
recurrence=$(printf "Daily\nWeekly\nDate" | \
    rofi -dmenu -p "" \
    -pid "$PID_FILE" \
    -theme-str "$THEME" \
    -theme-str 'window { width: 220px; } entry { placeholder: "Recurrence…"; }')

[[ -z "$recurrence" ]] && exit 0

case "$recurrence" in
    Daily)
        if ! output="$("$dashboard_cmd" add-task "$task" --daily 2>&1)"; then
            notify-send "Tasks" "$output"
            exit 1
        fi
        ;;

    Weekly)
        days=$(rofi -dmenu -p "" \
            -pid "$PID_FILE" \
            -theme-str "$THEME" \
            -theme-str 'window { width: 320px; } entry { placeholder: "Mon,Tue,…"; }')

        [[ -z "$days" ]] && exit 0
        if ! output="$("$dashboard_cmd" add-task "$task" --weekly "$days" 2>&1)"; then
            notify-send "Tasks" "$output"
            exit 1
        fi
        ;;

    Date)
        date=$(rofi -dmenu -p "" \
            -pid "$PID_FILE" \
            -theme-str "$THEME" \
            -theme-str 'window { width: 260px; } entry { placeholder: "MM-DD[-YYYY]"; }')

        [[ -z "$date" ]] && exit 0
        if ! output="$("$dashboard_cmd" add-task "$task" --date "$date" 2>&1)"; then
            notify-send "Tasks" "$output"
            exit 1
        fi
        ;;
esac

notify-send "Tasks" "${output:-Added: $task}"
