#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

THEME='
window { width: 1000; }
entry { placeholder: "Remove Task…"; }
element {
    orientation: horizontal;
    children: [ element-text ];
    spacing: 0px;
    padding: 8px 10px;
}
element-text {
    horizontal-align: 0.0;
    padding-left: 0px;
}
'

dashboard_cmd="${SCRIPT_DIR}/dashboard"

tasks="$("$dashboard_cmd" list-tasks)"

[[ -z "$tasks" ]] && {
    notify-send "Tasks" "No tasks found"
    exit 0
}

chosen=$(printf '%s\n' "$tasks" | rofi -dmenu -i \
    -p "" \
    -theme-str "$THEME" \
    -theme-str 'entry { placeholder: "Remove Task…"; }')

[[ -z "$chosen" ]] && exit 0

task_id=$(printf '%s\n' "$chosen" | awk -F':' '{print $1}')

if ! output="$("$dashboard_cmd" remove-task "$task_id" 2>&1)"; then
    notify-send "Tasks" "$output"
    exit 1
fi

notify-send "Tasks" "$output"
