#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-toggle"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="󰛨  Nightlight
  Top Bar
󰨝  Dashboard"

HOME_DIR="/home/dxle"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 325px; }
        entry { placeholder: "Tools…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Nightlight")
    "$SCRIPT_DIR/system-toggle-nightlight"
    ;;
  "Top Bar")
    "$SCRIPT_DIR/toggle-waybar"
    ;;
  "Dashboard")
    "$SCRIPT_DIR/toggle-dashboard"
    ;;
esac
