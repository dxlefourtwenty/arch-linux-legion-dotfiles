#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="  Top Bar
󰨝  Dashboard"

HOME_DIR="/home/dxle"

chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 325px; }
        entry { placeholder: "Tools…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Top Bar")
    "$SCRIPT_DIR/toggle-waybar"
    ;;
  "Dashboard")
    "$SCRIPT_DIR/toggle-dashboard"
    ;;
esac
