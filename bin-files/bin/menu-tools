#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
MENU_ID="menu-tools"
PID_FILE="/tmp/menu-rofi.pid"

if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
    exit 0
fi

options="´öî  Capture
´â¬  Clipboard
´öÄ  Share
¾░Şà  Emojis
¾░í»  Unicode
¾░©î  Color Converter
¾░©ë  Image Palette Converter
¯¡ğ  Tasks
¯½░  Files
¾▒¿Ñ  Toggle"

HOME_DIR="/home/dxle"

chosen=$(printf '%b\n' "$options" | "$SCRIPT_DIR/rofi-nerd-markup" | rofi -dmenu -i \
    -markup-rows \
    -pid "$PID_FILE" \
    -p "" \
    -theme-str '
        window { width: 400px; }
        entry { placeholder: "ToolsÔÇĞ"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Capture")
    "$SCRIPT_DIR/menu-capture"
    ;;
  "Clipboard")
    "$SCRIPT_DIR/menu-clipboard"
    ;;
  "Share")
    "$SCRIPT_DIR/menu-share"
    ;;
  "Emojis")
    "$SCRIPT_DIR/menu-emojis"
    ;;
  "Unicode")
    "$SCRIPT_DIR/menu-unicode"
    ;;
  "Color Converter")
    "$SCRIPT_DIR/menu-color-converter"
    ;;
  "Image Palette Converter")
    /home/dxle/.cargo/bin/lutgen-studio
    ;;
  "Tasks")
    "$SCRIPT_DIR/menu-tasks"
    ;;
  "Files") 
    "$SCRIPT_DIR/menu-files"
    ;;
  "Toggle") 
    "$SCRIPT_DIR/menu-toggle"
    ;;
esac
