#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

options="  Capture
󰴱  Color Picker"

HOME_DIR="/home/dxle"

chosen=$(echo -e "$options" | rofi -dmenu -i \
    -p "" \
    -theme-str '
        window { width: 325px; }
        entry { placeholder: "Trigger…"; }
        element { 
            orientation: horizontal;
            children: [ element-text ];
            spacing: 0px;
            padding: 8px 2px;
        }
        element-text { 
            horizontal-align: 0.0;
            padding-left: 0px;
        }
    ')

label="${chosen#*  }"   # remove up to the double-space after the icon

case "$label" in
  "Capture")
    "$SCRIPT_DIR/launch-screenshot-clipboard"
    ;;
  "Color Picker")
    "$SCRIPT_DIR/launch-colorpicker"
    ;;
esac
