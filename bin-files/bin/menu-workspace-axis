#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROFI_BIN="/usr/bin/rofi"
NOTIFY_BIN="/home/dxle/bin/notify-send"
AWK_BIN="/usr/bin/awk"
MKTEMP_BIN="/usr/bin/mktemp"
MV_BIN="/usr/bin/mv"
HYPRCTL_BIN="/usr/bin/hyprctl"
HYPR_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/animations.conf"
MENU_ID="menu-workspace-axis"
PID_FILE="/tmp/menu-rofi.pid"
DRY_RUN=0
SELECTED_AXIS=""
AXES=("horizontal" "vertical")

usage() {
    printf 'Usage: %s [--axis horizontal|vertical] [--config PATH] [--dry-run]\n' "$(basename "$0")"
}

notify() {
    "$NOTIFY_BIN" -t 4000 "Workspace Axis" "$1" >/dev/null 2>&1 || true
}

format_axis_display() {
    case "$1" in
        horizontal)
            printf 'Horizontal\n'
            ;;
        vertical)
            printf 'Vertical\n'
            ;;
        *)
            printf '%s\n' "$1"
            ;;
    esac
}

is_valid_axis() {
    local candidate="$1"
    local axis=""

    for axis in "${AXES[@]}"; do
        [[ "$candidate" == "$axis" ]] && return 0
    done

    return 1
}

axis_to_animation_style() {
    case "$1" in
        horizontal)
            printf 'slide\n'
            ;;
        vertical)
            printf 'slidevert\n'
            ;;
        *)
            return 1
            ;;
    esac
}

get_current_axis() {
    "$AWK_BIN" '
        {
            line = $0
            sub(/[[:space:]]*#.*/, "", line)
        }

        line ~ /^[[:space:]]*animation[[:space:]]*=[[:space:]]*workspaces([[:space:]]*,.*)?$/ {
            count = split(line, parts, ",")
            style = (count >= 5) ? parts[5] : ""

            if (style ~ /slidevert/) {
                print "vertical"
                exit
            }

            if (style ~ /slide/) {
                print "horizontal"
                exit
            }

            exit
        }
    ' "$HYPR_CONF"
}

choose_axis() {
    local current_axis="$1"
    local display_axes=()
    local axis=""
    local pretty=""
    local chosen_index=""

    for axis in "${AXES[@]}"; do
        pretty="$(format_axis_display "$axis")"

        if [[ "$axis" == "$current_axis" ]]; then
            pretty="<i>$pretty</i>"
        fi

        display_axes+=("$pretty")
    done

    chosen_index="$(
        printf '%s\n' "${display_axes[@]}" | "$ROFI_BIN" -dmenu -i -markup-rows -format i \
            -pid "$PID_FILE" \
            -p "" \
            -theme-str '
                window { width: 260px; }
                entry { placeholder: "WS Axis…"; }
                element {
                    orientation: horizontal;
                    children: [ element-text ];
                    spacing: 0px;
                    padding: 8px 8px;
                }
                element-text {
                    horizontal-align: 0.0;
                    padding-left: 0px;
                    margin: 0 2px;
                }
            '
    )" || return 1

    [[ "$chosen_index" =~ ^[0-9]+$ ]] || return 1
    [[ "$chosen_index" -lt "${#AXES[@]}" ]] || return 1

    printf '%s\n' "${AXES[chosen_index]}"
}

update_workspace_animation() {
    local target_style="$1"
    local tmp_file=""

    tmp_file="$("$MKTEMP_BIN")"

    "$AWK_BIN" -v target_style="$target_style" '
        {
            raw_line = $0
            test_line = raw_line
            sub(/[[:space:]]*#.*/, "", test_line)
        }

        !updated && test_line ~ /^[[:space:]]*animation[[:space:]]*=[[:space:]]*workspaces([[:space:]]*,.*)?$/ {
            comment = ""
            body = raw_line

            if (match(raw_line, /[[:space:]]+#.*/)) {
                comment = substr(raw_line, RSTART)
                body = substr(raw_line, 1, RSTART - 1)
            }

            count = split(body, parts, ",")

            if (count >= 5) {
                style = parts[5]

                if (style ~ /slidevert/) {
                    sub(/slidevert/, target_style, style)
                } else if (style ~ /slide/) {
                    sub(/slide/, target_style, style)
                } else {
                    style = style " " target_style
                }

                parts[5] = style
                body = parts[1]

                for (i = 2; i <= count; i++) {
                    body = body "," parts[i]
                }
            } else {
                body = body ", " target_style
            }

            print body comment
            updated = 1
            next
        }

        { print raw_line }

        END {
            if (!updated) {
                exit 1
            }
        }
    ' "$HYPR_CONF" > "$tmp_file"

    "$MV_BIN" "$tmp_file" "$HYPR_CONF"
}

reload_hyprland() {
    [[ -x "$HYPRCTL_BIN" ]] || return 0
    "$HYPRCTL_BIN" reload >/dev/null 2>&1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --axis)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            SELECTED_AXIS="$2"
            shift 2
            ;;
        --config)
            [[ $# -ge 2 ]] || {
                usage
                exit 1
            }
            HYPR_CONF="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 1
            ;;
    esac
done

[[ -f "$HYPR_CONF" ]] || {
    notify "Config not found: $HYPR_CONF"
    exit 1
}

CURRENT_AXIS="$(get_current_axis)"
[[ -n "$CURRENT_AXIS" ]] || {
    notify "Could not detect current workspace axis."
    exit 1
}

if [[ -z "$SELECTED_AXIS" ]]; then
    if "$SCRIPT_DIR/rofi-toggle-pidfile" begin "$MENU_ID"; then
        exit 0
    fi

    trap '"$SCRIPT_DIR/rofi-toggle-pidfile" clear "$MENU_ID"' EXIT

    SELECTED_AXIS="$(choose_axis "$CURRENT_AXIS" || true)"
    [[ -n "$SELECTED_AXIS" ]] || exit 0
fi

is_valid_axis "$SELECTED_AXIS" || {
    notify "Invalid axis: $SELECTED_AXIS"
    exit 1
}

[[ "$SELECTED_AXIS" != "$CURRENT_AXIS" ]] || exit 0

TARGET_STYLE="$(axis_to_animation_style "$SELECTED_AXIS")"

if [[ "$DRY_RUN" -eq 1 ]]; then
    printf 'Would set workspace axis to %s (%s) in %s\n' "$SELECTED_AXIS" "$TARGET_STYLE" "$HYPR_CONF"
    exit 0
fi

update_workspace_animation "$TARGET_STYLE" || {
    notify "Failed to update workspace animation."
    exit 1
}

if ! reload_hyprland; then
    notify "Set to $(format_axis_display "$SELECTED_AXIS"), but reload failed."
    exit 1
fi

notify "Set to $(format_axis_display "$SELECTED_AXIS")."
