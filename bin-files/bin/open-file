#!/usr/bin/env bash

IMAGE_VIEWER="imv"
VIDEO_VIEWER="celluloid"

[ -z "$1" ] && exit 1

FILE="$1"
MIME=$(xdg-mime query filetype "$FILE")

if [[ $MIME == image/* ]]; then
    nohup "$IMAGE_VIEWER" "$@" >/dev/null 2>&1 &
elif [[ $MIME == video/* ]]; then
    nohup "$VIDEO_VIEWER" "$@" >/dev/null 2>&1 &
else
    nohup xdg-open "$@" >/dev/null 2>&1 &
fi


