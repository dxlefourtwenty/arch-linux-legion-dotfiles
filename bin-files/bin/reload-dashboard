#!/usr/bin/env bash
set -euo pipefail

TOPDASH_BIN="${TOPDASH_BIN:-/home/dxle/builds/dashboard/build/topdash}"
PKILL_BIN="/usr/bin/pkill"
NOHUP_BIN="/usr/bin/nohup"
PGREP_BIN="/usr/bin/pgrep"
KILL_BIN="/usr/bin/kill"
SLEEP_BIN="/usr/bin/sleep"
SETSID_BIN="/usr/bin/setsid"
NOTIFY_SEND_BIN="/usr/bin/notify-send"

usage() {
    printf 'Usage: reload-dashboard [--dry-run]\n'
}

notify_error() {
    if [[ -x "$NOTIFY_SEND_BIN" ]]; then
        "$NOTIFY_SEND_BIN" -t 4000 "Dashboard" "$1" >/dev/null 2>&1 || true
    fi
}

validate_inputs() {
    if [[ -z "$TOPDASH_BIN" ]]; then
        notify_error "topdash binary path is empty."
        exit 1
    fi

    if [[ ! -x "$TOPDASH_BIN" ]]; then
        notify_error "topdash binary not found: $TOPDASH_BIN"
        exit 1
    fi
}

collect_topdash_pids() {
    {
        "$PGREP_BIN" -x topdash 2>/dev/null || true
        "$PGREP_BIN" -f -- "$TOPDASH_BIN" 2>/dev/null || true
    } | awk 'NF { print $1 }' | awk '!seen[$1]++'
}

stop_topdash() {
    local pids=()
    mapfile -t pids < <(collect_topdash_pids)

    [[ ${#pids[@]} -gt 0 ]] || return 0

    "$PKILL_BIN" -x topdash >/dev/null 2>&1 || true
    "$PKILL_BIN" -f -- "$TOPDASH_BIN" >/dev/null 2>&1 || true

    for _ in {1..20}; do
        mapfile -t pids < <(collect_topdash_pids)
        [[ ${#pids[@]} -eq 0 ]] && return 0
        "$SLEEP_BIN" 0.05
    done

    mapfile -t pids < <(collect_topdash_pids)
    if [[ ${#pids[@]} -gt 0 ]]; then
        "$KILL_BIN" -9 "${pids[@]}" >/dev/null 2>&1 || true
    fi
}

start_topdash() {
    if [[ -x "$SETSID_BIN" ]]; then
        "$SETSID_BIN" -f "$TOPDASH_BIN" >/dev/null 2>&1 || true
    else
        "$NOHUP_BIN" "$TOPDASH_BIN" >/dev/null 2>&1 &
    fi
}

wait_for_topdash() {
    local pids=()

    for _ in {1..40}; do
        mapfile -t pids < <(collect_topdash_pids)
        if [[ ${#pids[@]} -gt 0 ]]; then
            return 0
        fi
        "$SLEEP_BIN" 0.05
    done

    notify_error "Failed to start topdash."
    exit 1
}

main() {
    local dry_run=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=1
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                usage
                exit 1
                ;;
        esac
    done

    validate_inputs

    if [[ "$dry_run" -eq 1 ]]; then
        return 0
    fi

    stop_topdash
    start_topdash
    wait_for_topdash
}

main "$@"
