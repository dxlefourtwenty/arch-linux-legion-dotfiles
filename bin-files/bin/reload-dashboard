#!/usr/bin/env bash
set -euo pipefail

TOPDASH_BIN="${TOPDASH_BIN:-/home/dxle/builds/dashboard/build/topdash}"
PGREP_BIN="/usr/bin/pgrep"
KILL_BIN="/usr/bin/kill"
READLINK_BIN="/usr/bin/readlink"
NOTIFY_SEND_BIN="/home/dxle/bin/notify-send"
RELOAD_SIGNAL="${RELOAD_SIGNAL:-WINCH}"

usage() {
    printf 'Usage: reload-dashboard [--dry-run]\n'
}

notify_error() {
    if [[ -x "$NOTIFY_SEND_BIN" ]]; then
        "$NOTIFY_SEND_BIN" -t 4000 "Dashboard" "$1" >/dev/null 2>&1 || true
    fi
}

validate_inputs() {
    if [[ -z "$TOPDASH_BIN" ]]; then
        notify_error "topdash binary path is empty."
        exit 1
    fi

    if [[ ! -x "$TOPDASH_BIN" ]]; then
        notify_error "topdash binary not found: $TOPDASH_BIN"
        exit 1
    fi

    case "$RELOAD_SIGNAL" in
        WINCH|SIGWINCH)
            ;;
        *)
            notify_error "Unsupported reload signal: $RELOAD_SIGNAL"
            exit 1
            ;;
    esac
}

topdash_real_path() {
    "$READLINK_BIN" -f -- "$TOPDASH_BIN"
}

collect_topdash_pids() {
    local expected_exe=""
    local exe=""
    local pid=""

    expected_exe="$(topdash_real_path)"

    while IFS= read -r pid; do
        [[ -n "$pid" ]] || continue

        exe="$("$READLINK_BIN" -f "/proc/$pid/exe" 2>/dev/null || true)"
        if [[ "$exe" == "$expected_exe" ]]; then
            printf '%s\n' "$pid"
        fi
    done < <("$PGREP_BIN" -x topdash 2>/dev/null || true)
}

reload_topdash() {
    local pids=()
    mapfile -t pids < <(collect_topdash_pids)

    if [[ ${#pids[@]} -eq 0 ]]; then
        notify_error "topdash is not running."
        exit 1
    fi

    "$KILL_BIN" "-$RELOAD_SIGNAL" "${pids[@]}"
}

main() {
    local dry_run=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=1
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                usage
                exit 1
                ;;
        esac
    done

    validate_inputs

    if [[ "$dry_run" -eq 1 ]]; then
        return 0
    fi

    reload_topdash
}

main "$@"
