#!/usr/bin/env bash

set -euo pipefail

APP_CLASS=spotify

find_spotify_address() {
    hyprctl clients -j | jq -r '
        map(select((.class | ascii_downcase) == "'"$APP_CLASS"'"))[0].address // empty
    '
}

spicetify update

spotify_address="$(find_spotify_address)"

if [ -z "$spotify_address" ]; then
    exit 0
fi

# hyprctl dispatch focuswindow "address:$spotify_address" >/dev/null
# sleep 0.05
hyprctl dispatch sendshortcut "CTRL SHIFT, r, class:^(spotify)$" >/dev/null
