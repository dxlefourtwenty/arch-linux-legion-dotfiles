#!/usr/bin/env bash
set -euo pipefail

spotify_window_exists() {
    hyprctl clients -j | jq -e '
        any(.[]; (.class | ascii_downcase) == "spotify")
    ' >/dev/null
}

spotify_process_exists() {
    pgrep -x spotify >/dev/null
}

wait_for_spotify_shutdown() {
    for _ in {1..100}; do
        if ! spotify_process_exists && ! spotify_window_exists; then
            return 0
        fi
        sleep 0.1
    done

    echo "spicetify-set: Spotify did not shut down cleanly" >&2
    exit 1
}

[ $# -lt 1 ] && {
    echo "Usage: spicetify-set <mode>"
    exit 1
}

MODE="$1"
THEME=""
FLAVOR=""
relaunch_spotify=false

if spotify_window_exists; then
    relaunch_spotify=true
    pkill -x spotify || true
    wait_for_spotify_shutdown
fi

case "$MODE" in
    aetheria)
        THEME="StarryNight"
        FLAVOR="Galaxy"
        ;;
    akane)
        THEME="StarryNight"
        FLAVOR="Sunrise"
        ;;
    catppuccin)
        THEME="text"
        FLAVOR="CatppuccinMocha"
        ;;
    dracula)
        THEME="Sleek"
        FLAVOR="Dracula"
        ;;
    dreamwave)
        THEME="StarryNight"
        FLAVOR="Galaxy"
        ;;
    gruvbox)
        THEME="text"
        FLAVOR="Gruvbox"
        ;;
    matte-black)
        THEME="Sleek"
        FLAVOR="UltraBlack"
        ;;
    nord)
        THEME="text"
        FLAVOR="Nord"
        ;;
    rose-pine)
        THEME="text"
        FLAVOR="RosePine"
        ;;
    solarized)
        THEME="text"
        FLAVOR="Solarized"
        ;;
    tokyo-night)
        THEME="text"
        FLAVOR="TokyoNight"
        ;;
    everforest)
        THEME="text"
        FLAVOR="EverforestDarkMedium"
        ;;
    firesky)
        THEME="StarryNight"
        FLAVOR="Orange"
        ;;
    fuschia)
        THEME="StarryNight"
        FLAVOR="Cotton-candy"
        ;;
    osaka-jade)
        THEME="Ziro"
        FLAVOR="green-dark"
        ;;
    *)
        echo "Unknown mode: $MODE"
        exit 1
        ;;
esac

spicetify config current_theme "${THEME}"
if [ -n "${FLAVOR}" ]; then
  spicetify config color_scheme "${FLAVOR}"
fi

spicetify -n apply

if [ "$relaunch_spotify" = true ]; then
    launch-spotify
fi
