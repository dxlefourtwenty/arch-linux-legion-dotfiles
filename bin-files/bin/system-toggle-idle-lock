#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
LAUNCH_SCRIPT="${SCRIPT_DIR}/launch-hypridle"
NOTIFY_SEND_BIN="${NOTIFY_SEND_BIN:-/usr/bin/notify-send}"
IDLE_LOCK_NOTIFY_APP_NAME="${IDLE_LOCK_NOTIFY_APP_NAME:-system-toggle-idle-lock}"
IDLE_LOCK_NOTIFY_STACK_TAG="${IDLE_LOCK_NOTIFY_STACK_TAG:-system-toggle-idle-lock}"

notify() {
    "$NOTIFY_SEND_BIN" \
        -a "$IDLE_LOCK_NOTIFY_APP_NAME" \
        -h "string:x-dunst-stack-tag:$IDLE_LOCK_NOTIFY_STACK_TAG" \
        -t 2500 \
        "System" \
        "$1"
}

if pgrep -x hypridle >/dev/null 2>&1; then
    pkill -x hypridle
    notify "Idle lock: <b>OFF</b>"
    exit 0
fi

if [ -x "${LAUNCH_SCRIPT}" ]; then
    "${LAUNCH_SCRIPT}"
else
    hypridle >/dev/null 2>&1 &
    disown 2>/dev/null || true
fi

notify "Idle lock: <b>ON</b>"
