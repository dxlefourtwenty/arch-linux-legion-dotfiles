#!/usr/bin/env bash

# 1. Lock screen (your script)
~/bin/launch0-lock-screen &

# Give lock time to appear
sleep 0.5

# 2. Turn off displays
hyprctl dispatch dpms off

# Let system settle (avoid instant wake)
sleep 2

# 3. Wait for real input → wake displays
libinput debug-events | while read -r line; do
    if echo "$line" | grep -qE "KEYBOARD_KEY|POINTER_MOTION|POINTER_BUTTON"; then
        hyprctl dispatch dpms on
        pkill -f "libinput debug-events"
        break
    fi
done
