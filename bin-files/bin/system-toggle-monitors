#!/usr/bin/env bash

# 1. Lock screen
~/bin/launch-lock-screen &

sleep 0.5

# 2. Turn off displays
hyprctl dispatch dpms off

# 3. Wait until ANY input happens (Hyprland socket)
while true; do
    if hyprctl -j devices | grep -q '"active":true'; then
        hyprctl dispatch dpms on
        break
    fi
    sleep 0.2
done
