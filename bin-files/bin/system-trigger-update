#!/usr/bin/env bash
set -euo pipefail

PKG_DIR="$HOME/dotfiles/.packages"
HYPRIDLE_LAUNCHER="$HOME/bin/launch-hypridle"

stop_hypridle() {
  pkill -x hypridle >/dev/null 2>&1 || true

  for _ in {1..50}; do
    if ! pgrep -x hypridle >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done

  pkill -KILL -x hypridle >/dev/null 2>&1 || true

  for _ in {1..20}; do
    if ! pgrep -x hypridle >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done

  echo "Failed to stop hypridle before update." >&2
  return 1
}

restart_hypridle() {
  if [[ -x "$HYPRIDLE_LAUNCHER" ]]; then
    "$HYPRIDLE_LAUNCHER"
  fi
}

trap restart_hypridle EXIT

stop_hypridle

echo "==> Updating system..."
sudo pacman -Syu

echo "==> Updating AUR..."
if command -v yay &> /dev/null; then
  yay -Syu
fi

echo "==> Exporting package lists..."

mkdir -p "$PKG_DIR"

pacman -Qqe | sort > "$PKG_DIR/pkglist.txt"
pacman -Qqm | sort > "$PKG_DIR/aurlist.txt"

echo "==> Done. Package lists updated."
