#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/local/sbin:/usr/local/bin:/usr/bin:/bin"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
THEME_DIR="$HOME/.config/themes"
CURRENT_LINK="$THEME_DIR/current"
NOTIFY_SEND_BIN="/home/dxle/bin/notify-send"
HYPRLOCK_RANDOM_WALLPAPER_SCRIPT="$HOME/.config/hyprlock/scripts/random-wallpaper.sh"
HYPRLOCK_RANDOM_WALLPAPER_LINK="/tmp/hyprlock-random-wallpaper"

[ -z "$1" ] && {
    echo "Usage: theme <theme-name>"
    exit 1
}

NEW_THEME="$THEME_DIR/$1"

[ ! -d "$NEW_THEME" ] && {
    echo "Theme '$1' does not exist in $THEME_DIR"
    exit 1
}

# Stop apps that will be restarted against the new theme, if they are running.
# pgrep -x spotify >/dev/null && pkill -x spotify || true

"$SCRIPT_DIR/reload-nemo" || true
"$SCRIPT_DIR/reload-pavucontrol" || true

# Atomic theme switch (IMPORTANT)
ln -sfn "$NEW_THEME" "$CURRENT_LINK"
"$HYPRLOCK_RANDOM_WALLPAPER_SCRIPT" --dir "$CURRENT_LINK/wallpapers" --link "$HYPRLOCK_RANDOM_WALLPAPER_LINK" >/dev/null 2>&1 || true

"$SCRIPT_DIR/bg-refresh-current" >/dev/null 2>&1 &
"$SCRIPT_DIR/cursor-set" >/dev/null 2>&1 &
"$SCRIPT_DIR/reload-wardnc" || true
"$SCRIPT_DIR/reload-chromack" || true
"$SCRIPT_DIR/reload-dashboard" || true
"$SCRIPT_DIR/reload-dock" || true
"$SCRIPT_DIR/reload-browsers" || true

"$SCRIPT_DIR/reload-borders" || true
"$SCRIPT_DIR/reload-terminal" || true
"$SCRIPT_DIR/reload-waybar" || true
"$SCRIPT_DIR/reload-btop" || true
"$SCRIPT_DIR/reload-cava" || true
"$SCRIPT_DIR/reload-mako" || true
"$SCRIPT_DIR/reload-ward" || true

"$SCRIPT_DIR/reload-discord" >/dev/null 2>&1 &
"$SCRIPT_DIR/spicetify-set" --live "$1" >/dev/null 2>&1 &

"$SCRIPT_DIR/reload-celluloid" || true
"$SCRIPT_DIR/reload-swayosd" || true

killall xdg-desktop-portal >/dev/null 2>&1 || true
killall xdg-desktop-portal-gtk >/dev/null 2>&1 || true
killall xdg-desktop-portal-hyprland >/dev/null 2>&1 || true

if [[ "${THEME_SUPPRESS_NOTIFY:-0}" != "1" ]]; then
    # Pretty notification
    FORMATTED_NAME=$(echo "$1" | tr '-' ' ' | sed -E 's/\b(.)/\U\1/g')

    (
        # Start mako if needed, then wait until it is alive.
        pgrep -x mako >/dev/null || "$SCRIPT_DIR/launch-mako" || true

        for i in {1..20}; do
            pgrep -x mako >/dev/null && break
            sleep 0.1
        done

        if [[ -x "$NOTIFY_SEND_BIN" ]]; then
            "$NOTIFY_SEND_BIN" -t 5000 "Theme" "Updated to $FORMATTED_NAME." >/dev/null 2>&1 || true
        fi
    ) >/dev/null 2>&1 &
fi
