#!/usr/bin/env bash

set -euo pipefail

# --- defaults ---
COLORS=32
OUTPUT="palette.png"

# --- parse flags ---
while getopts ":o:c:" opt; do
  case $opt in
    o) OUTPUT="$OPTARG" ;;
    c) COLORS="$OPTARG" ;;
    *)
      echo "Usage: img-palette [-o output.png] [-c colors] <input_image>"
      exit 1
      ;;
  esac
done

shift $((OPTIND - 1))

# --- required arg ---
if [[ $# -lt 1 ]]; then
  echo "Usage: img-palette [-o output.png] [-c colors] <input_image>"
  exit 1
fi

INPUT="$1"

TMP_DIR="$(mktemp -d)"
TMP_PALETTE="$TMP_DIR/raw_palette.png"

trap 'rm -rf "$TMP_DIR"' EXIT

echo "[1/3] Resizing + reducing colors..."
magick "$INPUT" \
  -resize 256x256\! \
  -colors "$COLORS" \
  "$TMP_PALETTE"

echo "[2/3] Extracting unique colors..."
magick "$TMP_PALETTE" \
  -unique-colors \
  "$TMP_PALETTE"

echo "[3/3] Formatting palette (1-row)..."
magick "$TMP_PALETTE" \
  -resize x1\! \
  "$OUTPUT"

echo "Done -> $OUTPUT"
