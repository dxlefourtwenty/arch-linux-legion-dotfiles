#!/usr/bin/env bash
set -euo pipefail

PGREP_BIN="${PGREP_BIN:-/usr/bin/pgrep}"
PKILL_BIN="${PKILL_BIN:-/usr/bin/pkill}"
NOHUP_BIN="${NOHUP_BIN:-/usr/bin/nohup}"
HYPR_DOCK_BIN="${HYPR_DOCK_BIN:-hypr-dock}"

DRY_RUN=0
PROCESS_NAME="hypr-dock"
SIGNAL="SIGUSR2"

usage() {
    cat <<'EOF'
Usage: hypr-toggle-dock [--dry-run]

Toggle the hypr-dock slide state via SIGUSR2.
Start hypr-dock if it is not already running.
EOF
}

validate_command() {
    local command_path="$1"

    [[ -x "$command_path" ]]
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                DRY_RUN=1
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                usage
                exit 1
                ;;
        esac
    done
}

main() {
    parse_args "$@"

    validate_command "$PGREP_BIN" || exit 1
    validate_command "$PKILL_BIN" || exit 1
    validate_command "$NOHUP_BIN" || exit 1

    if [[ "$DRY_RUN" -eq 1 ]]; then
        if "$PGREP_BIN" -u "$USER" -x "$PROCESS_NAME" >/dev/null; then
            printf '%s -%s -u %s -x %s\n' "$PKILL_BIN" "$SIGNAL" "$USER" "$PROCESS_NAME"
        else
            printf '%s %s\n' "$NOHUP_BIN" "$HYPR_DOCK_BIN"
        fi
        exit 0
    fi

    if ! "$PGREP_BIN" -u "$USER" -x "$PROCESS_NAME" >/dev/null; then
        "$NOHUP_BIN" "$HYPR_DOCK_BIN" >/dev/null 2>&1 &
        exit 0
    fi

    "$PKILL_BIN" "-$SIGNAL" -u "$USER" -x "$PROCESS_NAME"
}

main "$@"
