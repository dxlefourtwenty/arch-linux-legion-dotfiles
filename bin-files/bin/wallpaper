#!/usr/bin/env bash

THEME_DIR="$HOME/.config/themes/current"
WALL_DIR="$THEME_DIR/wallpapers"
TARGET="$THEME_DIR/wallpaper.png"

# ---- LIST MODE ----
if [[ "$1" == "--list" ]]; then
    [[ ! -d "$WALL_DIR" ]] && { echo "No wallpapers directory found."; exit 1; }

    for file in "$WALL_DIR"/*; do
        filename=$(basename "$file")
        echo "$filename" | sed -E 's/^[0-9]+-//'
    done | sort
    exit 0
fi

# ---- SET MODE ----
if [[ -z "$1" ]]; then
    echo "Usage:"
    echo "  wallpaper <name>"
    echo "  wallpaper --list"
    exit 1
fi

match=$(find "$WALL_DIR" -type f | while read -r f; do
    base=$(basename "$f")
    clean=$(echo "$base" | sed -E 's/^[0-9]+-//')
    [[ "$clean" == "$1" ]] && echo "$f"
done)

[[ -z "$match" ]] && { echo "Wallpaper not found: $1"; exit 1; }

cp -f "$match" "$TARGET"

swww img "$TARGET" --transition-type fade --transition-duration 1

echo "Wallpaper set to $1"
