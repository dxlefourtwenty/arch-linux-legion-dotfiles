@import url("colors.css");

/* ===============================
   Main Window
================================= */
.nemo-window {
    background: @base;
    color: @text;
}

.nemo-window:backdrop,
.nemo-window.background:backdrop,
window.nemo-window.background:backdrop {
    background: @mantle !important;
    background-color: @mantle !important;
    background-image: none !important;
    box-shadow: none !important;
    color: @text;
}

window.nemo-window.background > grid,
window.nemo-window.background:backdrop > grid {
    background: @mantle !important;
    background-color: @mantle !important;
    background-image: none !important;
    box-shadow: none !important;
}

.nemo-window > grid,
.nemo-window > grid:backdrop,
.nemo-window:backdrop > grid,
.nemo-window > .vertical,
.nemo-window > .vertical:backdrop,
.nemo-window:backdrop > .vertical {
    background: @mantle !important;
    background-color: @mantle !important;
    background-image: none !important;
    box-shadow: none !important;
    color: @text;
}

/* Header Bar */
.nemo-window headerbar {
    background: @mantle;
    color: @text;
    border-bottom: 1px solid @surface1;
}

.nemo-window headerbar button:hover {
    background: @surface0;
}

/* Toolbar */
.nemo-window toolbar {
    background: @mantle;
    border-bottom: 1px solid @surface1;
}

/* Sidebar */
.nemo-window .sidebar {
    background: @crust;
    color: @subtext;
}

.nemo-window paned,
.nemo-window paned:backdrop,
.nemo-window paned.horizontal,
.nemo-window paned.horizontal:backdrop {
    background: @base !important;
    background-color: @base !important;
    background-image: none !important;
    box-shadow: none !important;
    color: @text;
}

.nemo-window paned > separator,
.nemo-window paned > separator:backdrop,
.nemo-window paned.horizontal > separator,
.nemo-window paned.horizontal > separator:backdrop {
    background: @surface1 !important;
    background-color: @surface1 !important;
    background-image: none !important;
    box-shadow: none !important;
    min-width: 1px;
    min-height: 1px;
}

.nemo-window .sidebar row:hover {
    background: @surface0;
}

.nemo-window .sidebar row:selected {
    background: @accent;
    color: @crust;
}

/* File View */
.nemo-window .view {
    background: @base;
    color: @text;
}

.nemo-window .view:selected {
    background: @accent;
    color: @crust;
}

/* List Headers */
.nemo-window treeview header button {
    background: @mantle;
    color: @subtext;
}

/* Pathbar */
.nemo-window .path-bar button {
    background: @surface0;
    color: @text;
}

.nemo-window .path-bar button:checked {
    background: @accent;
    color: @crust;
}

/* Status Bar */
.nemo-window statusbar {
    background: @mantle;
    color: @subtext;
    border-top: 1px solid @surface1;
}

/* Top chrome wrapper around Nemo's menubar/toolbar area */
.nemo-window > grid > eventbox,
.nemo-window > grid > eventbox:backdrop,
.nemo-window:backdrop > grid > eventbox,
.nemo-window > grid > box,
.nemo-window > grid > box:backdrop,
.nemo-window:backdrop > grid > box {
    background: @mantle !important;
    background-color: @mantle !important;
    background-image: none !important;
    box-shadow: none !important;
    color: @text;
}

.nemo-window > grid > separator,
.nemo-window > grid > separator:backdrop,
.nemo-window:backdrop > grid > separator {
    background: @surface1 !important;
    background-color: @surface1 !important;
    background-image: none !important;
}

/* Menus */
.nemo-window menubar,
.nemo-window menubar:backdrop,
.nemo-window:backdrop menubar,
.nemo-window .menubar,
.nemo-window .menubar:backdrop,
.nemo-window:backdrop .menubar,
window.nemo-window.background > grid > menubar,
window.nemo-window.background > grid > menubar:backdrop,
window.nemo-window.background:backdrop > grid > menubar,
window.nemo-window.background:backdrop > grid > menubar:backdrop {
    background: @mantle !important;
    background-color: @mantle !important;
    background-image: none !important;
    border-image: none !important;
    color: @text;
    border-bottom: 1px solid @surface1;
    box-shadow: none !important;
}

.nemo-window menubar > menuitem,
.nemo-window menubar > menuitem:backdrop,
.nemo-window:backdrop menubar > menuitem,
.nemo-window .menubar > menuitem,
.nemo-window .menubar > menuitem:backdrop,
.nemo-window:backdrop .menubar > menuitem,
window.nemo-window.background > grid > menubar > menuitem,
window.nemo-window.background > grid > menubar > menuitem:backdrop,
window.nemo-window.background:backdrop > grid > menubar > menuitem,
window.nemo-window.background:backdrop > grid > menubar > menuitem:backdrop {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border-image: none !important;
    color: @text;
    box-shadow: none !important;
}

.nemo-window menubar > menuitem:hover,
.nemo-window menubar > menuitem:active,
.nemo-window menubar > menuitem:selected,
.nemo-window .menubar > menuitem:hover,
.nemo-window .menubar > menuitem:active,
.nemo-window .menubar > menuitem:selected,
window.nemo-window.background > grid > menubar > menuitem:hover,
window.nemo-window.background > grid > menubar > menuitem:active,
window.nemo-window.background > grid > menubar > menuitem:selected,
window.nemo-window.background > grid > menubar > menuitem:backdrop:hover,
window.nemo-window.background > grid > menubar > menuitem:backdrop:active,
window.nemo-window.background > grid > menubar > menuitem:backdrop:selected {
    background: @surface0 !important;
    background-color: @surface0 !important;
    background-image: none !important;
    color: @text;
}

.nemo-window menubar > menuitem:backdrop:hover,
.nemo-window menubar > menuitem:backdrop:active,
.nemo-window menubar > menuitem:backdrop:selected,
.nemo-window:backdrop menubar > menuitem:hover,
.nemo-window:backdrop menubar > menuitem:active,
.nemo-window:backdrop menubar > menuitem:selected,
.nemo-window .menubar > menuitem:backdrop:hover,
.nemo-window .menubar > menuitem:backdrop:active,
.nemo-window .menubar > menuitem:backdrop:selected,
.nemo-window:backdrop .menubar > menuitem:hover,
.nemo-window:backdrop .menubar > menuitem:active,
.nemo-window:backdrop .menubar > menuitem:selected,
window.nemo-window.background:backdrop > grid > menubar > menuitem:hover,
window.nemo-window.background:backdrop > grid > menubar > menuitem:active,
window.nemo-window.background:backdrop > grid > menubar > menuitem:selected,
window.nemo-window.background:backdrop > grid > menubar > menuitem:backdrop:hover,
window.nemo-window.background:backdrop > grid > menubar > menuitem:backdrop:active,
window.nemo-window.background:backdrop > grid > menubar > menuitem:backdrop:selected {
    background: @surface0 !important;
    background-color: @surface0 !important;
    background-image: none !important;
    color: @text;
}

menu,
popover {
    background: @mantle;
    color: @text;
}

menuitem:hover {
    background: @surface0;
}

menuitem:selected {
    background: @accent;
    color: @crust;
}

/* Scrollbars */
scrollbar slider {
    background: @surface1;
    border-radius: 6px;
}

scrollbar slider:hover {
    background: @accent;
}

/* Entry */
entry {
    background: @surface0;
    color: @text;
    border: 1px solid @surface1;
}

entry:focus {
    border: 1px solid @accent;
}

/* ===== ROOT ===== */
filechooser {
    background: @base;
    color: @text;
    border-radius: 12px;
}

/* ===== HEADER BAR ===== */
filechooser headerbar {
    background: @mantle;
    color: @text;
    border: none;
    box-shadow: none;
}

/* Title + entry (filename input) */
filechooser entry {
    background: @surface0;
    color: @text;
    border-radius: 8px;
    border: 1px solid @surface1;
}

/* ===== SIDEBAR ===== */
filechooser .sidebar {
    background: @crust;
    color: @subtext;
}

/* Sidebar rows */
filechooser .sidebar row {
    border-radius: 8px;
    margin: 2px 6px;
}

/* Sidebar hover */
filechooser .sidebar row:hover {
    background: @surface0;
}

/* Sidebar selected */
filechooser .sidebar row:selected {
    background: @accent;
    color: @crust;
}

/* ===== FILE LIST ===== */
filechooser .view {
    background: @base;
    color: @text;
}

/* File rows */
filechooser .view row {
    border-radius: 8px;
}

/* Hover */
filechooser .view row:hover {
    background: @surface0;
}

/* Selected file */
filechooser .view row:selected {
    background: @accent;
    color: @crust;
}

/* ===== BUTTONS ===== */
filechooser button {
    background: @surface0;
    color: @text;
    border-radius: 8px;
    border: 1px solid @surface1;
}

/* Hover */
filechooser button:hover {
    background: @surface1;
}

/* Primary button (Save) */
filechooser button.suggested-action {
    background: @green;
    color: @crust;
}

/* Cancel button */
filechooser button.destructive-action {
    background: @red;
    color: @crust;
}

/* ===== PATH BAR ===== */
filechooser .path-bar button {
    background: transparent;
    color: @subtext;
}

filechooser .path-bar button:hover {
    background: @surface0;
    color: @text;
}

/* ===== SCROLLBARS ===== */
scrollbar slider {
    background: @surface2;
    border-radius: 6px;
}

scrollbar slider:hover {
    background: @accent;
}

/* ===== SEPARATORS ===== */
filechooser separator {
    background: @surface0;
}

/* ===== HEADERBAR (real target) ===== */
filechooser headerbar,
filechooser .headerbar {
    background: @mantle;
    color: @text;
    border: none;
    box-shadow: none;
}

/* inactive window */
filechooser headerbar:backdrop {
    background: @crust;
    color: @subtext;
}

/* ===== HEADERBAR BUTTONS (Cancel / Save) ===== */
filechooser headerbar button {
    background: @surface0;
    color: @text;
    border-radius: 8px;
    border: 1px solid @surface1;
}

/* hover */
filechooser headerbar button:hover {
    background: @surface1;
}

/* inactive buttons */
filechooser headerbar button:backdrop {
    background: @surface0;
    color: @subtext;
}

/* ===== PRIMARY ACTION (Save button) ===== */
filechooser headerbar button.suggested-action {
    background: @green;
    color: @crust;
    border: none;
}

/* ===== CANCEL BUTTON ===== */
filechooser headerbar button:not(.suggested-action) {
    background: @surface0;
    color: @text;
}

/* ===== WHOLE DIALOG ===== */
filechooser,
filechooser.background,
filechooser.csd,
filechooser > box,
filechooser > grid {
    background-color: @base;
    color: @text;
}

/* ===== TOP BAR / TITLEBAR / HEADERBAR ===== */
filechooser headerbar,
filechooser .headerbar,
filechooser.titlebar,
filechooser .titlebar,
filechooser decoration,
filechooser .background headerbar,
filechooser .background .titlebar,
filechooser > box > headerbar,
filechooser > box > .titlebar,
filechooser > grid > headerbar,
filechooser > grid > .titlebar {
    background: @mantle;
    background-color: @mantle;
    color: @text;
    border: none;
    box-shadow: none;
}

/* top bar when unfocused */
filechooser headerbar:backdrop,
filechooser .headerbar:backdrop,
filechooser.titlebar:backdrop,
filechooser .titlebar:backdrop {
    background: @crust;
    background-color: @crust;
    color: @subtext;
}

/* remove weird bright borders/shadows in top area */
filechooser headerbar *,
filechooser .headerbar *,
filechooser .titlebar *,
filechooser.titlebar * {
    box-shadow: none;
}

/* ===== HEADERBAR BUTTONS ===== */
filechooser headerbar button,
filechooser .headerbar button,
filechooser .titlebar button,
filechooser.titlebar button {
    background: @surface0;
    background-color: @surface0;
    color: @text;
    border: 1px solid @surface1;
    border-radius: 8px;
}

/* hover */
filechooser headerbar button:hover,
filechooser .headerbar button:hover,
filechooser .titlebar button:hover,
filechooser.titlebar button:hover {
    background: @surface1;
    background-color: @surface1;
    color: @text;
}

/* unfocused buttons */
filechooser headerbar button:backdrop,
filechooser .headerbar button:backdrop,
filechooser .titlebar button:backdrop,
filechooser.titlebar button:backdrop {
    background: @surface0;
    background-color: @surface0;
    color: @subtext;
}

/* Save button */
filechooser headerbar button.suggested-action,
filechooser .headerbar button.suggested-action,
filechooser .titlebar button.suggested-action,
filechooser.titlebar button.suggested-action {
    background: @green;
    background-color: @green;
    color: @crust;
    border: none;
}

/* filename entry */
filechooser entry,
filechooser headerbar entry,
filechooser .headerbar entry,
filechooser .titlebar entry {
    background: @surface0;
    background-color: @surface0;
    color: @text;
    border: 1px solid @surface1;
    border-radius: 8px;
    caret-color: @text;
}

/* focused entry */
filechooser entry:focus,
filechooser headerbar entry:focus,
filechooser .headerbar entry:focus,
filechooser .titlebar entry:focus {
    border-color: @blue;
    box-shadow: none;
}

/* search button / icon buttons in top bar */
filechooser button image,
filechooser headerbar button image,
filechooser .headerbar button image,
filechooser .titlebar button image {
    color: @text;
}

/* ===== SIDEBAR ===== */
filechooser placessidebar,
filechooser .sidebar,
filechooser .places-sidebar,
filechooser stacksidebar,
filechooser scrolledwindow.sidebar {
    background: @crust;
    background-color: @crust;
    color: @subtext;
}

filechooser placessidebar row,
filechooser .sidebar row,
filechooser .places-sidebar row {
    border-radius: 8px;
    margin: 2px 6px;
    color: @subtext;
}

filechooser placessidebar row:hover,
filechooser .sidebar row:hover,
filechooser .places-sidebar row:hover {
    background: @surface0;
    background-color: @surface0;
    color: @text;
}

filechooser placessidebar row:selected,
filechooser .sidebar row:selected,
filechooser .places-sidebar row:selected {
    background: @accent;
    background-color: @accent;
    color: @crust;
}

/* ===== FILE LIST ===== */
filechooser treeview,
filechooser treeview.view,
filechooser .view,
filechooser scrolledwindow,
filechooser viewport {
    background: @base;
    background-color: @base;
    color: @text;
}

filechooser treeview:selected,
filechooser .view:selected,
filechooser treeview.view:selected {
    background: @accent;
    background-color: @accent;
    color: @crust;
}

/* column header row */
filechooser treeview header button,
filechooser treeview.view header button {
    background: @surface0;
    background-color: @surface0;
    color: @text;
    border: 1px solid @surface1;
    border-radius: 0;
}

/* path bar */
filechooser .path-bar button,
filechooser pathbar button {
    background: transparent;
    background-color: transparent;
    color: @subtext;
    border: 1px solid @surface1;
    border-radius: 8px;
}

filechooser .path-bar button:hover,
filechooser pathbar button:hover {
    background: @surface0;
    background-color: @surface0;
    color: @text;
}

/* bottom type selector row */
filechooser combobox,
filechooser combobox button,
filechooser button.combo {
    background: @surface0;
    background-color: @surface0;
    color: @text;
    border: 1px solid @surface1;
    border-radius: 8px;
}

/* ===== FORCE TITLEBAR (this is what you're missing) ===== */
filechooser .titlebar,
filechooser headerbar.titlebar,
filechooser .background .titlebar {
    background: @mantle;
    background-color: @mantle;
    color: @text;
    border: none;
    box-shadow: none;
}

/* unfocused */
filechooser .titlebar:backdrop,
filechooser headerbar.titlebar:backdrop {
    background: @crust;
    background-color: @crust;
    color: @subtext;
}

/* EVERYTHING inside titlebar */
filechooser .titlebar * {
    background-color: transparent;
    color: @text;
    box-shadow: none;
}

/* buttons inside titlebar */
filechooser .titlebar button {
    background: @surface0;
    background-color: @surface0;
    color: @text;
    border: 1px solid @surface1;
    border-radius: 8px;
}

/* Save button */
filechooser .titlebar button.suggested-action {
    background: @green;
    background-color: @green;
    color: @crust;
    border: none;
}

/* ===== FIX WHITE TITLEBAR LAYER (REAL FIX) ===== */
filechooser.background,
filechooser.csd,
filechooser.background.csd,
filechooser.background > headerbar,
filechooser.background > box,
filechooser.background > grid {
    background: @mantle !important;
    background-color: @mantle !important;
}

/* also force decoration layer */
decoration,
filechooser decoration {
    background: @mantle !important;
    background-color: @mantle !important;
}

/* remove GTK light overlay */
filechooser.background.csd > * {
    background: transparent !important;
}

.background.csd {
    background: @mantle !important;
}

/* ===== KILL DEFAULT GTK TITLEBAR (REAL FIX) ===== */
.titlebar.default-decoration {
    background: @mantle !important;
    background-color: @mantle !important;
    border: none !important;
    box-shadow: none !important;
}

/* filechooser-specific override */
filechooser .titlebar.default-decoration,
filechooser headerbar.titlebar.default-decoration {
    background: @mantle !important;
    background-color: @mantle !important;
}

/* remove white overlay layer */
.background.csd {
    background: @mantle !important;
    background-color: @mantle !important;
}

/* force headerbar above it */
filechooser headerbar.titlebar {
    background: @mantle !important;
    background-color: @mantle !important;
}

/* ===== FILE PICKER MENU BAR (THE WHITE STRIP) ===== */
filechooser menubar {
    background: @mantle;
    background-color: @mantle;
    color: @text;
}

/* menu items */
filechooser menubar menuitem {
    background: transparent;
    color: @text;
}

/* hover */
filechooser menubar menuitem:hover {
    background: @surface0;
    color: @text;
}

/* active/open */
filechooser menubar menuitem:selected {
    background: @accent;
    color: @crust;
}

filechooser > box > menubar,
filechooser > grid > menubar,
menubar {
    background: @mantle !important;
    background-color: @mantle !important;
    color: @text !important;
}
