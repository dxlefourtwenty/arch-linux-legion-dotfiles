@import '/home/dxle/.config/themes/current/ward.css';

* {
    font-family = "JetBrainsMono Nerd Font";
}

NotificationPopup {
    background: transparent;
}

QFrame#notificationCard {
    background-color: var(--background);
    border: 2px solid var(--border-color);
    border-radius: 0;
}

QLabel#summaryLabel {
    color: var(--text-color);
    font-size: 11pt;
    font-weight: 700;
}

QLabel#bodyLabel {
    color: var(--text-color);
    font-size: 11pt;
    line-height: 1.35em;
}

QLabel#iconLabel {
    min-width: 0px;
}
