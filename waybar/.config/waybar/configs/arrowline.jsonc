{
	"layer": "top",
	"position": "top",
  "hidden": false,
  "output": "HDMI-A-1",
    "reload_style_on_change": true,
	"modules-left": [
		"hyprland/workspaces",
		"custom/arrow10",
    "custom/arrow11",
		"hyprland/window"
	],

	"modules-right": [
    "custom/arrow7",
    "custom/bluetooth",
		"custom/arrow6",
		"wireplumber",
		"custom/arrow5",
		"network",
		"custom/arrow4",
		"battery",
		"custom/arrow3",
		"clock#time",
		"custom/arrow2",
		"custom/wallpapers",
		"custom/arrow1",
		"custom/menu",
    "custom/arrow0",
    "custom/power"
	],

	// Modules
	"clock#time": {
        "format": "σ±ëç  {:%H:%M}",
        "align": 1,
        "justify": "right",
        "tooltip-format": "{:%I:%M %p ~  %a. %d.%m }",
        "timezones": [
            "America/Los_Angeles",
            "America/Los_Angeles",
        ],
        "on-click": "~/bin/toggle-dashboard",
    },
    
	"clock#date": {
		"format": "νΣΑ {:%d/%m}",
        "tooltip-format": "{:%I:%M %p ~  %a. %d.%m }",
        "timezones": [
            "Asia/Kolkata",
            "America/Los_Angeles",
        ],
        "actions":  {
            "on-click": "tz_up",
        }
	},

  // Modules configuration
  "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "warp-on-scroll": false,
      "show-special": true,
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span>",
      "format-icons": {
          "1": "ο΅¦",
          "2": "ο΅¦",
          "3": "ο΅¦",
          "4": "ο΅¦",
          "5": "ο΅¦",
          "6": "ο΅¦",
          "7": "ο΅¦",
          "8": "ο΅¦",
          "9": "ο΅¦",
          "10": "ο΅¦",
          "special": "+",
          "active": "ο³ë",
      },
      "persistent-workspaces": {
          "HDMI-A-1": [ 1,2,3,4,5 ],
      },
  },
  "hyprland/window": {
      "format": "{}",
      "max-length": 70,
      "tooltip": false,
      "rewrite": {
          "(.*)Hellpaper(.*)": "Select Background",
      },
  },

	"tray": {
		"icon-size": 18,
		"spacing": 10
	},
	
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {capacity}%",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "on-click": "/home/dxle/bin/menu-power-profile",
        "tooltip-format": "{capacity}%",
    },

	"temperature": {
		"critical-threshold": 90,
		"interval": 5,
		"format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {temperatureC}¬Α",
		"format-icons": [ "ο΄΄","ο΄ä","ο΄â","ο΄à","ο΄΅"],
	},
	
  "network": {
      "format": "",
      "on-click": "~/bin/launch-terminal-floating 1000 800 nmtui",
      "format-ethernet": "νΫ³",
      "format-wifi": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {signalStrength}%",
      "format-disconnected": "σΑûÉ no signal",
      "format-icons": ["σΑΔΩ ", "σΑΔΦ ", "σΑΔΫ ", "σΑΔΨ "],
      "tooltip-format-wifi": "{essid} ({signalStrength}%)",
      "tooltip-format-ethernet": "{ifname}",
      "tooltip-format-disconnected": "Disconnected",
  },

  "wireplumber": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {volume}%",
  "format-muted": "σΑùü  {volume}%",
  "format-icons": ["σΑ•Ä ", "σΑïΨ "],        
      "on-click": "~/bin/menu-audio",
      "on-click-right": "~/bin/launch-window-floating 1000 800 pavucontrol",
      "max-volume": 150,
      "scroll-step": 2,
      "tooltip-format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span>  {volume}%",
  },
    
	"niri/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},

    "niri/workspaces": {
        "format": "{value}",
        "on-click": "activate",
        "sort-by-number": true,
    },

	"custom/arrow1": {
		// "format": "ν²Ε",
		"format": "ν²≤",
		// "format": "ν²Κ",
		"tooltip": false
	},

