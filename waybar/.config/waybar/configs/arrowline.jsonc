{
	"layer": "top",
	"position": "top",
  "output": "HDMI-A-1",
    "reload_style_on_change": true,
	"modules-left": [
		"hyprland/workspaces",
		"custom/arrow10",
    "custom/arrow11",
		"hyprland/window"
	],

	"modules-right": [
    "custom/arrow7",
    "custom/bluetooth",
		"custom/arrow6",
		"wireplumber",
		"custom/arrow5",
		"network",
		"custom/arrow4",
		"battery",
		"custom/arrow3",
		"clock#time",
		"custom/arrow2",
		"custom/wallpapers",
		"custom/arrow1",
		"custom/menu",
    "custom/arrow0",
    "custom/power"
	],

	// Modules
	"clock#time": {
        "format": "у±‘Ќ  {:%H:%M}",
        "align": 1,
        "cursor": false,
        "justify": "right",
        "tooltip-format": "{:%I:%M %p ~  %a. %d.%m }",
        "timezones": [
            "America/Los_Angeles",
            "America/Los_Angeles",
        ],
        "actions":  {
            "on-click": "tz_up",
        }
    },
    
	"clock#date": {
		"format": "оЄ° {:%d/%m}",
        "tooltip-format": "{:%I:%M %p ~  %a. %d.%m }",
        "timezones": [
            "Asia/Kolkata",
            "America/Los_Angeles",
        ],
        "actions":  {
            "on-click": "tz_up",
        }
	},

  // Modules configuration
  "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "warp-on-scroll": false,
      "format": "{icon}",
      "format-icons": {
          "1": "п‡›",
          "2": "п‡›",
          "3": "п‡›",
          "4": "п‡›",
          "5": "п‡›",
          "6": "п‡›",
          "7": "п‡›",
          "8": "п‡›",
          "9": "п‡›",
          "10": "п‡›",
          "active": "п„‘",
      },
      "persistent-workspaces": {
          "HDMI-A-1": [ 1,2,3,4,5 ],
      },
  },
  "hyprland/window": {
      "format": "{}",
      "max-length": 70,
      "tooltip": false
  },

	"tray": {
		"icon-size": 18,
		"spacing": 10
	},
	
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "format": "{icon} {capacity}%",
        "format-icons": ["у°‚Ћ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "tooltip-format": "{capacity}%",
    },

	"temperature": {
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}В°",
		"format-icons": [ "п‹‹","п‹Љ","п‹‰","п‹€","п‹‡"],
	},
	
  "network": {
      "format": "",
      "cursor": false,
      "on-click": "~/bin/launch-terminal nmtui",
      "format-ethernet": "оЅ„",
      "format-wifi": "{icon} {signalStrength}%",
      "format-disconnected": "у°ћѓ no signal",
      "format-icons": ["у°ўї ", "у°ўј ", "у°ўЅ ", "у°ўѕ "],
      "tooltip-format-wifi": "{essid} ({signalStrength}%)",
      "tooltip-format-ethernet": "{ifname}",
      "tooltip-format-disconnected": "Disconnected",
  },

  "wireplumber": {
      "format": "{icon} {volume}%",
      "cursor": false,
  "format-muted": "у°ќџ",
  "format-icons": ["у°–Ђ ", "у°•ѕ "],        
      "on-click": "~/bin/menu-audio",
      "on-click-right": "pavucontrol",        
      "max-volume": 150,
      "scroll-step": 2,
      "tooltip-format": "{icon}  {volume}%",
  },
    
	"niri/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},

    "niri/workspaces": {
        "format": "{value}",
        "on-click": "activate",
        "sort-by-number": true,
    },

