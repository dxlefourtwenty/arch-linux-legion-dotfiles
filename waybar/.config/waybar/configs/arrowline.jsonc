		// "format": "ν²Κ",
		"tooltip": false
	},

  "custom/power": {
    "format": "οÄë ",
    "on-click": "~/bin/menu-power",
    "tooltip": false,
  },
  "custom/menu": {
    "format": "σΑΘ΅ ",
    "on-click": "~/bin/menu",
