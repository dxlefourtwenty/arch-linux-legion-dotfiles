{
	"layer":"top",
	"position":"top",
  "output": "HDMI-A-1",
   "reload_style_on_change": true,
   "spacing": 0,

   "margin-top": 10,
   "margin-right": 48,
   "margin-bottom": 0,
   "margin-left": 48,
    
	"modules-left"	: ["custom/menu", "custom/left-1", "hyprland/workspaces", "custom/left-2", "user"],
	"modules-center": ["hyprland/window"],
	"modules-right"	: [ "group/group-tools", "custom/left-1", "network","wireplumber","custom/left-2", "clock"],

    "custom/left-1": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">ţé╝</span>",
        "tooltip": false
    },

    "custom/left-2": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">ţé║</span>",
        "tooltip": false
    },

	"custom/menu": {
    "format": "<span font_desc=\"JetBrainsMono Nerd Font\">ˇ░úç</span> ",
    "on-click": "~/bin/menu",
    "tooltip-format": "Menu",
  },
	"user": {
       "format":"{user}'S DESK",
       "cursor": false,
       "interval": 60,
	},
   // "hyprland/workspaces": {
   //      "disable-scroll": true,
   //      "all-outputs": false,
   //      "warp-on-scroll": false,
   //      "show-special": true,
   //      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span>",
   //      "format-icons": {
   //          "1": "´çŤ",
   //          "2": "´çŤ",
   //          "3": "´çŤ",
   //          "4": "´çŤ",
   //          "5": "´çŤ",
   //          "6": "´çŤ",
   //          "7": "´çŤ",
   //          "8": "´çŤ",
   //          "9": "´çŤ",
   //          "10": "´çŤ",
   //          "socialspace": "<span font-size='12pt'>´ůş</span>",
   //          "discordspace": "<span font-size='12pt'>ˇ▒őŐ</span>",
   //          "mediaspace": "<span font-size='12pt'>´Çü</span>",
   //          "scratchpad": "´üÇ",
   //          "floating": "+",
   //          "active": "´äĹ"
   //      },
   //      "persistent-workspaces": {
   //      },
   //  },
    "hyprland/workspaces": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{windows}</span>",
      "format-empty": "<span font_desc=\"JetBrainsMono Nerd Font\">´ŹÖ</span>",
      "format-window-separator": "  / ",
      "window-rewrite-default": "ţş┐",
      "window-rewrite": {
        "title<.*youtube.*>": "´ů¬", // Windows whose titles contain "youtube"
        "title<.*chatgpt.*>": "ˇ░Üę",
        "class<.*chrome-chatgpt.*>": "ˇ░Üę",
        "class<.*chrome-github.*>": "ţÖŤ",
        "class<.*lutgen-studio.*>": "ˇ░ťő",
        "class<.*prismlauncher.*>": "´ć▓",
        "class<.*minecraft.*>": "ˇ░Ź│",
        "class<.*obsproject.Studio.*>": "´ÇŻ",
        "title<.*Claude.*>": "ˇ░Üę",
        "class<chromium>": "´ëĘ", // Windows whose classes are "chromium"
        "class<brave-browser>": "­čŽü", // Windows whose classes are "chromium"
        "class<chromium> title<.*github.*>": "´äô", // Windows whose class is "chromium" and title contains "github". Note that "class" always comes first.
        "class<.*chrome.*> title<.*Hyprland Wiki*>": "´ŹÖ", 
        "class<.*chrome.*> title<.*LazyVim.*>": "ˇ░ĺ▓", 
        "class<.*chrome.*> title<.*Bash.*>": "ˇ▒ćâ", 
        "class<.*chrome.*> title<.*Git Cheat Sheet.*>": "ţÖŁ", 
        "class<kitty>": "´äá", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<alacritty>": "´ĺë",
        "class<kitty> title<.*nvim.*>": "ţÜ«", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<localsend>": "´öÄ", // Windows whose classes are "chromium"
        "class<nemo>": "´ôô", // Windows whose classes are "chromium"
        "class<spotify>": "*´ć╝",
        "class<steam>": "´ćÂ",
        "class<obsidian>": "*´üä", // Windows whose classes are "obsidian"
        "class<vesktop>": "*´ç┐",
        "class<.*chrome-instagram.*>": "*ˇ░őż",
        "class<.*chrome-tiktok.*>": "*ˇ░Äç",
        "btop": "ţČŽ",
        "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
      },
      "show-special": true
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "tooltip": false,
        "rewrite": {
            "(.*)Hellpaper(.*)": "Select Background",
        },
    },
   "group/group-tools": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-info",
			"transition-left-to-right": true
		},
		"modules": [
			"custom/infolabel",
			"custom/btop",
			"custom/shot",
			"custom/wallpapers",
			"custom/theme",
		]
	}, 
	"custom/infolabel": {
       "format": "TOOLS",
       "tooltip": false
	},
   "custom/btop": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\"> ţĚą</span>",
		"tooltip-format": "Activity",
		"on-click":"~/bin/launch-terminal btop"
    },
   "custom/shot": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">´éâ</span>",
		"tooltip-format": "Screenshot",
		"on-click-right":"~/bin/menu-screenshot",
		"on-click":"~/bin/launch-screenshot-clipboard"
    },
    "custom/wallpapers": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">´Çż</span>",  
      "on-click": "~/bin/bg-set",
		  "tooltip-format": "Select Background",
    },
    "custom/theme": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">ţ╝Ľ</span>",  
      "on-click": "~/bin/menu-style",
		  "tooltip-format": "Style Configuration",
    },
   "wireplumber": {
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {volume}%",
		"format-muted":"<span font_desc=\"JetBrainsMono Nerd Font\">ˇ░Łč</span>",
		"format-icons": ["ˇ░ľÇ","ˇ░Ľż"],        
       "on-click": "~/bin/menu-audio",
       "on-click-right": "~/bin/launch-window-floating 1000 800 pavucontrol",       
       "max-volume": 120,
       "tooltip-format":"Volume: {volume}%",
    },
   "battery": {
       "bat":"BAT0",
       "interval": 60,
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {capacity}%",
       "format-icons": ["´ëä","´ëâ","´ëé","´ëü","´ëÇ"],
       "tooltip-format":"Battery: {capacity}%, {time}",
    }, 
   "network": {
       "format":"",
       "on-click": "~/bin/launch-terminal-floating 1000 800 nmtui",
       "format-ethernet":"<span font_desc=\"JetBrainsMono Nerd Font\">ţŻä</span>",
       "format-wifi":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {signalStrength}%",
       "format-disconnected":"<span font_desc=\"JetBrainsMono Nerd Font\">ˇ░Ąş</span>",
       "format-icons": ["ˇ░Ąč","ˇ░Ąó","ˇ░Ąą","ˇ░ĄĘ"],
       "tooltip-format-wifi":"{essid}: ({signalStrength}%)",
       "tooltip-format-ethernet":"{ifname}",
       "tooltip-format-disconnected":"Disconnected",
    },
   "clock": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">ˇ▒ĹŹ</span> {:%I:%M %p}",
		"tooltip-format":"ţ¬░  {:%a %m/%d}",
       "timezones": [
           "America/Los_Angeles",
        ],
       "actions":  {
           "on-click":"~/bin/toggle-dashboard",
        },
       "on-click":"~/bin/toggle-dashboard",
    },
    "mpris": {
       "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{player_icon}</span> {title}",
       "format-paused": "<span font_desc=\"JetBrainsMono Nerd Font\">{status_icon}</span> {title}",
       "player-icons": {
           "default": "´üő",
           "mpv": "´Ź«"
       },
       "status-icons": {
           "paused": "´üî"
	},
	// "ignored-players": ["firefox"]
}
}
