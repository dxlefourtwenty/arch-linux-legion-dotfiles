   //          "10": "’ćø",
   //          "socialspace": "<span font-size='12pt'>’ģŁ</span>",
   //          "discordspace": "<span font-size='12pt'>¾▒ŗŖ</span>",
   //          "mediaspace": "<span font-size='12pt'>’Ćü</span>",
   //          "scratchpad": "’üĆ",
   //          "floating": "+",
   //          "active": "’äæ"
