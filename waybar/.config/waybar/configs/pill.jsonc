{
	"layer":"top",
	"position":"top",
  "output": "HDMI-A-1",
   "reload_style_on_change": true,
   "spacing": 0,

   "margin-top": 8,
   "margin-right": 48,
   "margin-bottom": 0,
   "margin-left": 48,
    
	"modules-left"	: ["custom/menu", "custom/left-1", "hyprland/workspaces", "custom/left-2", "user"],
	"modules-center": ["hyprland/window"],
	"modules-right"	: [ "group/group-tools", "custom/left-1", "battery","network","wireplumber","custom/left-2", "clock"],

    "custom/left-1": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">ΌΓ╝</span>",
        "tooltip": false
    },

    "custom/left-2": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">ΌΓ║</span>",
        "tooltip": false
    },

	"custom/menu": {
    "format": "<span font_desc=\"JetBrainsMono Nerd Font\">≤░μΘ</span> ",
    "on-click": "~/bin/menu",
    "tooltip": false,
  },
	"user": {
       "format":"{user}'S DESK",
       "interval": 60,
	},
   // "hyprland/workspaces": {
   //      "disable-scroll": true,
   //      "all-outputs": false,
   //      "warp-on-scroll": false,
   //      "show-special": true,
   //      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span>",
   //      "format-icons": {
   //          "1": "ΎΘδ",
   //          "2": "ΎΘδ",
   //          "3": "ΎΘδ",
   //          "4": "ΎΘδ",
   //          "5": "ΎΘδ",
   //          "6": "ΎΘδ",
   //          "7": "ΎΘδ",
   //          "8": "ΎΘδ",
   //          "9": "ΎΘδ",
   //          "10": "ΎΘδ",
   //          "socialspace": "<span font-size='12pt'>ΎΖφ</span>",
   //          "discordspace": "<span font-size='12pt'>≤▒ΜΛ</span>",
   //          "mediaspace": "<span font-size='12pt'>ΎΑΒ</span>",
   //          "scratchpad": "ΎΒΑ",
   //          "floating": "+",
   //          "active": "ΎΕΣ"
   //      },
   //      "persistent-workspaces": {
   //      },
   //  },
    "hyprland/workspaces": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{windows}</span>",
      "format-empty": "<span font_desc=\"JetBrainsMono Nerd Font\">ΎΞβ</span>",
      "format-window-separator": "  ",
      "window-rewrite-default": "Όφ┐",
      "window-rewrite": {
        "title<.*youtube.*>": "ΎΖς", // Windows whose titles contain "youtube"
        "title<.*chatgpt.*>": "≤░γσ",
        "class<.*chrome-chatgpt.*>": "≤░γσ",
        "class<.*chrome-github.*>": "Όβδ",
        "class<.*lutgen-studio.*>": "≤░εΜ",
        "class<.*prismlauncher.*>": "ΎΗ▓",
        "class<.*minecraft.*>": "≤░Ξ│",
        "class<.*obsproject.Studio.*>": "ΎΑ╜",
        "title<.*Claude.*>": "≤░γσ",
        "class<chromium>": "ΎΚρ", // Windows whose classes are "chromium"
        "class<brave-browser>": "ΏθοΒ", // Windows whose classes are "chromium"
        "class<chromium> title<.*github.*>": "ΎΕΥ", // Windows whose class is "chromium" and title contains "github". Note that "class" always comes first.
        "class<.*chrome.*> title<.*Hyprland Wiki*>": "ΎΞβ", 
        "class<.*chrome.*> title<.*LazyVim.*>": "≤░Τ▓", 
        "class<.*chrome.*> title<.*Bash.*>": "≤▒ΗΔ", 
        "class<.*chrome.*> title<.*Git Cheat Sheet.*>": "Όβζ", 
        "class<kitty>": "ΎΕι", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<alacritty>": "ΎΤΚ",
        "class<kitty> title<.*nvim.*>": "Όγχ", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<localsend>": "ΎΦΟ", // Windows whose classes are "chromium"
        "class<nemo>": "ΎΥΥ", // Windows whose classes are "chromium"
        "class<spotify>": "*ΎΗ╝",
        "class<steam>": "ΎΗ╢",
        "class<obsidian>": "*ΎΒΕ", // Windows whose classes are "obsidian"
        "class<vesktop>": "*ΎΘ┐",
        "class<.*chrome-instagram.*>": "*≤░Μ╛",
        "class<.*chrome-tiktok.*>": "*≤░ΟΘ",
        "btop": "Όυο",
        "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
      },
      "show-special": true
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "tooltip": false,
        "rewrite": {
            "(.*)Hellpaper(.*)": "Select Background",
        },
    },
   "group/group-tools": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-info",
			"transition-left-to-right": true
		},
		"modules": [
			"custom/infolabel",
			"custom/htop",
			"custom/shot",
		]
	}, 
	"custom/infolabel": {
       "format": "TOOLS",
       "tooltip": false
	},
   "custom/htop": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">Ό╖ξ</span>",
		"tooltip-format": "top",
		"on-click":"alacritty -e btm"
    },
   "custom/shot": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">ΎΓΔ</span>",
		"tooltip-format": "screenshot",
		"on-click":"niri msg action screenshot-screen"
    },
   "wireplumber": {
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {volume}%",
		"format-muted":"<span font_desc=\"JetBrainsMono Nerd Font\">≤░ζθ</span>",
		"format-icons": ["≤░ΨΑ","≤░Χ╛"],        
       "on-click":"pavucontrol",        
       "max-volume": 150,
       "scroll-step": 2,
       "tooltip-format":"Volume: {volume}%",
    },
   "battery": {
       "bat":"BAT0",
       "interval": 60,
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {capacity}%",
       "format-icons": ["ΎΚΕ","ΎΚΔ","ΎΚΓ","ΎΚΒ","ΎΚΑ"],
       "tooltip-format":"Battery: {capacity}%, {time}",
    }, 
   "network": {
       "format":"",
       "on-click":"alacritty -e nmtui",
       "format-ethernet":"<span font_desc=\"JetBrainsMono Nerd Font\">Ό╜Ε</span>",
       "format-wifi":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {signalStrength}%",
       "format-disconnected":"<span font_desc=\"JetBrainsMono Nerd Font\">≤░νφ</span>",
       "format-icons": ["≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
       "tooltip-format-wifi":"{essid}: ({signalStrength}%)",
       "tooltip-format-ethernet":"{ifname}",
       "tooltip-format-disconnected":"Disconnected",
    },
   "clock": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">≤▒ΣΞ</span> {:%I:%M %p}",
		"tooltip-format":"{:%I:%M %p ~  %a. %d.%m }",
       "timezones": [
           "America/Los_Angeles",
        ],
       "actions":  {
           "on-click":"~/bin/toggle-dashboard",
        },
       "on-click":"~/bin/toggle-dashboard",
    },
    "mpris": {
       "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{player_icon}</span> {title}",
       "format-paused": "<span font_desc=\"JetBrainsMono Nerd Font\">{status_icon}</span> {title}",
       "player-icons": {
           "default": "ΎΒΜ",
           "mpv": "ΎΞχ"
       },
       "status-icons": {
           "paused": "ΎΒΝ"
	},
	// "ignored-players": ["firefox"]
}
}
