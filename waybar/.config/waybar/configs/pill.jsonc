    "hyprland/workspaces": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{windows}</span>",
      "format-empty": "<span font_desc=\"JetBrainsMono Nerd Font\">’ŹÖ</span>",
      "format-window-separator": "  / ",
      "window-rewrite-default": "ŅŁ┐",
      "window-rewrite": {
        "title<.*youtube.*>": "’ģ¬", // Windows whose titles contain "youtube"
        "title<.*chatgpt.*>": "¾░Ü®",
        "class<.*chrome-chatgpt.*>": "¾░Ü®",
        "class<.*chrome-github.*>": "ŅÖø",
        "class<.*lutgen-studio.*>": "¾░£ŗ",
        "class<.*prismlauncher.*>": "’å▓",
        "class<.*minecraft.*>": "¾░Ź│",
        "class<.*obsproject.Studio.*>": "’ĆĮ",
        "title<.*Claude.*>": "¾░Ü®",
        "title<.*Chromium.*>": "’ē©",
        "class<chromium>": "’ē©", // Windows whose classes are "chromium"
        "class<brave-browser>": "’üŁ", // Windows whose classes are "chromium"
        "class<chromium> title<.*github.*>": "’äō", // Windows whose class is "chromium" and title contains "github". Note that "class" always comes first.
        "class<.*chrome.*> title<.*Hyprland Wiki*>": "’ŹÖ", 
        "class<.*chrome.*> title<.*LazyVim.*>": "¾░Æ▓", 
        "class<.*chrome.*> title<.*Bash.*>": "¾▒åā", 
        "class<.*chrome.*> title<.*Git Cheat Sheet.*>": "ŅÖØ", 
        "class<kitty>": "’äĀ", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<alacritty>": "’Æē",
        "class<kitty> title<.*nvim.*>": "ŅÜ«", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<kitty> title<.*btop.*>": "¾░©ć", // Windows that contain "kitty" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
        "class<localsend>": "’öÄ", // Windows whose classes are "chromium"
        "class<nemo>": "’ōō", // Windows whose classes are "chromium"
        "class<spotify>": "*’å╝",
        "class<steam>": "’åČ",
        "class<obsidian>": "*’üä", // Windows whose classes are "obsidian"
        "class<vesktop>": "*’ć┐",
        "class<.*chrome-instagram.*>": "*¾░ŗŠ",
        "class<.*chrome-tiktok.*>": "*¾░Äć",
        "title<.* - (.*) - VSCodium>": "codium $1"  // captures part of the window title and formats it into output
      },
      "show-special": true
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "tooltip": false,
        "rewrite": {
            "^(.*) - YouTube - Chromium$": "’ģ¬  YouTube - $1",
        },
    },
   "group/group-tools": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-info",
			"transition-left-to-right": true
		},
		"modules": [
			"custom/infolabel",
			"custom/btop",
			"custom/shot",
			"custom/wallpapers",
			"custom/theme",
		]
	}, 
	"custom/infolabel": {
       "format": "TOOLS",
       "tooltip": false
	},
   "custom/btop": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\"> ¾░©ć</span>",
		"tooltip-format": "Activity",
		"on-click":"~/bin/launch-terminal btop"
    },
   "custom/shot": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">’éā</span>",
		"tooltip-format": "Screenshot",
		"on-click-right":"~/bin/menu-screenshot",
		"on-click":"~/bin/launch-screenshot-clipboard"
    },
    "custom/wallpapers": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">’ĆŠ</span>",  
      "on-click": "~/bin/bg-set",
		  "tooltip-format": "Select Background",
    },
    "custom/theme": {
      "format": "<span font_desc=\"JetBrainsMono Nerd Font\">Ņ╝Ģ</span>",  
      "on-click": "~/bin/menu-style",
		  "tooltip-format": "Style Configuration",
    },
   "wireplumber": {
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {volume}%",
		"format-muted":"<span font_desc=\"JetBrainsMono Nerd Font\">¾░Ø¤</span>",
		"format-icons": ["¾░¢Ć","¾░ĢŠ"],        
       "on-click": "~/bin/menu-audio",
       "on-click-right": "~/bin/launch-window-floating 1000 800 pavucontrol",       
       "max-volume": 120,
       "tooltip-format":"Volume: {volume}%",
    },
   "battery": {
       "bat":"BAT0",
       "interval": 60,
       "format":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {capacity}%",
       "format-icons": ["’ēä","’ēā","’ēé","’ēü","’ēĆ"],
       "tooltip-format":"Battery: {capacity}%, {time}",
    }, 
   "network": {
       "format":"",
       "on-click": "~/bin/launch-terminal-floating 1000 800 nmtui",
       "format-ethernet":"<span font_desc=\"JetBrainsMono Nerd Font\">ŅĮä</span>",
       "format-wifi":"<span font_desc=\"JetBrainsMono Nerd Font\">{icon}</span> {signalStrength}%",
       "format-disconnected":"<span font_desc=\"JetBrainsMono Nerd Font\">¾░żŁ</span>",
       "format-icons": ["¾░ż¤","¾░żó","¾░żź","¾░ż©"],
       "tooltip-format-wifi":"{essid}: ({signalStrength}%)",
       "tooltip-format-ethernet":"{ifname}",
       "tooltip-format-disconnected":"Disconnected",
    },
   "clock": {
		"format":"<span font_desc=\"JetBrainsMono Nerd Font\">¾▒æŹ</span> {:%I:%M %p}",
		"tooltip-format":"Ņ¬░  {:%a %m/%d}",
       "timezones": [
           "America/Los_Angeles",
        ],
       "actions":  {
           "on-click":"~/bin/toggle-dashboard",
        },
       "on-click":"~/bin/toggle-dashboard",
    },
    "mpris": {
       "format": "<span font_desc=\"JetBrainsMono Nerd Font\">{player_icon}</span> {title}",
       "format-paused": "<span font_desc=\"JetBrainsMono Nerd Font\">{status_icon}</span> {title}",
       "player-icons": {
           "default": "’üŗ",
           "mpv": "’Ź«"
       },
       "status-icons": {
           "paused": "’üī"
	},
	// "ignored-players": ["firefox"]
}
}
