{
	"layer":"top",
	"position":"top",
  "output": "HDMI-A-1",
   "reload_style_on_change": true,
   "spacing": 0,

   "margin-top": 10,
   "margin-right": 48,
   "margin-bottom": 0,
   "margin-left": 48,
    
	"modules-left"	: ["custom/menu", "custom/left-1", "hyprland/workspaces", "custom/left-2", "user"],
	"modules-center": ["hyprland/window"],
	"modules-right"	: [ "group/group-tools", "custom/left-1", "network","wireplumber","custom/left-2", "clock"],

    "custom/left-1": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">Ņé╝</span>",
        "tooltip": false
    },

    "custom/left-2": {
        "format" : "<span font_desc=\"JetBrainsMono Nerd Font\">Ņé║</span>",
        "tooltip": false
    },

	"custom/menu": {
    "format": "<span font_desc=\"JetBrainsMono Nerd Font\">¾░Żć</span> ",
    "on-click": "~/bin/menu",
    "tooltip-format": "Menu",
  },
	"user": {
       "format":"{user}'S DESK",
       "cursor": false,
       "interval": 60,
	},
   // "hyprland/workspaces": {
